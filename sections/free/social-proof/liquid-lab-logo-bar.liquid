{%- liquid
  assign section_id = section.id
  assign layout_type = section.settings.layout_type
  assign block_count = section.blocks.size
  assign needs_extra_render = false
  if block_count > 0 and block_count < 4
    assign needs_extra_render = true
  endif

  assign aria_label_value = section.settings.heading
  if aria_label_value == blank
    assign aria_label_value = 'Trusted brand logos'
  endif

  assign show_header = false
  if section.settings.show_heading and section.settings.heading != blank
    assign show_header = true
  endif
  if section.settings.show_subheading and section.settings.subheading != blank
    assign show_header = true
  endif

  assign show_cta_btn = false
  if section.settings.show_cta and section.settings.cta_label != blank
    assign show_cta_btn = true
  endif

  assign bg_alpha = section.settings.bg_color_opacity | times: 0.01
  assign gradient_alpha = section.settings.gradient_color_opacity | times: 0.01
  assign heading_alpha = section.settings.heading_color_opacity | times: 0.01
  assign subheading_alpha = section.settings.subheading_color_opacity | times: 0.01
  assign border_alpha = section.settings.border_color_opacity | times: 0.01
  assign cta_bg_alpha = section.settings.cta_bg_color_opacity | times: 0.01
  assign cta_text_alpha = section.settings.cta_text_color_opacity | times: 0.01
  assign cta_border_alpha = section.settings.cta_border_color_opacity | times: 0.01
  assign cta_hover_bg_alpha = section.settings.cta_hover_bg_color_opacity | times: 0.01
  assign cta_hover_text_alpha = section.settings.cta_hover_text_color_opacity | times: 0.01
  assign cta_hover_border_alpha = section.settings.cta_hover_border_color_opacity | times: 0.01

  assign logo_opacity_default_dec = section.settings.logo_opacity_default | times: 0.01
  assign logo_opacity_hover_dec = section.settings.logo_opacity_hover | times: 0.01

  assign edge_fade_size_pct = section.settings.marquee_edge_fade_size | append: '%'
-%}

<section
  id="lab-{{ section_id }}"
  class="lab_logo_bar lab_logo_bar--{{ layout_type }} color-{{ section.settings.color_scheme }} gradient{% if section.settings.entrance_animation %} lab_logo_bar--anim lab_logo_bar--anim-{{ section.settings.entrance_type }}{% endif %}{% if section.settings.spacing_size != 'custom' %} lab_section--spacing-{{ section.settings.spacing_size }}{% endif %}"
  data-lab-direction="{{ section.settings.marquee_direction }}"
  data-lab-pause-hover="{{ section.settings.marquee_pause_hover }}"
  data-lab-edge-fade="{{ section.settings.marquee_edge_fade }}"
  data-lab-layout="{{ layout_type }}"
  data-lab-spacing="{{ section.settings.spacing_size }}"
  aria-label="{{ aria_label_value | escape }}"
>
  <div class="lab_container lab_container--{{ section.settings.container_width }} lab_logo_bar__inner">
    {%- if show_header -%}
      <header class="lab_logo_bar__header" data-lab-align="{{ section.settings.header_align }}">
        {%- if section.settings.show_heading and section.settings.heading != blank -%}
          <h2 class="lab_logo_bar__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.show_subheading and section.settings.subheading != blank -%}
          <div class="lab_logo_bar__subheading">{{ section.settings.subheading }}</div>
        {%- endif -%}
      </header>
    {%- endif -%}

    {%- if block_count > 0 -%}
      {%- if layout_type == 'marquee' -%}
        <div class="lab_logo_bar__marquee" role="region" aria-label="{{ aria_label_value | escape }}">
          <div class="lab_logo_bar__track">
            {%- for block in section.blocks -%}
              <div class="lab_logo_bar__item" {{ block.shopify_attributes }}>
                {% render 'liquid-lab-logo-bar-item', block: block, section: section %}
              </div>
            {%- endfor -%}

            {%- for block in section.blocks -%}
              <div class="lab_logo_bar__item" aria-hidden="true">
                {% render 'liquid-lab-logo-bar-item', block: block, section: section %}
              </div>
            {%- endfor -%}

            {%- if needs_extra_render -%}
              {%- for i in (1..2) -%}
                {%- for block in section.blocks -%}
                  <div class="lab_logo_bar__item" aria-hidden="true">
                    {% render 'liquid-lab-logo-bar-item', block: block, section: section %}
                  </div>
                {%- endfor -%}
              {%- endfor -%}
            {%- endif -%}
          </div>
        </div>
      {%- else -%}
        <div class="lab_logo_bar__grid" role="region" aria-label="{{ aria_label_value | escape }}">
          {%- for block in section.blocks -%}
            <div class="lab_logo_bar__item" {{ block.shopify_attributes }}>
              {% render 'liquid-lab-logo-bar-item', block: block, section: section %}
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- endif -%}

    {%- if show_cta_btn -%}
      <div class="lab_logo_bar__cta-wrap">
        <a
          href="{{ section.settings.cta_url | default: '#' }}"
          class="lab_logo_bar__cta"
          data-lab-hover="{{ section.settings.cta_hover_effect }}"
        >
          {{ section.settings.cta_label | escape }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  #shopify-section-{{ section_id }} .lab_logo_bar {
    --lab-logo-height-mobile: {{ section.settings.logo_max_height_mobile }}px;
    --lab-logo-height-desktop: {{ section.settings.logo_max_height_desktop }}px;
    --lab-logo-fit: {{ section.settings.logo_object_fit }};
    --lab-logo-opacity-default: {{ logo_opacity_default_dec }};
    --lab-logo-opacity-hover: {{ logo_opacity_hover_dec }};
    --lab-logo-grayscale-default: {% if section.settings.logo_grayscale_default %}grayscale(100%){% else %}none{% endif %};
    --lab-logo-grayscale-hover: {% if section.settings.logo_grayscale_off_hover %}grayscale(0%){% else %}var(--lab-logo-grayscale-default){% endif %};
    --lab-marquee-duration: {{ section.settings.marquee_speed }}s;
    --lab-fade-size: {{ edge_fade_size_pct }};
    --lab-gap-mobile: {{ section.settings.items_gap_mobile }}px;
    --lab-gap-desktop: {{ section.settings.items_gap_desktop }}px;
    --lab-cols-mobile: {{ section.settings.columns_mobile }};
    --lab-cols-desktop: {{ section.settings.columns_desktop }};
    --lab-content-max: {{ section.settings.content_max_width }}px;
    position: relative;
    color: var(--color-foreground);
    {% if section.settings.bg_color != blank %}background-color: {{ section.settings.bg_color | color_modify: 'alpha', bg_alpha }};{% endif %}
    {% if section.settings.enable_gradient and section.settings.gradient_color != blank and section.settings.bg_color != blank %}
      {%- assign grad_dir = section.settings.gradient_direction -%}
      background-image: linear-gradient({{ grad_dir }}, {{ section.settings.bg_color | color_modify: 'alpha', bg_alpha }}, {{ section.settings.gradient_color | color_modify: 'alpha', gradient_alpha }});
    {% endif %}
    {% if section.settings.enable_border_top and section.settings.border_color != blank %}border-top: {{ section.settings.border_width }}px solid {{ section.settings.border_color | color_modify: 'alpha', border_alpha }};{% endif %}
    {% if section.settings.enable_border_bottom and section.settings.border_color != blank %}border-bottom: {{ section.settings.border_width }}px solid {{ section.settings.border_color | color_modify: 'alpha', border_alpha }};{% endif %}
  }

  #shopify-section-{{ section_id }} .lab_logo_bar__inner {
    box-sizing: border-box;
  }

  {% if section.settings.spacing_size == 'custom' %}
    #shopify-section-{{ section_id }} .lab_logo_bar {
      margin-top: {{ section.settings.spacing_top_custom }}px;
      margin-bottom: {{ section.settings.spacing_bottom_custom }}px;
    }
  {% endif %}

  /* Header ----------------------------------------------------------------- */
  #shopify-section-{{ section_id }} .lab_logo_bar__header {
    margin-bottom: clamp(1.5rem, 4vw, 3rem);
    max-width: var(--lab-content-max);
    margin-inline: auto;
  }
  #shopify-section-{{ section_id }} .lab_logo_bar__header[data-lab-align="left"]   { text-align: left; }
  #shopify-section-{{ section_id }} .lab_logo_bar__header[data-lab-align="center"] { text-align: center; }
  #shopify-section-{{ section_id }} .lab_logo_bar__header[data-lab-align="right"]  { text-align: right; }

  #shopify-section-{{ section_id }} .lab_logo_bar__heading {
    margin: 0 0 0.5rem;
    font-size: {{ section.settings.heading_size_mobile }}px;
    font-weight: {{ section.settings.heading_weight }};
    text-transform: {{ section.settings.heading_transform }};
    letter-spacing: {{ section.settings.heading_letter_spacing }}px;
    line-height: calc({{ section.settings.heading_line_height }} / 10);
    color: {% if section.settings.heading_color != blank %}{{ section.settings.heading_color | color_modify: 'alpha', heading_alpha }}{% else %}var(--color-foreground){% endif %};
  }

  #shopify-section-{{ section_id }} .lab_logo_bar__subheading {
    font-size: {{ section.settings.subheading_size_mobile }}px;
    font-weight: {{ section.settings.subheading_weight }};
    line-height: 1.5;
    color: {% if section.settings.subheading_color != blank %}{{ section.settings.subheading_color | color_modify: 'alpha', subheading_alpha }}{% else %}var(--color-foreground){% endif %};
  }
  #shopify-section-{{ section_id }} .lab_logo_bar__subheading > * { margin: 0 0 0.5rem; }
  #shopify-section-{{ section_id }} .lab_logo_bar__subheading > *:last-child { margin-bottom: 0; }

  /* Marquee ---------------------------------------------------------------- */
  #shopify-section-{{ section_id }} .lab_logo_bar__marquee {
    overflow: hidden;
    width: 100%;
  }

  #shopify-section-{{ section_id }} .lab_logo_bar__track {
    display: flex;
    width: max-content;
    gap: var(--lab-gap-mobile);
    align-items: center;
    animation: lab_logo_marquee_{{ section_id }} var(--lab-marquee-duration) linear infinite;
    will-change: transform;
  }

  #shopify-section-{{ section_id }} .lab_logo_bar[data-lab-direction="right"] .lab_logo_bar__track {
    animation-direction: reverse;
  }

  @keyframes lab_logo_marquee_{{ section_id }} {
    from { transform: translateX(0); }
    to   { transform: translateX(calc(-50% - (var(--lab-gap-mobile) / 2))); }
  }

  #shopify-section-{{ section_id }} .lab_logo_bar[data-lab-edge-fade="true"] .lab_logo_bar__marquee {
    -webkit-mask-image: linear-gradient(90deg, transparent 0%, black var(--lab-fade-size), black calc(100% - var(--lab-fade-size)), transparent 100%);
            mask-image: linear-gradient(90deg, transparent 0%, black var(--lab-fade-size), black calc(100% - var(--lab-fade-size)), transparent 100%);
  }

  /* Grid ------------------------------------------------------------------- */
  #shopify-section-{{ section_id }} .lab_logo_bar__grid {
    display: grid;
    grid-template-columns: repeat(var(--lab-cols-mobile), minmax(0, 1fr));
    gap: var(--lab-gap-mobile);
    align-items: center;
    justify-items: center;
    max-width: var(--lab-content-max);
    margin-inline: auto;
  }

  /* Item / link / image ---------------------------------------------------- */
  #shopify-section-{{ section_id }} .lab_logo_bar__item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #shopify-section-{{ section_id }} .lab_logo_bar__link,
  #shopify-section-{{ section_id }} .lab_logo_bar__static {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    min-width: 44px;
    padding: 0.5rem 0.75rem;
    box-sizing: border-box;
    text-decoration: none;
    color: inherit;
    border-radius: 4px;
    transition: opacity 0.25s ease, filter 0.25s ease, transform 0.25s ease;
    opacity: var(--lab-logo-opacity-override, var(--lab-logo-opacity-default));
    filter: var(--lab-logo-grayscale-default);
  }

  #shopify-section-{{ section_id }} .lab_logo_bar__link:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 3px;
  }

  #shopify-section-{{ section_id }} .lab_logo_bar__image {
    display: block;
    height: var(--lab-logo-height-override, var(--lab-logo-height-mobile));
    width: auto;
    max-width: 100%;
    object-fit: var(--lab-logo-fit);
  }

  #shopify-section-{{ section_id }} .lab_logo_bar__placeholder {
    fill: var(--color-foreground);
    opacity: 0.4;
  }

  @media (hover: hover) {
    #shopify-section-{{ section_id }} .lab_logo_bar__link:hover,
    #shopify-section-{{ section_id }} .lab_logo_bar__link:focus-visible {
      opacity: var(--lab-logo-opacity-override, var(--lab-logo-opacity-hover));
      filter: var(--lab-logo-grayscale-hover);
    }

    #shopify-section-{{ section_id }} .lab_logo_bar[data-lab-pause-hover="true"]:hover .lab_logo_bar__track {
      animation-play-state: paused;
    }
  }

  /* CTA -------------------------------------------------------------------- */
  #shopify-section-{{ section_id }} .lab_logo_bar__cta-wrap {
    margin-top: clamp(1.5rem, 4vw, 2.5rem);
    text-align: {{ section.settings.header_align }};
  }

  #shopify-section-{{ section_id }} .lab_logo_bar__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: {{ section.settings.cta_padding_y }}px {{ section.settings.cta_padding_x }}px;
    border-style: solid;
    border-width: {{ section.settings.cta_border_width }}px;
    border-radius: {{ section.settings.cta_border_radius }}px;
    text-decoration: none;
    font-weight: 500;
    line-height: 1.2;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
    background-color: {% if section.settings.cta_bg_color != blank %}{{ section.settings.cta_bg_color | color_modify: 'alpha', cta_bg_alpha }}{% else %}var(--color-button){% endif %};
    color: {% if section.settings.cta_text_color != blank %}{{ section.settings.cta_text_color | color_modify: 'alpha', cta_text_alpha }}{% else %}var(--color-button-text){% endif %};
    border-color: {% if section.settings.cta_border_color != blank %}{{ section.settings.cta_border_color | color_modify: 'alpha', cta_border_alpha }}{% else %}transparent{% endif %};
  }

  #shopify-section-{{ section_id }} .lab_logo_bar__cta:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 3px;
  }

  @media (hover: hover) {
    #shopify-section-{{ section_id }} .lab_logo_bar__cta[data-lab-hover="fill"]:hover,
    #shopify-section-{{ section_id }} .lab_logo_bar__cta[data-lab-hover="darken"]:hover,
    #shopify-section-{{ section_id }} .lab_logo_bar__cta[data-lab-hover="outline"]:hover {
      background-color: {% if section.settings.cta_hover_bg_color != blank %}{{ section.settings.cta_hover_bg_color | color_modify: 'alpha', cta_hover_bg_alpha }}{% else %}var(--color-button){% endif %};
      color: {% if section.settings.cta_hover_text_color != blank %}{{ section.settings.cta_hover_text_color | color_modify: 'alpha', cta_hover_text_alpha }}{% else %}var(--color-button-text){% endif %};
      border-color: {% if section.settings.cta_hover_border_color != blank %}{{ section.settings.cta_hover_border_color | color_modify: 'alpha', cta_hover_border_alpha }}{% else %}transparent{% endif %};
    }

    #shopify-section-{{ section_id }} .lab_logo_bar__cta[data-lab-hover="darken"]:hover {
      filter: brightness(0.85);
    }

    #shopify-section-{{ section_id }} .lab_logo_bar__cta[data-lab-hover="lift"]:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 16px rgba(0, 0, 0, 0.18);
    }

    #shopify-section-{{ section_id }} .lab_logo_bar__cta[data-lab-hover="glow"]:hover {
      box-shadow: 0 0 18px {% if section.settings.cta_hover_bg_color != blank %}{{ section.settings.cta_hover_bg_color | color_modify: 'alpha', 0.6 }}{% else %}rgba(0,0,0,0.25){% endif %};
    }
  }

  /* Entrance animation ----------------------------------------------------- */
  {% if section.settings.entrance_animation %}
    #shopify-section-{{ section_id }} .lab_logo_bar__header,
    #shopify-section-{{ section_id }} .lab_logo_bar__cta-wrap {
      opacity: 0;
      animation: lab_logo_entrance_{{ section_id }} 0.7s ease forwards 0.1s;
    }

    #shopify-section-{{ section_id }} .lab_logo_bar--anim-fade .lab_logo_bar__cta-wrap { animation-delay: 0.25s; }

    @keyframes lab_logo_entrance_{{ section_id }} {
      from {
        opacity: 0;
        {% if section.settings.entrance_type == 'slide-up' %}transform: translateY(16px);{% endif %}
      }
      to {
        opacity: 1;
        {% if section.settings.entrance_type == 'slide-up' %}transform: translateY(0);{% endif %}
      }
    }
  {% endif %}

  /* Reduced motion --------------------------------------------------------- */
  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section_id }} .lab_logo_bar__track {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transform: none !important;
      flex-wrap: wrap;
      justify-content: center;
      width: 100%;
    }
    #shopify-section-{{ section_id }} .lab_logo_bar__header,
    #shopify-section-{{ section_id }} .lab_logo_bar__cta-wrap {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
      opacity: 1 !important;
      transform: none !important;
    }
    #shopify-section-{{ section_id }} .lab_logo_bar__link,
    #shopify-section-{{ section_id }} .lab_logo_bar__cta {
      transition-duration: 0.01ms !important;
    }
  }

  /* Desktop breakpoint ----------------------------------------------------- */
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section_id }} .lab_logo_bar__heading {
      font-size: {{ section.settings.heading_size_desktop }}px;
    }

    #shopify-section-{{ section_id }} .lab_logo_bar__subheading {
      font-size: {{ section.settings.subheading_size_desktop }}px;
    }

    #shopify-section-{{ section_id }} .lab_logo_bar__track {
      gap: var(--lab-gap-desktop);
    }

    @keyframes lab_logo_marquee_{{ section_id }} {
      from { transform: translateX(0); }
      to   { transform: translateX(calc(-50% - (var(--lab-gap-desktop) / 2))); }
    }

    #shopify-section-{{ section_id }} .lab_logo_bar__grid {
      grid-template-columns: repeat(var(--lab-cols-desktop), minmax(0, 1fr));
      gap: var(--lab-gap-desktop);
    }

    #shopify-section-{{ section_id }} .lab_logo_bar__image {
      height: var(--lab-logo-height-override, var(--lab-logo-height-desktop));
    }
  }

  /* Visibility (§8.9) ------------------------------------------------------ */
  {% if section.settings.hide_on_mobile %}
    #shopify-section-{{ section_id }} { display: none; }
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section_id }} {
        display: {% if section.settings.hide_on_desktop %}none{% else %}revert{% endif %};
      }
    }
  {% elsif section.settings.hide_on_desktop %}
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section_id }} { display: none; }
    }
  {% endif %}

  /* Custom CSS ------------------------------------------------------------- */
  {% if section.settings.custom_css != blank %}
    #shopify-section-{{ section_id }} {
      {{ section.settings.custom_css }}
    }
  {% endif %}
</style>

{% if section.settings.layout_type == 'marquee' %}
<script>
  (function() {
    if (!window.Shopify || !Shopify.designMode) return;
    var section = document.getElementById('lab-{{ section_id }}');
    if (!section) return;
    var track = section.querySelector('.lab_logo_bar__track');
    if (!track) return;
    var slowed = ({{ section.settings.marquee_speed }} * 2) + 's';
    track.style.animationDuration = slowed;
  })();
</script>
{% endif %}

{% schema %}
{
  "name": "🧪 Logo Bar",
  "tag": "section",
  "class": "lab_section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 24,
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "checkbox", "id": "show_heading", "label": "Show heading", "default": true },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Trusted by leading brands", "visible_if": "{{ section.settings.show_heading }}" },
    { "type": "checkbox", "id": "show_subheading", "label": "Show subheading", "default": false },
    { "type": "richtext", "id": "subheading", "label": "Subheading", "default": "<p>Join 2,000+ stores already using our platform.</p>", "visible_if": "{{ section.settings.show_subheading }}" },
    { "type": "checkbox", "id": "show_cta", "label": "Show CTA button", "default": false },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "View all partners", "visible_if": "{{ section.settings.show_cta }}" },
    { "type": "url", "id": "cta_url", "label": "Button link", "visible_if": "{{ section.settings.show_cta }}" },

    { "type": "header", "content": "Typography" },
    { "type": "range", "id": "heading_size_mobile", "label": "Heading size (mobile)", "min": 14, "max": 48, "step": 1, "unit": "px", "default": 22 },
    { "type": "range", "id": "heading_size_desktop", "label": "Heading size (desktop)", "min": 18, "max": 80, "step": 1, "unit": "px", "default": 32 },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading weight",
      "options": [
        { "value": "300", "label": "Thin" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "select",
      "id": "heading_transform",
      "label": "Heading transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "uppercase"
    },
    {
      "type": "select",
      "id": "header_align",
      "label": "Header alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    { "type": "color", "id": "heading_color", "label": "Heading color" },
    { "type": "range", "id": "heading_color_opacity", "label": "Heading color opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 100 },
    { "type": "range", "id": "heading_letter_spacing", "label": "Heading letter spacing", "min": -2, "max": 10, "step": 1, "unit": "px", "default": 1 },
    { "type": "range", "id": "heading_line_height", "label": "Heading line height", "min": 10, "max": 20, "step": 1, "default": 12, "info": "Displayed as 1/10 (12 = 1.2)" },
    { "type": "range", "id": "subheading_size_mobile", "label": "Subheading size (mobile)", "min": 12, "max": 32, "step": 1, "unit": "px", "default": 14, "visible_if": "{{ section.settings.show_subheading }}" },
    { "type": "range", "id": "subheading_size_desktop", "label": "Subheading size (desktop)", "min": 14, "max": 40, "step": 1, "unit": "px", "default": 16, "visible_if": "{{ section.settings.show_subheading }}" },
    {
      "type": "select",
      "id": "subheading_weight",
      "label": "Subheading weight",
      "options": [
