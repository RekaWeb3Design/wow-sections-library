{% comment %} 1. Assigns {% endcomment %}
{% liquid
  assign section_id = section.id
  assign columns = section.settings.columns | default: 3
  assign alignment = section.settings.content_alignment | default: 'center'
  assign icon_type = section.settings.icon_type | default: 'emoji'
  assign card_style = section.settings.card_style | default: 'outlined'
  assign animation_enabled = section.settings.animation_enabled
  assign animation_type = section.settings.animation_type | default: 'fade'
  assign animation_delay = section.settings.animation_delay | default: 0
%}

{% comment %} 2. HTML structure {% endcomment %}
<div class="color-{{ section.settings.color_scheme }} gradient">
  <section
    id="wow-{{ section_id }}"
    class="wow_features_icons wow_features_icons--cols-{{ columns }} wow_features_icons--align-{{ alignment }} wow_features_icons--card-{{ card_style }}{% if section.settings.mobile_stack %} wow_features_icons--mobile-stack{% endif %}{% if animation_enabled %} wow_features_icons--animated wow_features_icons--anim-{{ animation_type }}{% endif %} wow_section"
    aria-label="{{ section.settings.heading | default: 'Features' | escape }}"
  >
    <div class="wow_features_icons__inner">
      {% if section.settings.heading != blank or section.settings.subheading != blank %}
        <header class="wow_features_icons__header">
          {% if section.settings.heading != blank %}
            <h2 class="wow_features_icons__title">{{ section.settings.heading | escape }}</h2>
          {% endif %}
          {% if section.settings.subheading != blank %}
            <p class="wow_features_icons__subtitle">{{ section.settings.subheading | escape | newline_to_br }}</p>
          {% endif %}
        </header>
      {% endif %}

      {% if section.blocks.size > 0 %}
        <ul class="wow_features_icons__grid" role="list">
          {% for block in section.blocks %}
            {% if block.type == 'feature' %}
              <li
                class="wow_features_icons__card"
                {{ block.shopify_attributes }}
                {% if animation_enabled %}style="--wow-anim-offset: {{ forloop.index0 | times: animation_delay }}ms;"{% endif %}
              >
                {% if icon_type == 'emoji' and block.settings.icon != blank %}
                  <span class="wow_features_icons__icon" aria-hidden="true">{{ block.settings.icon | escape }}</span>
                {% endif %}
                {% if block.settings.title != blank %}
                  <h3 class="wow_features_icons__card-title">{{ block.settings.title | escape }}</h3>
                {% endif %}
                {% if block.settings.description != blank %}
                  <p class="wow_features_icons__card-desc">{{ block.settings.description | escape | newline_to_br }}</p>
                {% endif %}
              </li>
            {% endif %}
          {% endfor %}
        </ul>
      {% endif %}
    </div>
  </section>
</div>

{% comment %} 3. CSS — section scoped {% endcomment %}
<style>
  #shopify-section-{{ section.id }} .wow_features_icons {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: var(--color-background);
    color: var(--color-foreground);
  }

  #shopify-section-{{ section.id }} .wow_features_icons__inner {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding-inline: clamp(1rem, 4vw, 3rem);
    display: flex;
    flex-direction: column;
    gap: clamp(2rem, 4vw, 3.5rem);
  }

  #shopify-section-{{ section.id }} .wow_features_icons__header {
    display: flex;
    flex-direction: column;
    gap: clamp(0.75rem, 1.5vw, 1.25rem);
    max-width: 52rem;
  }

  #shopify-section-{{ section.id }} .wow_features_icons--align-left .wow_features_icons__header {
    text-align: left;
    align-self: flex-start;
  }
  #shopify-section-{{ section.id }} .wow_features_icons--align-center .wow_features_icons__header {
    text-align: center;
    align-self: center;
  }
  #shopify-section-{{ section.id }} .wow_features_icons--align-right .wow_features_icons__header {
    text-align: right;
    align-self: flex-end;
  }

  #shopify-section-{{ section.id }} .wow_features_icons__title {
    margin: 0;
    font-size: clamp(1.75rem, 4vw, 3rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-foreground);
  }

  #shopify-section-{{ section.id }} .wow_features_icons__subtitle {
    margin: 0;
    font-size: clamp(1rem, 1.4vw, 1.125rem);
    line-height: 1.6;
    color: var(--color-foreground-75);
  }

  #shopify-section-{{ section.id }} .wow_features_icons__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: clamp(1rem, 2.5vw, 2rem);
    grid-template-columns: 1fr;
  }

  #shopify-section-{{ section.id }} .wow_features_icons--mobile-stack .wow_features_icons__grid {
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    #shopify-section-{{ section.id }} .wow_features_icons__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    #shopify-section-{{ section.id }} .wow_features_icons--cols-3 .wow_features_icons__grid {
      grid-template-columns: repeat(3, 1fr);
    }
    #shopify-section-{{ section.id }} .wow_features_icons--cols-4 .wow_features_icons__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  #shopify-section-{{ section.id }} .wow_features_icons__card {
    display: flex;
    flex-direction: column;
    gap: clamp(0.5rem, 1vw, 0.875rem);
    padding: clamp(1.25rem, 2.5vw, 2rem);
    border-radius: 0.75rem;
    background-color: transparent;
    border: 1px solid transparent;
    transition: transform 0.25s ease, border-color 0.25s ease, background-color 0.25s ease;
  }

  #shopify-section-{{ section.id }} .wow_features_icons--card-outlined .wow_features_icons__card {
    border-color: var(--color-border);
  }

  #shopify-section-{{ section.id }} .wow_features_icons--card-filled .wow_features_icons__card {
    background-color: var(--color-foreground);
    color: var(--color-background);
  }

  #shopify-section-{{ section.id }} .wow_features_icons--card-filled .wow_features_icons__card-title,
  #shopify-section-{{ section.id }} .wow_features_icons--card-filled .wow_features_icons__card-desc {
    color: var(--color-background);
  }

  #shopify-section-{{ section.id }} .wow_features_icons__card:hover {
    transform: translateY(-2px);
  }

  #shopify-section-{{ section.id }} .wow_features_icons--align-left .wow_features_icons__card {
    text-align: left;
    align-items: flex-start;
  }
  #shopify-section-{{ section.id }} .wow_features_icons--align-center .wow_features_icons__card {
    text-align: center;
    align-items: center;
  }
  #shopify-section-{{ section.id }} .wow_features_icons--align-right .wow_features_icons__card {
    text-align: right;
    align-items: flex-end;
  }

  #shopify-section-{{ section.id }} .wow_features_icons__icon {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    line-height: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: clamp(2.75rem, 5vw, 3.5rem);
    height: clamp(2.75rem, 5vw, 3.5rem);
    border-radius: 0.625rem;
    background-color: var(--color-background-contrast, transparent);
  }

  #shopify-section-{{ section.id }} .wow_features_icons__card-title {
    margin: 0;
    font-size: clamp(1.125rem, 1.75vw, 1.375rem);
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--color-foreground);
  }

  #shopify-section-{{ section.id }} .wow_features_icons__card-desc {
    margin: 0;
    font-size: clamp(0.9375rem, 1.2vw, 1rem);
    line-height: 1.55;
    color: var(--color-foreground-75);
  }

  #shopify-section-{{ section.id }} .wow_features_icons--animated .wow_features_icons__card {
    opacity: 0;
    will-change: opacity, transform;
    transition: opacity 0.6s ease, transform 0.6s ease;
    transition-delay: var(--wow-anim-offset, 0ms);
  }
  #shopify-section-{{ section.id }} .wow_features_icons--anim-fade .wow_features_icons__card {
    transform: none;
  }
  #shopify-section-{{ section.id }} .wow_features_icons--anim-slide .wow_features_icons__card {
    transform: translateY(1.25rem);
  }
  #shopify-section-{{ section.id }} .wow_features_icons--anim-zoom .wow_features_icons__card {
    transform: scale(0.96);
  }
  #shopify-section-{{ section.id }} .wow_features_icons--animated .wow_features_icons__card.is-visible {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .wow_features_icons__card,
    #shopify-section-{{ section.id }} .wow_features_icons--animated .wow_features_icons__card {
      transition: none;
      transform: none;
      opacity: 1;
    }
  }
</style>

{% comment %} 4. JavaScript — only when animation enabled {% endcomment %}
{% if section.settings.animation_enabled %}
  <script>
    (function() {
      var section = document.getElementById('wow-{{ section.id }}');
      if (!section) return;
      var cards = section.querySelectorAll('.wow_features_icons__card');
      if (!cards.length || !('IntersectionObserver' in window)) {
        cards.forEach(function(c) { c.classList.add('is-visible'); });
        return;
      }
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15 });
      cards.forEach(function(c) { observer.observe(c); });
      document.addEventListener('shopify:section:unload', function handler(e) {
        if (e.target !== section) return;
        observer.disconnect();
        document.removeEventListener('shopify:section:unload', handler);
      });
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "⚡ Features — Icons",
  "tag": "section",
  "class": "wow_section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    { "type": "header", "content": "Content" },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Everything you need"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "A short line that sums up the benefits below."
    },

    { "type": "header", "content": "Media" },
    {
      "type": "select",
      "id": "icon_type",
      "label": "Icon type",
      "options": [
        { "value": "emoji", "label": "Emoji / text" },
        { "value": "none", "label": "No icon" }
      ],
      "default": "emoji",
      "info": "Choose how each card renders its icon. Emoji lets you paste any character per block."
    },

    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns (desktop)",
      "options": [
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" }
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "checkbox",
      "id": "mobile_stack",
      "label": "Stack cards on mobile",
      "default": true
    },

    { "type": "header", "content": "Appearance" },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "card_style",
      "label": "Card style",
      "options": [
        { "value": "plain", "label": "Plain" },
        { "value": "outlined", "label": "Outlined" },
        { "value": "filled", "label": "Filled" }
      ],
      "default": "outlined"
    },

    { "type": "header", "content": "Animation" },
    {
      "type": "checkbox",
      "id": "animation_enabled",
      "label": "Enable animation",
      "default": false
    },
    {
      "type": "select",
      "id": "animation_type",
      "label": "Animation type",
      "options": [
        { "value": "fade", "label": "Fade" },
        { "value": "slide", "label": "Slide" },
        { "value": "zoom", "label": "Zoom" }
      ],
      "default": "fade",
      "visible_if": "{{ section.settings.animation_enabled }}"
    },
    {
      "type": "range",
      "id": "animation_delay",
      "label": "Animation delay (per card)",
      "min": 0,
      "max": 500,
      "step": 50,
      "unit": "ms",
      "default": 100,
      "visible_if": "{{ section.settings.animation_enabled }}"
    },

    { "type": "header", "content": "Spacing" },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature card",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji or character)",
          "default": "⚡"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Fast by default"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Short sentence that explains the value of this feature to the shopper."
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "⚡ Features — Icons",
      "category": "WOW Sections",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "⚡",
            "title": "Fast by default",
            "description": "Pages load instantly so shoppers never wait for the next step."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "🛡️",
            "title": "Safe checkout",
            "description": "Secure payments and clear returns — every single order."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "💬",
            "title": "Real support",
            "description": "Humans answer every question within one business day."
          }
        }
      ]
    }
  ]
}
{% endschema %}
