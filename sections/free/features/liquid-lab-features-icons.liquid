{% comment %} 1. Assigns {% endcomment %}
{% liquid
  assign section_id = section.id
  assign columns = section.settings.columns | default: 3
  assign alignment = section.settings.content_alignment | default: 'center'
  assign icon_type = section.settings.icon_type | default: 'emoji'
  assign animation_enabled = section.settings.animation_enabled
  assign animation_type = section.settings.animation_type | default: 'fade'
  assign animation_delay = section.settings.animation_delay | default: 0
  assign bg_pct = section.settings.bg_opacity
  assign bg_grad_pct = section.settings.bg_gradient_color_opacity
  assign card_hover = section.settings.feature_card_hover_transform
%}

{% comment %} Card shadow variant classes map to CSS tokens {% endcomment %}

{% comment %} 2. HTML structure {% endcomment %}
<div class="color-{{ section.settings.color_scheme }} gradient">
  <section
    id="lab-{{ section_id }}"
    class="lab_features_icons lab_features_icons--cols-{{ columns }} lab_features_icons--align-{{ alignment }} lab_features_icons--pos-{{ section.settings.content_position }} lab_features_icons--width-{{ section.settings.section_width }} lab_features_icons--shadow-{{ section.settings.feature_card_shadow }} lab_features_icons--hover-shadow-{{ section.settings.feature_card_hover_shadow }} lab_features_icons--hover-{{ card_hover }}{% if section.settings.mobile_stack %} lab_features_icons--mobile-stack{% endif %}{% if animation_enabled %} lab_features_icons--animated lab_features_icons--anim-{{ animation_type }}{% endif %} lab_section"
    aria-label="{{ section.settings.heading | default: 'Features' | escape }}"
  >
    <div class="lab_features_icons__inner">
      {% if section.settings.heading != blank or section.settings.subheading != blank %}
        <header class="lab_features_icons__header">
          {% if section.settings.heading != blank %}
            <h2 class="lab_features_icons__title">{{ section.settings.heading | escape }}</h2>
          {% endif %}
          {% if section.settings.subheading != blank %}
            <p class="lab_features_icons__subtitle">{{ section.settings.subheading | escape | newline_to_br }}</p>
          {% endif %}
        </header>
      {% endif %}

      {% if section.blocks.size > 0 %}
        <ul class="lab_features_icons__grid" role="list">
          {% for block in section.blocks %}
            {% if block.type == 'feature' %}
              {% liquid
                if block.settings.card_title_color != blank
                  assign ct_color = 'color-mix(in srgb, ' | append: block.settings.card_title_color | append: ' ' | append: block.settings.card_title_color_opacity | append: '%, transparent)'
                else
                  assign ct_color = 'var(--color-foreground)'
                endif
                if block.settings.card_desc_color != blank
                  assign cd_color = 'color-mix(in srgb, ' | append: block.settings.card_desc_color | append: ' ' | append: block.settings.card_desc_color_opacity | append: '%, transparent)'
                else
                  assign cd_color = 'var(--color-foreground-75)'
                endif
                assign anim_offset = forloop.index0 | times: animation_delay
              %}
              <li
                class="lab_features_icons__card"
                {{ block.shopify_attributes }}
                style="--lab-ct-size: {{ block.settings.card_title_size }}px; --lab-ct-weight: {{ block.settings.card_title_weight }}; --lab-ct-transform: {{ block.settings.card_title_transform }}; --lab-ct-color: {{ ct_color }}; --lab-ct-ls: calc({{ block.settings.card_title_letter_spacing }} / 100 * 1em); --lab-ct-lh: calc({{ block.settings.card_title_line_height }} / 10); --lab-cd-size: {{ block.settings.card_desc_size }}px; --lab-cd-weight: {{ block.settings.card_desc_weight }}; --lab-cd-transform: {{ block.settings.card_desc_transform }}; --lab-cd-color: {{ cd_color }}; --lab-cd-ls: calc({{ block.settings.card_desc_letter_spacing }} / 100 * 1em); --lab-cd-lh: calc({{ block.settings.card_desc_line_height }} / 10);{% if animation_enabled %} --lab-anim-offset: {{ anim_offset }}ms;{% endif %}"
              >
                {% if icon_type == 'emoji' and block.settings.icon != blank %}
                  <span class="lab_features_icons__icon" aria-hidden="true">{{ block.settings.icon | escape }}</span>
                {% endif %}
                {% if block.settings.title != blank %}
                  <h3 class="lab_features_icons__card-title">{{ block.settings.title | escape }}</h3>
                {% endif %}
                {% if block.settings.description != blank %}
                  <p class="lab_features_icons__card-desc">{{ block.settings.description | escape | newline_to_br }}</p>
                {% endif %}
              </li>
            {% endif %}
          {% endfor %}
        </ul>
      {% endif %}
    </div>
  </section>
</div>

{% comment %} 3. CSS — section scoped {% endcomment %}
<style>
  #shopify-section-{{ section.id }} .lab_features_icons {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    color: var(--color-foreground);
    {% if section.settings.bg_color != blank %}
      background-color: color-mix(in srgb, {{ section.settings.bg_color }} {{ bg_pct }}%, transparent);
    {% else %}
      background-color: var(--color-background);
    {% endif %}
    {% if section.settings.bg_gradient and section.settings.bg_color != blank and section.settings.bg_gradient_color != blank %}
      background-image: linear-gradient(
        {{ section.settings.bg_gradient_direction }},
        color-mix(in srgb, {{ section.settings.bg_color }} {{ bg_pct }}%, transparent),
        color-mix(in srgb, {{ section.settings.bg_gradient_color }} {{ bg_grad_pct }}%, transparent)
      );
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_features_icons__inner {
    width: 100%;
    max-width: {% if section.settings.section_width == 'full' %}100%{% elsif section.settings.section_width == 'narrow' %}860px{% else %}var(--page-width, 1200px){% endif %};
    margin-inline: auto;
    padding-inline: {% if section.settings.section_width == 'full' %}0{% else %}clamp(1rem, 4vw, 2rem){% endif %};
    display: flex;
    flex-direction: column;
    gap: clamp(2rem, 4vw, 3.5rem);
  }

  #shopify-section-{{ section.id }} .lab_features_icons__header {
    display: flex;
    flex-direction: column;
    gap: clamp(0.75rem, 1.5vw, 1.25rem);
    max-width: {{ section.settings.content_max_width }}px;
    width: 100%;
  }

  /* content_alignment controls text-align inside the header */
  #shopify-section-{{ section.id }} .lab_features_icons--align-left .lab_features_icons__header {
    text-align: left;
  }
  #shopify-section-{{ section.id }} .lab_features_icons--align-center .lab_features_icons__header {
    text-align: center;
  }
  #shopify-section-{{ section.id }} .lab_features_icons--align-right .lab_features_icons__header {
    text-align: right;
  }

  /* content_position controls where the header block sits within the inner — horizontal axis maps to align-self */
  #shopify-section-{{ section.id }} .lab_features_icons--pos-top-left .lab_features_icons__header,
  #shopify-section-{{ section.id }} .lab_features_icons--pos-center-left .lab_features_icons__header,
  #shopify-section-{{ section.id }} .lab_features_icons--pos-bottom-left .lab_features_icons__header {
    align-self: flex-start;
  }
  #shopify-section-{{ section.id }} .lab_features_icons--pos-top-center .lab_features_icons__header,
  #shopify-section-{{ section.id }} .lab_features_icons--pos-center .lab_features_icons__header,
  #shopify-section-{{ section.id }} .lab_features_icons--pos-bottom-center .lab_features_icons__header {
    align-self: center;
  }
  #shopify-section-{{ section.id }} .lab_features_icons--pos-top-right .lab_features_icons__header,
  #shopify-section-{{ section.id }} .lab_features_icons--pos-center-right .lab_features_icons__header,
  #shopify-section-{{ section.id }} .lab_features_icons--pos-bottom-right .lab_features_icons__header {
    align-self: flex-end;
  }

  /* content_position vertical axis: bottom variants render header AFTER the grid in column flow */
  #shopify-section-{{ section.id }} .lab_features_icons--pos-bottom-left .lab_features_icons__inner,
  #shopify-section-{{ section.id }} .lab_features_icons--pos-bottom-center .lab_features_icons__inner,
  #shopify-section-{{ section.id }} .lab_features_icons--pos-bottom-right .lab_features_icons__inner {
    flex-direction: column-reverse;
  }

  #shopify-section-{{ section.id }} .lab_features_icons__title {
    margin: 0;
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
    text-transform: {{ section.settings.heading_transform }};
    letter-spacing: calc({{ section.settings.heading_letter_spacing }} / 100 * 1em);
    line-height: calc({{ section.settings.heading_line_height }} / 10);
    {% if section.settings.heading_color != blank %}
      color: color-mix(in srgb, {{ section.settings.heading_color }} {{ section.settings.heading_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_features_icons__subtitle {
    margin: 0;
    font-size: {{ section.settings.subheading_size }}px;
    font-weight: {{ section.settings.subheading_weight }};
    text-transform: {{ section.settings.subheading_transform }};
    letter-spacing: calc({{ section.settings.subheading_letter_spacing }} / 100 * 1em);
    line-height: calc({{ section.settings.subheading_line_height }} / 10);
    {% if section.settings.subheading_color != blank %}
      color: color-mix(in srgb, {{ section.settings.subheading_color }} {{ section.settings.subheading_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground-75);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_features_icons__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: clamp(1rem, 2.5vw, 2rem);
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    #shopify-section-{{ section.id }} .lab_features_icons__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    #shopify-section-{{ section.id }} .lab_features_icons--cols-3 .lab_features_icons__grid {
      grid-template-columns: repeat(3, 1fr);
    }
    #shopify-section-{{ section.id }} .lab_features_icons--cols-4 .lab_features_icons__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  #shopify-section-{{ section.id }} .lab_features_icons__card {
    display: flex;
    flex-direction: column;
    gap: clamp(0.5rem, 1vw, 0.875rem);
    padding: {{ section.settings.feature_card_padding }}px;
    border-radius: {{ section.settings.feature_card_border_radius }}px;
    border: {{ section.settings.feature_card_border_width }}px solid {% if section.settings.feature_card_border_color != blank %}color-mix(in srgb, {{ section.settings.feature_card_border_color }} {{ section.settings.feature_card_border_color_opacity }}%, transparent){% else %}var(--color-border){% endif %};
    transition: transform 0.25s ease, border-color 0.25s ease, background-color 0.25s ease, box-shadow 0.25s ease;
    {% if section.settings.feature_card_bg_color != blank %}
      background-color: color-mix(in srgb, {{ section.settings.feature_card_bg_color }} {{ section.settings.feature_card_bg_color_opacity }}%, transparent);
    {% else %}
      background-color: transparent;
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_features_icons--shadow-none .lab_features_icons__card { box-shadow: none; }
  #shopify-section-{{ section.id }} .lab_features_icons--shadow-soft .lab_features_icons__card { box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05); }
  #shopify-section-{{ section.id }} .lab_features_icons--shadow-medium .lab_features_icons__card { box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08); }
  #shopify-section-{{ section.id }} .lab_features_icons--shadow-strong .lab_features_icons__card { box-shadow: 0 16px 40px rgba(0, 0, 0, 0.14); }

  #shopify-section-{{ section.id }} .lab_features_icons__card:hover {
    {% if section.settings.feature_card_hover_bg_color != blank %}
      background-color: color-mix(in srgb, {{ section.settings.feature_card_hover_bg_color }} {{ section.settings.feature_card_hover_bg_color_opacity }}%, transparent);
    {% endif %}
    {% if section.settings.feature_card_hover_border_color != blank %}
      border-color: color-mix(in srgb, {{ section.settings.feature_card_hover_border_color }} {{ section.settings.feature_card_hover_border_color_opacity }}%, transparent);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_features_icons--hover-shadow-soft .lab_features_icons__card:hover { box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05); }
  #shopify-section-{{ section.id }} .lab_features_icons--hover-shadow-medium .lab_features_icons__card:hover { box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08); }
  #shopify-section-{{ section.id }} .lab_features_icons--hover-shadow-strong .lab_features_icons__card:hover { box-shadow: 0 16px 40px rgba(0, 0, 0, 0.14); }

  #shopify-section-{{ section.id }} .lab_features_icons--hover-lift .lab_features_icons__card:hover {
    transform: translateY(-4px);
  }
  #shopify-section-{{ section.id }} .lab_features_icons--hover-scale .lab_features_icons__card:hover {
    transform: scale(1.02);
  }
  #shopify-section-{{ section.id }} .lab_features_icons--hover-border .lab_features_icons__card:hover {
    border-color: {% if section.settings.feature_card_hover_border_color != blank %}color-mix(in srgb, {{ section.settings.feature_card_hover_border_color }} {{ section.settings.feature_card_hover_border_color_opacity }}%, transparent){% else %}var(--color-foreground){% endif %};
  }
  #shopify-section-{{ section.id }} .lab_features_icons--hover-glow .lab_features_icons__card:hover {
    box-shadow: 0 0 28px {% if section.settings.feature_card_hover_bg_color != blank %}color-mix(in srgb, {{ section.settings.feature_card_hover_bg_color }} 45%, transparent){% else %}rgba(0, 0, 0, 0.16){% endif %};
  }

  #shopify-section-{{ section.id }} .lab_features_icons--align-left .lab_features_icons__card {
    text-align: left;
    align-items: flex-start;
  }
  #shopify-section-{{ section.id }} .lab_features_icons--align-center .lab_features_icons__card {
    text-align: center;
    align-items: center;
  }
  #shopify-section-{{ section.id }} .lab_features_icons--align-right .lab_features_icons__card {
    text-align: right;
    align-items: flex-end;
  }

  #shopify-section-{{ section.id }} .lab_features_icons__icon {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    line-height: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: clamp(2.75rem, 5vw, 3.5rem);
    height: clamp(2.75rem, 5vw, 3.5rem);
    border-radius: 0.625rem;
    background-color: var(--color-background-contrast, transparent);
  }

  #shopify-section-{{ section.id }} .lab_features_icons__card-title {
    margin: 0;
    font-size: var(--lab-ct-size, 20px);
    font-weight: var(--lab-ct-weight, 600);
    text-transform: var(--lab-ct-transform, none);
    letter-spacing: var(--lab-ct-ls, 0);
    line-height: var(--lab-ct-lh, 1.3);
    color: var(--lab-ct-color, var(--color-foreground));
  }

  #shopify-section-{{ section.id }} .lab_features_icons__card-desc {
    margin: 0;
    font-size: var(--lab-cd-size, 16px);
    font-weight: var(--lab-cd-weight, 400);
    text-transform: var(--lab-cd-transform, none);
    letter-spacing: var(--lab-cd-ls, 0);
    line-height: var(--lab-cd-lh, 1.55);
    color: var(--lab-cd-color, var(--color-foreground-75));
  }

  #shopify-section-{{ section.id }} .lab_features_icons--animated .lab_features_icons__card {
    opacity: 0;
    will-change: opacity, transform;
    transition: opacity 0.6s ease, transform 0.6s ease;
    transition-delay: var(--lab-anim-offset, 0ms);
  }
  #shopify-section-{{ section.id }} .lab_features_icons--anim-fade .lab_features_icons__card {
    transform: none;
  }
  #shopify-section-{{ section.id }} .lab_features_icons--anim-slide .lab_features_icons__card {
    transform: translateY(1.25rem);
  }
  #shopify-section-{{ section.id }} .lab_features_icons--anim-zoom .lab_features_icons__card {
    transform: scale(0.96);
  }
  #shopify-section-{{ section.id }} .lab_features_icons--animated .lab_features_icons__card.is-visible {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .lab_features_icons__card,
    #shopify-section-{{ section.id }} .lab_features_icons--animated .lab_features_icons__card {
      transition: none;
      transform: none;
      opacity: 1;
    }
  }

  {% if section.settings.hide_on_mobile %}
    #shopify-section-{{ section.id }} { display: none; }
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} {
        display: {% if section.settings.hide_on_desktop %}none{% else %}revert{% endif %};
      }
    }
  {% elsif section.settings.hide_on_desktop %}
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} { display: none; }
    }
  {% endif %}

  {% if section.settings.custom_css != blank %}
    #shopify-section-{{ section.id }} {
      {{ section.settings.custom_css }}
    }
  {% endif %}
</style>

{% comment %} 4. JavaScript — only when animation enabled {% endcomment %}
{% if section.settings.animation_enabled %}
  <script>
    (function() {
      var section = document.getElementById('lab-{{ section.id }}');
      if (!section) return;
      var cards = section.querySelectorAll('.lab_features_icons__card');
      if (!cards.length || !('IntersectionObserver' in window)) {
        cards.forEach(function(c) { c.classList.add('is-visible'); });
        return;
      }
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15 });
      cards.forEach(function(c) { observer.observe(c); });
      document.addEventListener('shopify:section:unload', function handler(e) {
        if (e.target !== section) return;
        observer.disconnect();
        document.removeEventListener('shopify:section:unload', handler);
      });
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "🧪 Features — Icons",
  "tag": "section",
  "class": "lab_section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Everything you need" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "A short line that sums up the benefits below." },

    { "type": "header", "content": "Typography" },
    { "type": "range", "id": "heading_size", "label": "Heading size", "min": 12, "max": 80, "step": 1, "unit": "px", "default": 40 },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading weight",
      "options": [
        { "value": "300", "label": "Thin" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "heading_transform",
      "label": "Heading transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "none"
    },
    { "type": "color", "id": "heading_color", "label": "Heading color" },
    { "type": "range", "id": "heading_color_opacity", "label": "Heading color opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 100 },
    { "type": "range", "id": "heading_letter_spacing", "label": "Heading letter spacing", "min": -5, "max": 20, "step": 1, "unit": "em", "default": -2, "info": "1/100em" },
    { "type": "range", "id": "heading_line_height", "label": "Heading line height", "min": 10, "max": 30, "step": 1, "default": 12, "info": "1/10 (15 = 1.5)" },

    { "type": "range", "id": "subheading_size", "label": "Subheading size", "min": 12, "max": 80, "step": 1, "unit": "px", "default": 17 },
    {
      "type": "select",
      "id": "subheading_weight",
      "label": "Subheading weight",
      "options": [
        { "value": "300", "label": "Thin" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "400"
    },
    {
      "type": "select",
      "id": "subheading_transform",
      "label": "Subheading transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "none"
    },
    { "type": "color", "id": "subheading_color", "label": "Subheading color" },
    { "type": "range", "id": "subheading_color_opacity", "label": "Subheading color opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 100 },
    { "type": "range", "id": "subheading_letter_spacing", "label": "Subheading letter spacing", "min": -5, "max": 20, "step": 1, "unit": "em", "default": 0 },
    { "type": "range", "id": "subheading_line_height", "label": "Subheading line height", "min": 10, "max": 30, "step": 1, "default": 16 },

    { "type": "header", "content": "Media" },
    {
      "type": "select",
      "id": "icon_type",
      "label": "Icon type",
      "options": [
        { "value": "emoji", "label": "Emoji / text" },
        { "value": "none", "label": "No icon" }
      ],
      "default": "emoji"
    },

    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns (desktop)",
      "options": [
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" }
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Header position",
      "options": [
        { "value": "top-left", "label": "Top left" },
        { "value": "top-center", "label": "Top center" },
        { "value": "top-right", "label": "Top right" },
        { "value": "center-left", "label": "Middle left" },
        { "value": "center", "label": "Middle center" },
        { "value": "center-right", "label": "Middle right" },
        { "value": "bottom-left", "label": "Bottom left" },
        { "value": "bottom-center", "label": "Bottom center" },
        { "value": "bottom-right", "label": "Bottom right" }
      ],
      "default": "center"
    },
    { "type": "range", "id": "content_max_width", "label": "Header max width", "min": 400, "max": 1400, "step": 50, "unit": "px", "default": 800 },
    { "type": "checkbox", "id": "mobile_stack", "label": "Stack cards on mobile", "default": true },
    { "type": "checkbox", "id": "hide_on_mobile", "label": "Hide on mobile", "default": false },
    { "type": "checkbox", "id": "hide_on_desktop", "label": "Hide on desktop", "default": false },
    {
      "type": "select",
      "id": "section_width",
