        "display_mode": "static",
        "show_close_button": false,
        "bar_height": 48,
        "bar_text_weight": "700",
        "bar_text_transform": "uppercase",
        "bar_text_letter_spacing": 2,
        "bar_text_color": "#e8e9ff",
        "bg_color": "#0a0b1a",
        "link_bg_color": "#7c6ff7",
        "link_text_color": "#ffffff",
        "link_border_color": "#7c6ff7",
        "link_border_width": 0,
        "link_border_radius": 8,
        "link_hover_effect": "lift"
      }
    },
    {
      "name": "⚡ Announcement — Warm",
      "category": "WOW Sections",
      "settings": {
        "bar_text": "Complimentary samples with every order",
