        "display_mode": "static",
        "show_close_button": true,
        "bar_height": 44,
        "bar_text_weight": "400",
        "bar_text_transform": "none",
        "bar_text_letter_spacing": -1,
        "bar_text_color": "#3d2c1e",
        "bg_color": "#fdf6ee",
        "link_bg_color": "#d4956a",
        "link_text_color": "#ffffff",
        "link_border_color": "#d4956a",
