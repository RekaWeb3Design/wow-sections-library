{% comment %} 1. Assigns {% endcomment %}
{% liquid
  assign section_id = section.id
  assign display_mode = section.settings.display_mode
  assign marquee_speed = section.settings.marquee_speed
  assign bar_height = section.settings.bar_height
  assign show_close = section.settings.show_close_button
  assign bar_text = section.settings.bar_text
  assign link_label = section.settings.link_label
  assign link_url = section.settings.link_url
  assign bg_pct = section.settings.bg_opacity
  assign bg_grad_pct = section.settings.bg_gradient_color_opacity
%}

{% comment %} 2. HTML structure {% endcomment %}
<div class="color-{{ section.settings.color_scheme }} gradient wow_announcement_bar__wrap">
  <aside
    id="wow-{{ section_id }}"
    class="wow_announcement_bar wow_announcement_bar--{{ display_mode }} wow_announcement_bar--link-hover-{{ section.settings.link_hover_effect }} wow_section"
    role="complementary"
    aria-label="{{ bar_text | default: 'Announcement' | escape }}"
    data-wow-announcement-id="{{ section_id }}"
  >
    <div class="wow_announcement_bar__inner">
      {% if display_mode == 'marquee' %}
        <div class="wow_announcement_bar__viewport" aria-hidden="false">
          <div class="wow_announcement_bar__track">
            {% for i in (1..2) %}
              <div class="wow_announcement_bar__group" {% if i == 2 %}aria-hidden="true"{% endif %}>
                {% for j in (1..4) %}
                  <span class="wow_announcement_bar__item">
                    {% if bar_text != blank %}
                      <span class="wow_announcement_bar__text">{{ bar_text | escape }}</span>
                    {% endif %}
                    {% if link_label != blank and link_url != blank %}
                      <a
                        href="{{ link_url }}"
                        class="wow_announcement_bar__link"
                        aria-label="{{ link_label | escape }}"
                      >
                        {{ link_label | escape }}
                      </a>
                    {% endif %}
                    <span class="wow_announcement_bar__sep" aria-hidden="true">•</span>
                  </span>
                {% endfor %}
              </div>
            {% endfor %}
          </div>
        </div>
      {% else %}
        <div class="wow_announcement_bar__static">
          {% if bar_text != blank %}
            <span class="wow_announcement_bar__text">{{ bar_text | escape }}</span>
          {% endif %}
          {% if link_label != blank and link_url != blank %}
            <a
              href="{{ link_url }}"
              class="wow_announcement_bar__link"
              aria-label="{{ link_label | escape }}"
            >
              {{ link_label | escape }}
            </a>
          {% endif %}
        </div>
      {% endif %}

      {% if show_close %}
        <button
          type="button"
          class="wow_announcement_bar__close"
          aria-label="Dismiss announcement"
          data-wow-announcement-close
        >
          <svg
            class="wow_announcement_bar__close-icon"
            viewBox="0 0 16 16"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            aria-hidden="true"
            focusable="false"
          >
            <path d="M4 4L12 12M12 4L4 12" />
          </svg>
        </button>
      {% endif %}
    </div>
  </aside>
</div>

{% comment %} 3. CSS — section scoped {% endcomment %}
<style>
  #shopify-section-{{ section.id }} .wow_announcement_bar__wrap {
    position: sticky;
    top: 0;
    z-index: 100;
  }

  #shopify-section-{{ section.id }} .wow_announcement_bar {
    width: 100%;
    min-height: {{ bar_height }}px;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    color: var(--color-foreground);
    border-bottom: 1px solid var(--color-border);
    overflow: hidden;
    {% if section.settings.bg_color != blank %}
      background-color: color-mix(in srgb, {{ section.settings.bg_color }} {{ bg_pct }}%, transparent);
    {% else %}
      background-color: var(--color-background);
    {% endif %}
    {% if section.settings.bg_gradient and section.settings.bg_color != blank and section.settings.bg_gradient_color != blank %}
      background-image: linear-gradient(
        {{ section.settings.bg_gradient_direction }},
        color-mix(in srgb, {{ section.settings.bg_color }} {{ bg_pct }}%, transparent),
        color-mix(in srgb, {{ section.settings.bg_gradient_color }} {{ bg_grad_pct }}%, transparent)
      );
    {% endif %}
  }

  #shopify-section-{{ section.id }} .wow_announcement_bar__inner {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
    max-width: {% if section.settings.section_width == 'full' %}100%{% elsif section.settings.section_width == 'narrow' %}860px{% else %}var(--page-width, 1200px){% endif %};
    margin-inline: auto;
    min-height: {{ bar_height }}px;
    padding-inline: clamp(0.75rem, 3vw, 2rem);
    gap: clamp(0.5rem, 2vw, 1.5rem);
  }

  #shopify-section-{{ section.id }} .wow_announcement_bar__static {
    flex: 1 1 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(0.5rem, 1.5vw, 1rem);
    flex-wrap: wrap;
  }

  #shopify-section-{{ section.id }} .wow_announcement_bar__text {
    font-size: {{ section.settings.bar_text_size }}px;
    font-weight: {{ section.settings.bar_text_weight }};
    text-transform: {{ section.settings.bar_text_transform }};
    letter-spacing: calc({{ section.settings.bar_text_letter_spacing }} / 100 * 1em);
    line-height: calc({{ section.settings.bar_text_line_height }} / 10);
    {% if section.settings.bar_text_color != blank %}
      color: color-mix(in srgb, {{ section.settings.bar_text_color }} {{ section.settings.bar_text_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .wow_announcement_bar__viewport {
    flex: 1 1 auto;
    overflow: hidden;
    mask-image: linear-gradient(
      to right,
      transparent 0,
      var(--color-foreground) 3rem,
      var(--color-foreground) calc(100% - 3rem),
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0,
      var(--color-foreground) 3rem,
      var(--color-foreground) calc(100% - 3rem),
      transparent 100%
    );
  }

  #shopify-section-{{ section.id }} .wow_announcement_bar__track {
    display: flex;
    width: max-content;
    will-change: transform;
    animation: wow_announcement_marquee_{{ section.id }} {{ marquee_speed }}s linear infinite;
  }

  #shopify-section-{{ section.id }} .wow_announcement_bar__group {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    gap: clamp(1rem, 3vw, 2.5rem);
    padding-inline-end: clamp(1rem, 3vw, 2.5rem);
  }

  #shopify-section-{{ section.id }} .wow_announcement_bar__item {
    display: inline-flex;
    align-items: center;
    gap: clamp(0.5rem, 1.25vw, 1rem);
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .wow_announcement_bar__sep {
    opacity: 0.5;
    font-size: 0.75em;
  }

  #shopify-section-{{ section.id }} .wow_announcement_bar__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ section.settings.link_padding_y }}px {{ section.settings.link_padding_x }}px;
    border-radius: {{ section.settings.link_border_radius }}px;
    border: {{ section.settings.link_border_width }}px solid {% if section.settings.link_border_color != blank %}color-mix(in srgb, {{ section.settings.link_border_color }} {{ section.settings.link_border_color_opacity }}%, transparent){% else %}transparent{% endif %};
    text-decoration: underline;
    text-underline-offset: 0.2em;
    font-weight: 600;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
    {% if section.settings.link_bg_color != blank %}
      background-color: color-mix(in srgb, {{ section.settings.link_bg_color }} {{ section.settings.link_bg_color_opacity }}%, transparent);
    {% else %}
      background-color: transparent;
    {% endif %}
    {% if section.settings.link_text_color != blank %}
      color: color-mix(in srgb, {{ section.settings.link_text_color }} {{ section.settings.link_text_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .wow_announcement_bar--link-hover-fill .wow_announcement_bar__link:hover,
  #shopify-section-{{ section.id }} .wow_announcement_bar--link-hover-darken .wow_announcement_bar__link:hover,
  #shopify-section-{{ section.id }} .wow_announcement_bar--link-hover-lift .wow_announcement_bar__link:hover,
  #shopify-section-{{ section.id }} .wow_announcement_bar--link-hover-glow .wow_announcement_bar__link:hover {
    {% if section.settings.link_hover_bg_color != blank %}
      background-color: color-mix(in srgb, {{ section.settings.link_hover_bg_color }} {{ section.settings.link_hover_bg_color_opacity }}%, transparent);
    {% endif %}
    {% if section.settings.link_hover_text_color != blank %}
      color: color-mix(in srgb, {{ section.settings.link_hover_text_color }} {{ section.settings.link_hover_text_color_opacity }}%, transparent);
    {% endif %}
    {% if section.settings.link_hover_border_color != blank %}
      border-color: color-mix(in srgb, {{ section.settings.link_hover_border_color }} {{ section.settings.link_hover_border_color_opacity }}%, transparent);
    {% endif %}
  }
  #shopify-section-{{ section.id }} .wow_announcement_bar--link-hover-darken .wow_announcement_bar__link:hover {
    filter: brightness(0.85);
  }
  #shopify-section-{{ section.id }} .wow_announcement_bar--link-hover-lift .wow_announcement_bar__link:hover {
    transform: translateY(-1px);
  }
  #shopify-section-{{ section.id }} .wow_announcement_bar--link-hover-glow .wow_announcement_bar__link:hover {
    box-shadow: 0 0 18px {% if section.settings.link_hover_bg_color != blank %}color-mix(in srgb, {{ section.settings.link_hover_bg_color }} 55%, transparent){% else %}rgba(0, 0, 0, 0.15){% endif %};
  }
  #shopify-section-{{ section.id }} .wow_announcement_bar--link-hover-outline .wow_announcement_bar__link:hover {
    background-color: transparent;
    {% if section.settings.link_hover_text_color != blank %}
      color: color-mix(in srgb, {{ section.settings.link_hover_text_color }} {{ section.settings.link_hover_text_color_opacity }}%, transparent);
    {% endif %}
    {% if section.settings.link_hover_border_color != blank %}
      border-color: color-mix(in srgb, {{ section.settings.link_hover_border_color }} {{ section.settings.link_hover_border_color_opacity }}%, transparent);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .wow_announcement_bar__close {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    padding: 0;
    background: transparent;
    color: inherit;
    border: 0;
    border-radius: 999px;
    cursor: pointer;
    opacity: 0.7;
    transition: opacity 0.2s ease, background-color 0.2s ease;
  }

  #shopify-section-{{ section.id }} .wow_announcement_bar__close:hover,
  #shopify-section-{{ section.id }} .wow_announcement_bar__close:focus-visible {
    opacity: 1;
    background-color: var(--color-border);
    outline: none;
  }

  #shopify-section-{{ section.id }} .wow_announcement_bar__close-icon {
    width: 0.875rem;
    height: 0.875rem;
  }

  @keyframes wow_announcement_marquee_{{ section.id }} {
    from { transform: translate3d(0, 0, 0); }
    to { transform: translate3d(-50%, 0, 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .wow_announcement_bar__track {
      animation: none;
      transform: none;
    }
    #shopify-section-{{ section.id }} .wow_announcement_bar__link {
      transition: none;
    }
  }

  @media (min-width: 750px) {
    #shopify-section-{{ section.id }} .wow_announcement_bar__inner {
      padding-inline: clamp(1.5rem, 4vw, 3rem);
    }
  }

  {% if section.settings.hide_on_mobile %}
    @media (max-width: 749px) {
      #shopify-section-{{ section.id }} { display: none; }
    }
  {% endif %}
  {% if section.settings.hide_on_desktop %}
    @media (min-width: 750px) {
      #shopify-section-{{ section.id }} { display: none; }
    }
  {% endif %}

  {% if section.settings.custom_css != blank %}
    #shopify-section-{{ section.id }} {
      {{ section.settings.custom_css }}
    }
  {% endif %}
</style>

{% comment %} 4. JavaScript — close button dismiss (marquee animation is pure CSS) {% endcomment %}
{% if show_close %}
  <script>
    (function () {
      var section = document.getElementById('wow-{{ section.id }}');
      if (!section) return;

      var wrap = section.parentElement;
      var storageKey = 'wow_announcement_bar_dismissed_{{ section.id }}';
      var closeBtn = section.querySelector('[data-wow-announcement-close]');

      try {
        if (window.localStorage && localStorage.getItem(storageKey) === '1' && !window.Shopify) {
          if (wrap && wrap.parentNode) wrap.parentNode.removeChild(wrap);
          return;
        }
      } catch (err) {
        /* localStorage unavailable — continue */
      }

      function handleClose() {
        try {
          if (window.localStorage) localStorage.setItem(storageKey, '1');
        } catch (err) {
          /* ignore */
        }
        if (wrap && wrap.parentNode) wrap.parentNode.removeChild(wrap);
      }

      function handleUnload(e) {
        if (e.target !== section) return;
        if (closeBtn) closeBtn.removeEventListener('click', handleClose);
        document.removeEventListener('shopify:section:unload', handleUnload);
      }

      if (closeBtn) closeBtn.addEventListener('click', handleClose);
      document.addEventListener('shopify:section:unload', handleUnload);
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "⚡ Announcement Bar",
  "tag": "section",
  "class": "wow_section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "bar_text", "label": "Announcement text", "default": "Free shipping on orders over $50 🎉" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "Shop now" },
    { "type": "url", "id": "link_url", "label": "Link URL" },

    { "type": "header", "content": "Typography" },
    { "type": "range", "id": "bar_text_size", "label": "Text size", "min": 12, "max": 80, "step": 1, "unit": "px", "default": 14 },
    {
      "type": "select",
      "id": "bar_text_weight",
      "label": "Text weight",
      "options": [
        { "value": "300", "label": "Thin" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "500"
    },
    {
      "type": "select",
      "id": "bar_text_transform",
      "label": "Text transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "none"
    },
    { "type": "color", "id": "bar_text_color", "label": "Text color" },
    { "type": "range", "id": "bar_text_color_opacity", "label": "Text color opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 100 },
    { "type": "range", "id": "bar_text_letter_spacing", "label": "Text letter spacing", "min": -5, "max": 20, "step": 1, "unit": "em", "default": 0, "info": "1/100em" },
    { "type": "range", "id": "bar_text_line_height", "label": "Text line height", "min": 10, "max": 30, "step": 1, "default": 14, "info": "1/10" },

    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "display_mode",
      "label": "Display mode",
      "options": [
        { "value": "static", "label": "Static (centered)" },
        { "value": "marquee", "label": "Marquee (scrolling)" }
      ],
      "default": "static"
    },
    {
      "type": "range",
      "id": "marquee_speed",
      "label": "Scroll speed",
      "min": 20,
      "max": 100,
      "step": 10,
      "unit": "s",
      "default": 40,
      "visible_if": "{{ section.settings.display_mode == 'marquee' }}"
    },
    { "type": "checkbox", "id": "show_close_button", "label": "Show close button", "default": true },
    { "type": "checkbox", "id": "hide_on_mobile", "label": "Hide on mobile", "default": false },
    { "type": "checkbox", "id": "hide_on_desktop", "label": "Hide on desktop", "default": false },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "full", "label": "Full width" },
        { "value": "boxed", "label": "Boxed (theme width)" },
        { "value": "narrow", "label": "Narrow" }
      ],
      "default": "full"
    },

    { "type": "header", "content": "Appearance" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "range", "id": "bar_height", "label": "Bar height", "min": 32, "max": 80, "step": 4, "unit": "px", "default": 44 },

    { "type": "color", "id": "bg_color", "label": "Background color" },
    { "type": "range", "id": "bg_opacity", "label": "Background opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 100 },
    { "type": "checkbox", "id": "bg_gradient", "label": "Enable gradient background", "default": false },
    { "type": "color", "id": "bg_gradient_color", "label": "Gradient second color", "visible_if": "{{ section.settings.bg_gradient }}" },
    { "type": "range", "id": "bg_gradient_color_opacity", "label": "Gradient second color opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 100, "visible_if": "{{ section.settings.bg_gradient }}" },
    {
      "type": "select",
      "id": "bg_gradient_direction",
      "label": "Gradient direction",
      "options": [
        { "value": "to bottom", "label": "To bottom" },
        { "value": "to right", "label": "To right" },
        { "value": "to bottom right", "label": "To bottom right" },
        { "value": "to bottom left", "label": "To bottom left" }
      ],
      "default": "to right",
      "visible_if": "{{ section.settings.bg_gradient }}"
    },

    { "type": "color", "id": "link_bg_color", "label": "Link background color" },
    { "type": "range", "id": "link_bg_color_opacity", "label": "Link background color opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 100 },
    { "type": "color", "id": "link_text_color", "label": "Link text color" },
    { "type": "range", "id": "link_text_color_opacity", "label": "Link text color opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 100 },
    { "type": "color", "id": "link_border_color", "label": "Link border color" },
    { "type": "range", "id": "link_border_color_opacity", "label": "Link border color opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 100 },
    { "type": "range", "id": "link_border_width", "label": "Link border width", "min": 0, "max": 6, "step": 1, "unit": "px", "default": 0 },
    { "type": "range", "id": "link_border_radius", "label": "Link border radius", "min": 0, "max": 50, "step": 2, "unit": "px", "default": 4 },
    { "type": "range", "id": "link_padding_x", "label": "Link horizontal padding", "min": 8, "max": 80, "step": 2, "unit": "px", "default": 8 },
    { "type": "range", "id": "link_padding_y", "label": "Link vertical padding", "min": 4, "max": 40, "step": 2, "unit": "px", "default": 4 },
    {
      "type": "select",
      "id": "link_hover_effect",
      "label": "Link hover effect",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "fill", "label": "Fill" },
        { "value": "darken", "label": "Darken" },
        { "value": "lift", "label": "Lift" },
        { "value": "outline", "label": "Outline" },
        { "value": "glow", "label": "Glow" }
      ],
      "default": "darken"
    },
    { "type": "color", "id": "link_hover_bg_color", "label": "Link hover background color" },
    { "type": "range", "id": "link_hover_bg_color_opacity", "label": "Link hover background color opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 100 },
    { "type": "color", "id": "link_hover_text_color", "label": "Link hover text color" },
    { "type": "range", "id": "link_hover_text_color_opacity", "label": "Link hover text color opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 100 },
    { "type": "color", "id": "link_hover_border_color", "label": "Link hover border color" },
    { "type": "range", "id": "link_hover_border_color_opacity", "label": "Link hover border color opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 100 },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 40, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 40, "step": 4, "unit": "px", "default": 0 },

    { "type": "header", "content": "Custom CSS" },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "info": "Advanced: add custom CSS that applies only to this section. Wrap selectors in #shopify-section-{{ section.id }} for proper scoping."
    }
  ],
  "presets": [
    {
      "name": "⚡ Announcement — Dark",
      "category": "WOW Sections",
      "settings": {
        "bar_text": "Free expedited shipping on orders over $200",
