{% comment %} 1. Assigns {% endcomment %}
{% liquid
  assign section_id = section.id
  assign show_name = section.settings.show_name_field
  assign form_layout = section.settings.form_layout
  assign animation_enabled = section.settings.animation_enabled
  assign animation_type = section.settings.animation_type
  assign animation_delay = section.settings.animation_delay
  assign bg_pct = section.settings.bg_opacity
  assign bg_grad_pct = section.settings.bg_gradient_color_opacity
%}

{% comment %} 2. HTML structure {% endcomment %}
<div class="color-{{ section.settings.color_scheme }} gradient">
  <section
    id="lab-{{ section_id }}"
    class="lab_newsletter_signup lab_newsletter_signup--align-{{ section.settings.content_alignment }} lab_newsletter_signup--pos-{{ section.settings.content_position }} lab_newsletter_signup--layout-{{ form_layout }} lab_newsletter_signup--width-{{ section.settings.section_width }} lab_newsletter_signup--btn-hover-{{ section.settings.cta_hover_effect }}{% if animation_enabled %} lab_newsletter_signup--animated lab_newsletter_signup--anim-{{ animation_type }}{% endif %} lab_section"
    aria-label="{{ section.settings.heading | default: 'Newsletter signup' | escape }}"
  >
    <div class="lab_newsletter_signup__inner"
      {% if animation_enabled %}style="animation-delay: {{ animation_delay }}ms;"{% endif %}>
      {% if section.settings.heading != blank %}
        <h2 class="lab_newsletter_signup__heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="lab_newsletter_signup__subheading">{{ section.settings.subheading | escape | newline_to_br }}</p>
      {% endif %}

      {% form 'customer', id: 'lab-newsletter-form-' | append: section_id, class: 'lab_newsletter_signup__form' %}
        {% if form.posted_successfully? %}
          <p class="lab_newsletter_signup__success" role="status">
            {{ section.settings.success_message | escape }}
          </p>
        {% else %}
          <input type="hidden" name="contact[tags]" value="newsletter">

          <div class="lab_newsletter_signup__fields">
            {% if show_name %}
              <div class="lab_newsletter_signup__field lab_newsletter_signup__field--name">
                <label for="lab-newsletter-name-{{ section_id }}" class="lab_newsletter_signup__label">
                  {{ section.settings.name_placeholder | default: 'First name' | escape }}
                </label>
                <input
                  type="text"
                  id="lab-newsletter-name-{{ section_id }}"
                  name="contact[first_name]"
                  class="lab_newsletter_signup__input"
                  placeholder="{{ section.settings.name_placeholder | default: 'First name' | escape }}"
                  autocomplete="given-name"
                >
              </div>
            {% endif %}

            <div class="lab_newsletter_signup__field lab_newsletter_signup__field--email">
              <label for="lab-newsletter-email-{{ section_id }}" class="lab_newsletter_signup__label">
                {{ section.settings.email_placeholder | default: 'Email address' | escape }}
              </label>
              <input
                type="email"
                id="lab-newsletter-email-{{ section_id }}"
                name="contact[email]"
                class="lab_newsletter_signup__input"
                placeholder="{{ section.settings.email_placeholder | default: 'Email address' | escape }}"
                autocomplete="email"
                required
                {% if section.settings.privacy_text != blank %}aria-describedby="lab-newsletter-privacy-{{ section_id }}"{% endif %}
              >
            </div>

            <button type="submit" class="lab_newsletter_signup__submit">
              {{ section.settings.button_label | default: 'Subscribe' | escape }}
            </button>
          </div>

          {% if form.errors %}
            <p class="lab_newsletter_signup__error" role="alert">
              {{ form.errors.messages.email | default: form.errors.translated_fields.email | escape }}
            </p>
          {% endif %}

          {% if section.settings.privacy_text != blank %}
            <p id="lab-newsletter-privacy-{{ section_id }}" class="lab_newsletter_signup__privacy">
              {{ section.settings.privacy_text | escape }}
            </p>
          {% endif %}
        {% endif %}
      {% endform %}
    </div>
  </section>
</div>

{% comment %} 3. CSS — section scoped {% endcomment %}
<style>
  #shopify-section-{{ section.id }} .lab_newsletter_signup {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    padding-inline: {% if section.settings.section_width == 'full' %}clamp(1rem, 4vw, 2rem){% else %}clamp(1rem, 4vw, 2rem){% endif %};
    {% if section.settings.bg_color != blank %}
      background-color: color-mix(in srgb, {{ section.settings.bg_color }} {{ bg_pct }}%, transparent);
    {% else %}
      background-color: var(--color-background);
    {% endif %}
    {% if section.settings.bg_gradient and section.settings.bg_color != blank and section.settings.bg_gradient_color != blank %}
      background-image: linear-gradient(
        {{ section.settings.bg_gradient_direction }},
        color-mix(in srgb, {{ section.settings.bg_color }} {{ bg_pct }}%, transparent),
        color-mix(in srgb, {{ section.settings.bg_gradient_color }} {{ bg_grad_pct }}%, transparent)
      );
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_newsletter_signup__inner {
    width: 100%;
    max-width: {{ section.settings.content_max_width }}px;
    margin-inline: {% if section.settings.content_alignment == 'left' %}0 auto 0 0{% elsif section.settings.content_alignment == 'right' %}0 0 0 auto{% else %}auto{% endif %};
    text-align: {% if section.settings.content_alignment == 'left' %}left{% elsif section.settings.content_alignment == 'right' %}right{% else %}center{% endif %};
    display: flex;
    flex-direction: column;
    gap: clamp(0.75rem, 2vw, 1.25rem);
  }

  #shopify-section-{{ section.id }} .lab_newsletter_signup__heading {
    margin: 0;
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
    text-transform: {{ section.settings.heading_transform }};
    text-align: {{ section.settings.heading_text_align }};
    letter-spacing: calc({{ section.settings.heading_letter_spacing }} / 100 * 1em);
    line-height: calc({{ section.settings.heading_line_height }} / 10);
    {% if section.settings.heading_color != blank %}
      color: color-mix(in srgb, {{ section.settings.heading_color }} {{ section.settings.heading_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_newsletter_signup__subheading {
    margin: 0;
    font-size: {{ section.settings.subheading_size }}px;
    font-weight: {{ section.settings.subheading_weight }};
    text-transform: {{ section.settings.subheading_transform }};
    text-align: {{ section.settings.subheading_text_align }};
    letter-spacing: calc({{ section.settings.subheading_letter_spacing }} / 100 * 1em);
    line-height: calc({{ section.settings.subheading_line_height }} / 10);
    {% if section.settings.subheading_color != blank %}
      color: color-mix(in srgb, {{ section.settings.subheading_color }} {{ section.settings.subheading_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground-75, var(--color-foreground));
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_newsletter_signup__form {
    margin: clamp(0.5rem, 1.5vw, 1rem) 0 0;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .lab_newsletter_signup__fields {
    display: flex;
    flex-direction: column;
    gap: clamp(0.5rem, 1vw, 0.75rem);
  }

  #shopify-section-{{ section.id }} .lab_newsletter_signup__field {
    display: flex;
    flex-direction: column;
  }

  #shopify-section-{{ section.id }} .lab_newsletter_signup__label {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  #shopify-section-{{ section.id }} .lab_newsletter_signup__input {
    width: 100%;
    min-height: 48px;
    padding: 0.75rem 1rem;
    border-radius: {{ section.settings.input_border_radius }}px;
    border: {{ section.settings.input_border_width }}px solid {% if section.settings.input_border_color != blank %}color-mix(in srgb, {{ section.settings.input_border_color }} {{ section.settings.input_border_color_opacity }}%, transparent){% else %}color-mix(in srgb, var(--color-foreground) 25%, transparent){% endif %};
    font-family: inherit;
    font-size: 1rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    {% if section.settings.input_bg_color != blank %}
      background-color: color-mix(in srgb, {{ section.settings.input_bg_color }} {{ section.settings.input_bg_color_opacity }}%, transparent);
    {% else %}
      background-color: var(--color-background);
    {% endif %}
    {% if section.settings.input_text_color != blank %}
      color: color-mix(in srgb, {{ section.settings.input_text_color }} {{ section.settings.input_text_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_newsletter_signup__input::placeholder {
    color: color-mix(in srgb, currentColor 50%, transparent);
  }

  #shopify-section-{{ section.id }} .lab_newsletter_signup__input:focus,
  #shopify-section-{{ section.id }} .lab_newsletter_signup__input:focus-visible {
    outline: none;
    border-color: {% if section.settings.focus_border_color != blank %}color-mix(in srgb, {{ section.settings.focus_border_color }} {{ section.settings.focus_border_color_opacity }}%, transparent){% else %}var(--color-foreground){% endif %};
    box-shadow: 0 0 0 3px {% if section.settings.focus_border_color != blank %}color-mix(in srgb, {{ section.settings.focus_border_color }} 25%, transparent){% else %}color-mix(in srgb, var(--color-foreground) 18%, transparent){% endif %};
  }

  #shopify-section-{{ section.id }} .lab_newsletter_signup__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: {{ section.settings.cta_padding_y }}px {{ section.settings.cta_padding_x }}px;
    border-radius: {{ section.settings.cta_border_radius }}px;
    border: {{ section.settings.cta_border_width }}px solid {% if section.settings.cta_border_color != blank %}color-mix(in srgb, {{ section.settings.cta_border_color }} {{ section.settings.cta_border_color_opacity }}%, transparent){% else %}transparent{% endif %};
    font-family: inherit;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
    {% if section.settings.cta_bg_color != blank %}
      background-color: color-mix(in srgb, {{ section.settings.cta_bg_color }} {{ section.settings.cta_bg_color_opacity }}%, transparent);
    {% else %}
      background-color: var(--color-button);
    {% endif %}
    {% if section.settings.cta_text_color != blank %}
      color: color-mix(in srgb, {{ section.settings.cta_text_color }} {{ section.settings.cta_text_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-button-text);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_newsletter_signup--btn-hover-fill .lab_newsletter_signup__submit:hover,
  #shopify-section-{{ section.id }} .lab_newsletter_signup--btn-hover-darken .lab_newsletter_signup__submit:hover,
  #shopify-section-{{ section.id }} .lab_newsletter_signup--btn-hover-lift .lab_newsletter_signup__submit:hover,
  #shopify-section-{{ section.id }} .lab_newsletter_signup--btn-hover-glow .lab_newsletter_signup__submit:hover {
    {% if section.settings.cta_hover_bg_color != blank %}
      background-color: color-mix(in srgb, {{ section.settings.cta_hover_bg_color }} {{ section.settings.cta_hover_bg_color_opacity }}%, transparent);
    {% endif %}
    {% if section.settings.cta_hover_text_color != blank %}
      color: color-mix(in srgb, {{ section.settings.cta_hover_text_color }} {{ section.settings.cta_hover_text_color_opacity }}%, transparent);
    {% endif %}
    {% if section.settings.cta_hover_border_color != blank %}
      border-color: color-mix(in srgb, {{ section.settings.cta_hover_border_color }} {{ section.settings.cta_hover_border_color_opacity }}%, transparent);
    {% endif %}
  }
  #shopify-section-{{ section.id }} .lab_newsletter_signup--btn-hover-darken .lab_newsletter_signup__submit:hover {
    filter: brightness(0.88);
  }
  #shopify-section-{{ section.id }} .lab_newsletter_signup--btn-hover-lift .lab_newsletter_signup__submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px color-mix(in srgb, var(--color-foreground) 18%, transparent);
  }
  #shopify-section-{{ section.id }} .lab_newsletter_signup--btn-hover-glow .lab_newsletter_signup__submit:hover {
    box-shadow: 0 0 24px {% if section.settings.cta_hover_bg_color != blank %}color-mix(in srgb, {{ section.settings.cta_hover_bg_color }} 60%, transparent){% else %}color-mix(in srgb, var(--color-foreground) 25%, transparent){% endif %};
  }
  #shopify-section-{{ section.id }} .lab_newsletter_signup--btn-hover-outline .lab_newsletter_signup__submit:hover {
    background-color: transparent;
    {% if section.settings.cta_hover_text_color != blank %}
      color: color-mix(in srgb, {{ section.settings.cta_hover_text_color }} {{ section.settings.cta_hover_text_color_opacity }}%, transparent);
    {% endif %}
    {% if section.settings.cta_hover_border_color != blank %}
      border-color: color-mix(in srgb, {{ section.settings.cta_hover_border_color }} {{ section.settings.cta_hover_border_color_opacity }}%, transparent);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_newsletter_signup__submit:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 3px;
  }

  /* Inline layout — single row from 600px up */
  @media (min-width: 600px) {
    #shopify-section-{{ section.id }} .lab_newsletter_signup--layout-inline .lab_newsletter_signup__fields {
      flex-direction: row;
      align-items: stretch;
    }
    #shopify-section-{{ section.id }} .lab_newsletter_signup--layout-inline .lab_newsletter_signup__field {
      flex: 1 1 0;
    }
    #shopify-section-{{ section.id }} .lab_newsletter_signup--layout-inline .lab_newsletter_signup__submit {
      flex: 0 0 auto;
    }
  }

  #shopify-section-{{ section.id }} .lab_newsletter_signup__privacy {
    margin: 0;
    font-size: {{ section.settings.privacy_text_size }}px;
    font-weight: {{ section.settings.privacy_text_weight }};
    text-transform: {{ section.settings.privacy_text_transform }};
    text-align: {{ section.settings.privacy_text_text_align }};
    letter-spacing: calc({{ section.settings.privacy_text_letter_spacing }} / 100 * 1em);
    line-height: calc({{ section.settings.privacy_text_line_height }} / 10);
    {% if section.settings.privacy_text_color != blank %}
      color: color-mix(in srgb, {{ section.settings.privacy_text_color }} {{ section.settings.privacy_text_color_opacity }}%, transparent);
    {% else %}
      color: color-mix(in srgb, var(--color-foreground) 60%, transparent);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_newsletter_signup__success {
    margin: clamp(0.5rem, 1.5vw, 1rem) 0 0;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    background-color: color-mix(in srgb, var(--color-foreground) 6%, transparent);
    color: var(--color-foreground);
    font-weight: 500;
  }

  #shopify-section-{{ section.id }} .lab_newsletter_signup__error {
    margin: clamp(0.5rem, 1vw, 0.75rem) 0 0;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    background-color: color-mix(in srgb, var(--color-foreground) 8%, transparent);
    color: var(--color-foreground);
    font-size: 0.875rem;
  }

  /* Animation */
  {% if animation_enabled %}
    #shopify-section-{{ section.id }} .lab_newsletter_signup--animated .lab_newsletter_signup__inner {
      opacity: 0;
      animation-duration: 0.6s;
      animation-fill-mode: forwards;
      animation-timing-function: ease-out;
    }
    #shopify-section-{{ section.id }} .lab_newsletter_signup--anim-fade .lab_newsletter_signup__inner {
      animation-name: lab_newsletter_signup_fade_{{ section.id }};
    }
    #shopify-section-{{ section.id }} .lab_newsletter_signup--anim-slide .lab_newsletter_signup__inner {
      animation-name: lab_newsletter_signup_slide_{{ section.id }};
    }
    #shopify-section-{{ section.id }} .lab_newsletter_signup--anim-zoom .lab_newsletter_signup__inner {
      animation-name: lab_newsletter_signup_zoom_{{ section.id }};
    }
    @keyframes lab_newsletter_signup_fade_{{ section.id }} {
      from { opacity: 0; } to { opacity: 1; }
    }
    @keyframes lab_newsletter_signup_slide_{{ section.id }} {
      from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); }
    }
    @keyframes lab_newsletter_signup_zoom_{{ section.id }} {
      from { opacity: 0; transform: scale(0.97); } to { opacity: 1; transform: scale(1); }
    }
  {% endif %}

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .lab_newsletter_signup__inner,
    #shopify-section-{{ section.id }} .lab_newsletter_signup__submit,
    #shopify-section-{{ section.id }} .lab_newsletter_signup__input {
      transition: none;
      animation: none;
      transform: none;
    }
  }

  {% if section.settings.hide_on_mobile %}
    #shopify-section-{{ section.id }} { display: none; }
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} {
        display: {% if section.settings.hide_on_desktop %}none{% else %}revert{% endif %};
      }
    }
  {% elsif section.settings.hide_on_desktop %}
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} { display: none; }
    }
  {% endif %}

  {% if section.settings.custom_css != blank %}
    #shopify-section-{{ section.id }} {
      {{ section.settings.custom_css }}
    }
  {% endif %}
</style>

{% schema %}
{
  "name": "🧪 Newsletter Signup",
  "tag": "section",
  "class": "lab_section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Stay in the loop" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Get early access to drops, restocks, and the occasional deep cut from the studio." },
    { "type": "checkbox", "id": "show_name_field", "label": "Show first name field", "default": false },
    { "type": "text", "id": "name_placeholder", "label": "Name placeholder", "default": "First name" },
    { "type": "text", "id": "email_placeholder", "label": "Email placeholder", "default": "you@email.com" },
    { "type": "text", "id": "button_label", "label": "Submit button label", "default": "Subscribe" },
    { "type": "text", "id": "privacy_text", "label": "Privacy text", "default": "We respect your inbox. Unsubscribe anytime." },
    { "type": "text", "id": "success_message", "label": "Success message", "default": "Thanks for subscribing — keep an eye on your inbox." },

    { "type": "header", "content": "Typography" },
    { "type": "range", "id": "heading_size", "label": "Heading size", "min": 12, "max": 80, "step": 1, "unit": "px", "default": 36 },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading weight",
      "options": [
        { "value": "300", "label": "Thin" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "heading_transform",
      "label": "Heading text transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "heading_text_align",
      "label": "Heading text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    { "type": "color", "id": "heading_color", "label": "Heading color" },
    { "type": "range", "id": "heading_color_opacity", "label": "Heading color opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 100 },
    { "type": "range", "id": "heading_letter_spacing", "label": "Heading letter spacing", "min": -5, "max": 20, "step": 1, "unit": "em", "default": -1 },
    { "type": "range", "id": "heading_line_height", "label": "Heading line height", "min": 10, "max": 30, "step": 1, "default": 12 },

    { "type": "range", "id": "subheading_size", "label": "Subheading size", "min": 12, "max": 80, "step": 1, "unit": "px", "default": 16 },
    {
      "type": "select",
      "id": "subheading_weight",
      "label": "Subheading weight",
      "options": [
        { "value": "300", "label": "Thin" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "400"
    },
    {
      "type": "select",
      "id": "subheading_transform",
      "label": "Subheading text transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "subheading_text_align",
      "label": "Subheading text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    { "type": "color", "id": "subheading_color", "label": "Subheading color" },
    { "type": "range", "id": "subheading_color_opacity", "label": "Subheading color opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 100 },
    { "type": "range", "id": "subheading_letter_spacing", "label": "Subheading letter spacing", "min": -5, "max": 20, "step": 1, "unit": "em", "default": 0 },
    { "type": "range", "id": "subheading_line_height", "label": "Subheading line height", "min": 10, "max": 30, "step": 1, "default": 15 },

