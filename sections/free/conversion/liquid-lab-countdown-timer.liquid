{% comment %} 1. Assigns {% endcomment %}
{% liquid
  assign section_id = section.id
  assign show_labels = section.settings.show_labels
  assign animation_enabled = section.settings.animation_enabled
  assign animation_type = section.settings.animation_type
  assign animation_delay = section.settings.animation_delay
  assign bg_pct = section.settings.bg_opacity
  assign bg_grad_pct = section.settings.bg_gradient_color_opacity
%}

{% comment %} 2. HTML structure {% endcomment %}
<div class="color-{{ section.settings.color_scheme }} gradient">
  <section
    id="lab-{{ section_id }}"
    class="lab_countdown_timer lab_countdown_timer--align-{{ section.settings.content_alignment }} lab_countdown_timer--pos-{{ section.settings.content_position }} lab_countdown_timer--cta-hover-{{ section.settings.cta_hover_effect }}{% if animation_enabled %} lab_countdown_timer--animated lab_countdown_timer--anim-{{ animation_type }}{% endif %} lab_section{% if section.settings.spacing_size != 'custom' %} lab_section--spacing-{{ section.settings.spacing_size }}{% endif %}"
    aria-label="{{ section.settings.heading | default: 'Countdown timer' | escape }}"
    data-lab-countdown-end="{{ section.settings.end_date | escape }}"
    data-lab-spacing="{{ section.settings.spacing_size }}"
  >
    <div class="lab_container lab_container--{{ section.settings.container_width }} lab_countdown_timer__inner"
      {% if animation_enabled %}style="animation-delay: {{ animation_delay }}ms;"{% endif %}>
      {% if section.settings.heading != blank %}
        <h2 class="lab_countdown_timer__heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="lab_countdown_timer__subheading">{{ section.settings.subheading | escape | newline_to_br }}</p>
      {% endif %}

      <div
        class="lab_countdown_timer__display"
        data-lab-countdown-display
        aria-live="polite"
        aria-atomic="true"
      >
        <div class="lab_countdown_timer__digit-block" data-lab-countdown-block="days">
          <span class="lab_countdown_timer__digit" data-lab-countdown-value="days">00</span>
          {% if show_labels %}
            <span class="lab_countdown_timer__label">{{ section.settings.label_days | default: 'Days' | escape }}</span>
          {% endif %}
        </div>
        <span class="lab_countdown_timer__separator" aria-hidden="true">:</span>
        <div class="lab_countdown_timer__digit-block" data-lab-countdown-block="hours">
          <span class="lab_countdown_timer__digit" data-lab-countdown-value="hours">00</span>
          {% if show_labels %}
            <span class="lab_countdown_timer__label">{{ section.settings.label_hours | default: 'Hours' | escape }}</span>
          {% endif %}
        </div>
        <span class="lab_countdown_timer__separator" aria-hidden="true">:</span>
        <div class="lab_countdown_timer__digit-block" data-lab-countdown-block="minutes">
          <span class="lab_countdown_timer__digit" data-lab-countdown-value="minutes">00</span>
          {% if show_labels %}
            <span class="lab_countdown_timer__label">{{ section.settings.label_minutes | default: 'Minutes' | escape }}</span>
          {% endif %}
        </div>
        <span class="lab_countdown_timer__separator" aria-hidden="true">:</span>
        <div class="lab_countdown_timer__digit-block" data-lab-countdown-block="seconds">
          <span class="lab_countdown_timer__digit" data-lab-countdown-value="seconds">00</span>
          {% if show_labels %}
            <span class="lab_countdown_timer__label">{{ section.settings.label_seconds | default: 'Seconds' | escape }}</span>
          {% endif %}
        </div>
      </div>

      <p class="lab_countdown_timer__expired" data-lab-countdown-expired hidden>
        {{ section.settings.expired_message | default: 'This offer has ended.' | escape }}
      </p>

      {% if section.settings.cta_label != blank %}
        <a
          href="{{ section.settings.cta_url | default: '#' }}"
          class="lab_countdown_timer__cta"
          data-lab-countdown-cta
        >
          {{ section.settings.cta_label | escape }}
        </a>
      {% endif %}
    </div>
  </section>
</div>

{% comment %} 3. CSS — section scoped {% endcomment %}
<style>
  #shopify-section-{{ section.id }} .lab_countdown_timer {
    {% if section.settings.bg_color != blank %}
      background-color: color-mix(in srgb, {{ section.settings.bg_color }} {{ bg_pct }}%, transparent);
    {% else %}
      background-color: var(--color-background);
    {% endif %}
    {% if section.settings.bg_gradient and section.settings.bg_color != blank and section.settings.bg_gradient_color != blank %}
      background-image: linear-gradient(
        {{ section.settings.bg_gradient_direction }},
        color-mix(in srgb, {{ section.settings.bg_color }} {{ bg_pct }}%, transparent),
        color-mix(in srgb, {{ section.settings.bg_gradient_color }} {{ bg_grad_pct }}%, transparent)
      );
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_countdown_timer__inner {
    max-width: {{ section.settings.content_max_width }}px;
    margin-inline: {% if section.settings.content_alignment == 'left' %}0 auto 0 0{% elsif section.settings.content_alignment == 'right' %}0 0 0 auto{% else %}auto{% endif %};
    text-align: {% if section.settings.content_alignment == 'left' %}left{% elsif section.settings.content_alignment == 'right' %}right{% else %}center{% endif %};
    display: flex;
    flex-direction: column;
    align-items: {% if section.settings.content_alignment == 'left' %}flex-start{% elsif section.settings.content_alignment == 'right' %}flex-end{% else %}center{% endif %};
    gap: clamp(1rem, 2.5vw, 1.75rem);
  }

  {% if section.settings.spacing_size == 'custom' %}
    #shopify-section-{{ section.id }} .lab_countdown_timer {
      margin-top: {{ section.settings.spacing_top_custom }}px;
      margin-bottom: {{ section.settings.spacing_bottom_custom }}px;
    }
  {% endif %}

  #shopify-section-{{ section.id }} .lab_countdown_timer__heading {
    margin: 0;
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
    text-transform: {{ section.settings.heading_transform }};
    text-align: {{ section.settings.heading_text_align }};
    letter-spacing: calc({{ section.settings.heading_letter_spacing }} / 100 * 1em);
    line-height: calc({{ section.settings.heading_line_height }} / 10);
    {% if section.settings.heading_color != blank %}
      color: color-mix(in srgb, {{ section.settings.heading_color }} {{ section.settings.heading_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_countdown_timer__subheading {
    margin: 0;
    font-size: {{ section.settings.subheading_size }}px;
    font-weight: {{ section.settings.subheading_weight }};
    text-transform: {{ section.settings.subheading_transform }};
    text-align: {{ section.settings.subheading_text_align }};
    letter-spacing: calc({{ section.settings.subheading_letter_spacing }} / 100 * 1em);
    line-height: calc({{ section.settings.subheading_line_height }} / 10);
    {% if section.settings.subheading_color != blank %}
      color: color-mix(in srgb, {{ section.settings.subheading_color }} {{ section.settings.subheading_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground-75, var(--color-foreground));
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_countdown_timer__display {
    display: flex;
    align-items: center;
    gap: clamp(0.25rem, 1vw, 0.75rem);
    flex-wrap: nowrap;
  }

  #shopify-section-{{ section.id }} .lab_countdown_timer__digit-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(0.25rem, 0.75vw, 0.5rem);
    min-width: clamp(3.5rem, 10vw, 5.5rem);
    padding: clamp(0.5rem, 1.5vw, 1rem) clamp(0.75rem, 2vw, 1.25rem);
    border-radius: {{ section.settings.digit_border_radius }}px;
    border: {{ section.settings.digit_border_width }}px solid {% if section.settings.digit_border_color != blank %}color-mix(in srgb, {{ section.settings.digit_border_color }} {{ section.settings.digit_border_color_opacity }}%, transparent){% else %}transparent{% endif %};
    {% if section.settings.digit_bg_color != blank %}
      background-color: color-mix(in srgb, {{ section.settings.digit_bg_color }} {{ section.settings.digit_bg_color_opacity }}%, transparent);
    {% else %}
      background-color: color-mix(in srgb, var(--color-foreground) 6%, transparent);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_countdown_timer__digit {
    font-size: {{ section.settings.timer_digits_size }}px;
    font-weight: {{ section.settings.timer_digits_weight }};
    text-transform: {{ section.settings.timer_digits_transform }};
    text-align: {{ section.settings.timer_digits_text_align }};
    letter-spacing: calc({{ section.settings.timer_digits_letter_spacing }} / 100 * 1em);
    line-height: calc({{ section.settings.timer_digits_line_height }} / 10);
    font-variant-numeric: tabular-nums;
    {% if section.settings.timer_digits_color != blank %}
      color: color-mix(in srgb, {{ section.settings.timer_digits_color }} {{ section.settings.timer_digits_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_countdown_timer__label {
    font-size: {{ section.settings.timer_labels_size }}px;
    font-weight: {{ section.settings.timer_labels_weight }};
    text-transform: {{ section.settings.timer_labels_transform }};
    text-align: {{ section.settings.timer_labels_text_align }};
    letter-spacing: calc({{ section.settings.timer_labels_letter_spacing }} / 100 * 1em);
    line-height: calc({{ section.settings.timer_labels_line_height }} / 10);
    {% if section.settings.timer_labels_color != blank %}
      color: color-mix(in srgb, {{ section.settings.timer_labels_color }} {{ section.settings.timer_labels_color_opacity }}%, transparent);
    {% else %}
      color: color-mix(in srgb, var(--color-foreground) 65%, transparent);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_countdown_timer__separator {
    font-size: clamp(1.25rem, 4vw, 2.25rem);
    font-weight: 700;
    line-height: 1;
    align-self: flex-start;
    padding-top: clamp(0.5rem, 1.5vw, 1rem);
    {% if section.settings.separator_color != blank %}
      color: color-mix(in srgb, {{ section.settings.separator_color }} {{ section.settings.separator_color_opacity }}%, transparent);
    {% else %}
      color: color-mix(in srgb, var(--color-foreground) 35%, transparent);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_countdown_timer__expired {
    margin: 0;
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    font-weight: 600;
    color: var(--color-foreground);
  }

  #shopify-section-{{ section.id }} .lab_countdown_timer__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: {{ section.settings.cta_padding_y }}px {{ section.settings.cta_padding_x }}px;
    border-radius: {{ section.settings.cta_border_radius }}px;
    border: {{ section.settings.cta_border_width }}px solid {% if section.settings.cta_border_color != blank %}color-mix(in srgb, {{ section.settings.cta_border_color }} {{ section.settings.cta_border_color_opacity }}%, transparent){% else %}transparent{% endif %};
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
    {% if section.settings.cta_bg_color != blank %}
      background-color: color-mix(in srgb, {{ section.settings.cta_bg_color }} {{ section.settings.cta_bg_color_opacity }}%, transparent);
    {% else %}
      background-color: var(--color-button);
    {% endif %}
    {% if section.settings.cta_text_color != blank %}
      color: color-mix(in srgb, {{ section.settings.cta_text_color }} {{ section.settings.cta_text_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-button-text);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_countdown_timer--cta-hover-fill .lab_countdown_timer__cta:hover,
  #shopify-section-{{ section.id }} .lab_countdown_timer--cta-hover-darken .lab_countdown_timer__cta:hover,
  #shopify-section-{{ section.id }} .lab_countdown_timer--cta-hover-lift .lab_countdown_timer__cta:hover,
  #shopify-section-{{ section.id }} .lab_countdown_timer--cta-hover-glow .lab_countdown_timer__cta:hover {
    {% if section.settings.cta_hover_bg_color != blank %}
      background-color: color-mix(in srgb, {{ section.settings.cta_hover_bg_color }} {{ section.settings.cta_hover_bg_color_opacity }}%, transparent);
    {% endif %}
    {% if section.settings.cta_hover_text_color != blank %}
      color: color-mix(in srgb, {{ section.settings.cta_hover_text_color }} {{ section.settings.cta_hover_text_color_opacity }}%, transparent);
    {% endif %}
    {% if section.settings.cta_hover_border_color != blank %}
      border-color: color-mix(in srgb, {{ section.settings.cta_hover_border_color }} {{ section.settings.cta_hover_border_color_opacity }}%, transparent);
    {% endif %}
  }
  #shopify-section-{{ section.id }} .lab_countdown_timer--cta-hover-darken .lab_countdown_timer__cta:hover {
    filter: brightness(0.88);
  }
  #shopify-section-{{ section.id }} .lab_countdown_timer--cta-hover-lift .lab_countdown_timer__cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px color-mix(in srgb, var(--color-foreground) 18%, transparent);
  }
  #shopify-section-{{ section.id }} .lab_countdown_timer--cta-hover-glow .lab_countdown_timer__cta:hover {
    box-shadow: 0 0 24px {% if section.settings.cta_hover_bg_color != blank %}color-mix(in srgb, {{ section.settings.cta_hover_bg_color }} 60%, transparent){% else %}color-mix(in srgb, var(--color-foreground) 25%, transparent){% endif %};
  }
  #shopify-section-{{ section.id }} .lab_countdown_timer--cta-hover-outline .lab_countdown_timer__cta:hover {
    background-color: transparent;
    {% if section.settings.cta_hover_text_color != blank %}
      color: color-mix(in srgb, {{ section.settings.cta_hover_text_color }} {{ section.settings.cta_hover_text_color_opacity }}%, transparent);
    {% endif %}
    {% if section.settings.cta_hover_border_color != blank %}
      border-color: color-mix(in srgb, {{ section.settings.cta_hover_border_color }} {{ section.settings.cta_hover_border_color_opacity }}%, transparent);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_countdown_timer__cta:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 3px;
  }

  /* Animation */
  {% if animation_enabled %}
    #shopify-section-{{ section.id }} .lab_countdown_timer--animated .lab_countdown_timer__inner {
      opacity: 0;
      animation-duration: 0.6s;
      animation-fill-mode: forwards;
      animation-timing-function: ease-out;
    }
    #shopify-section-{{ section.id }} .lab_countdown_timer--anim-fade .lab_countdown_timer__inner {
      animation-name: lab_countdown_timer_fade_{{ section.id }};
    }
    #shopify-section-{{ section.id }} .lab_countdown_timer--anim-slide .lab_countdown_timer__inner {
      animation-name: lab_countdown_timer_slide_{{ section.id }};
    }
    #shopify-section-{{ section.id }} .lab_countdown_timer--anim-zoom .lab_countdown_timer__inner {
      animation-name: lab_countdown_timer_zoom_{{ section.id }};
    }
    @keyframes lab_countdown_timer_fade_{{ section.id }} {
      from { opacity: 0; } to { opacity: 1; }
    }
    @keyframes lab_countdown_timer_slide_{{ section.id }} {
      from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); }
    }
    @keyframes lab_countdown_timer_zoom_{{ section.id }} {
      from { opacity: 0; transform: scale(0.97); } to { opacity: 1; transform: scale(1); }
    }
  {% endif %}

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .lab_countdown_timer__inner,
    #shopify-section-{{ section.id }} .lab_countdown_timer__cta {
      transition: none;
      animation: none;
      transform: none;
    }
  }

  {% if section.settings.hide_on_mobile %}
    #shopify-section-{{ section.id }} { display: none; }
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} {
        display: {% if section.settings.hide_on_desktop %}none{% else %}revert{% endif %};
      }
    }
  {% elsif section.settings.hide_on_desktop %}
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} { display: none; }
    }
  {% endif %}

  {% if section.settings.custom_css != blank %}
    #shopify-section-{{ section.id }} {
      {{ section.settings.custom_css }}
    }
  {% endif %}
</style>

{% comment %} 4. JavaScript — countdown timer {% endcomment %}
<script>
  (function () {
    var section = document.getElementById('lab-{{ section.id }}');
    if (!section) return;

    var endDateStr = section.dataset.labCountdownEnd;
    var endDate = new Date(endDateStr);
    if (isNaN(endDate.getTime())) return;

    var display = section.querySelector('[data-lab-countdown-display]');
    var expiredEl = section.querySelector('[data-lab-countdown-expired]');
    var ctaEl = section.querySelector('[data-lab-countdown-cta]');
    var valueEls = {
      days: section.querySelector('[data-lab-countdown-value="days"]'),
      hours: section.querySelector('[data-lab-countdown-value="hours"]'),
      minutes: section.querySelector('[data-lab-countdown-value="minutes"]'),
      seconds: section.querySelector('[data-lab-countdown-value="seconds"]')
    };

    var intervalId = null;

    function pad(value) {
      return String(value).padStart(2, '0');
    }

    function update() {
      var now = new Date().getTime();
      var diff = endDate.getTime() - now;

      if (diff <= 0) {
        if (display) display.hidden = true;
        if (expiredEl) expiredEl.hidden = false;
        if (ctaEl) ctaEl.hidden = true;
        if (intervalId) {
          clearInterval(intervalId);
          intervalId = null;
        }
        return;
      }

      var days = Math.floor(diff / (1000 * 60 * 60 * 24));
      var hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      var minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
      var seconds = Math.floor((diff % (1000 * 60)) / 1000);

      if (valueEls.days) valueEls.days.textContent = pad(days);
      if (valueEls.hours) valueEls.hours.textContent = pad(hours);
      if (valueEls.minutes) valueEls.minutes.textContent = pad(minutes);
      if (valueEls.seconds) valueEls.seconds.textContent = pad(seconds);
    }

    update();
    intervalId = setInterval(update, 1000);

    function handleUnload(e) {
      if (e.target !== section) return;
      if (intervalId) {
        clearInterval(intervalId);
        intervalId = null;
      }
      document.removeEventListener('shopify:section:unload', handleUnload);
    }
    document.addEventListener('shopify:section:unload', handleUnload);
  })();
</script>

{% schema %}
{
  "name": "🧪 Countdown Timer",
  "tag": "section",
  "class": "lab_section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Limited-time launch" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Free shipping on every order until the timer hits zero." },
    { "type": "text", "id": "end_date", "label": "End date", "default": "2026-12-31T23:59:59", "info": "Format: YYYY-MM-DDTHH:MM:SS (e.g. 2026-12-31T23:59:59). Time portion is required — entering only YYYY-MM-DD makes the countdown start 1 hour off in non-UTC timezones because dates without time parse as UTC midnight. Time is interpreted as the visitor's local browser time." },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Shop the launch" },
    { "type": "url", "id": "cta_url", "label": "Button link" },
    { "type": "text", "id": "expired_message", "label": "Expired message", "default": "This offer has ended." },

    { "type": "header", "content": "Typography" },
    { "type": "range", "id": "heading_size", "label": "Heading size", "min": 12, "max": 80, "step": 1, "unit": "px", "default": 36 },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading weight",
      "options": [
        { "value": "300", "label": "Thin" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "heading_transform",
      "label": "Heading text transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "heading_text_align",
      "label": "Heading text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    { "type": "color", "id": "heading_color", "label": "Heading color" },
    { "type": "range", "id": "heading_color_opacity", "label": "Heading color opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 100 },
    { "type": "range", "id": "heading_letter_spacing", "label": "Heading letter spacing", "min": -5, "max": 20, "step": 1, "unit": "em", "default": -1 },
    { "type": "range", "id": "heading_line_height", "label": "Heading line height", "min": 10, "max": 30, "step": 1, "default": 12 },

    { "type": "range", "id": "subheading_size", "label": "Subheading size", "min": 12, "max": 80, "step": 1, "unit": "px", "default": 16 },
    {
      "type": "select",
      "id": "subheading_weight",
      "label": "Subheading weight",
      "options": [
        { "value": "300", "label": "Thin" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "400"
    },
    {
      "type": "select",
      "id": "subheading_transform",
      "label": "Subheading text transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "subheading_text_align",
      "label": "Subheading text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    { "type": "color", "id": "subheading_color", "label": "Subheading color" },
    { "type": "range", "id": "subheading_color_opacity", "label": "Subheading color opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 100 },
