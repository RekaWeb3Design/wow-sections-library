{% comment %} 1. Assigns {% endcomment %}
{% liquid
  assign section_id = section.id
  assign show_phone = section.settings.show_phone_field
  assign show_subject = section.settings.show_subject_field
  assign layout_style = section.settings.layout_style
  assign animation_enabled = section.settings.animation_enabled
  assign animation_type = section.settings.animation_type
  assign animation_delay = section.settings.animation_delay
  assign bg_pct = section.settings.bg_opacity
  assign bg_grad_pct = section.settings.bg_gradient_color_opacity
%}

{% comment %} 2. HTML structure {% endcomment %}
<div class="color-{{ section.settings.color_scheme }} gradient">
  <section
    id="lab-{{ section_id }}"
    class="lab_contact_form lab_contact_form--align-{{ section.settings.content_alignment }} lab_contact_form--pos-{{ section.settings.content_position }} lab_contact_form--layout-{{ layout_style }} lab_contact_form--width-{{ section.settings.section_width }} lab_contact_form--btn-hover-{{ section.settings.cta_hover_effect }}{% if animation_enabled %} lab_contact_form--animated lab_contact_form--anim-{{ animation_type }}{% endif %} lab_section"
    aria-label="{{ section.settings.heading | default: 'Contact form' | escape }}"
  >
    <div class="lab_contact_form__inner"
      {% if animation_enabled %}style="animation-delay: {{ animation_delay }}ms;"{% endif %}>
      {% if section.settings.heading != blank %}
        <h2 class="lab_contact_form__heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="lab_contact_form__subheading">{{ section.settings.subheading | escape | newline_to_br }}</p>
      {% endif %}

      {% form 'contact', id: 'lab-contact-form-' | append: section_id, class: 'lab_contact_form__form' %}
        {% if form.posted_successfully? %}
          <p class="lab_contact_form__success" role="status">
            {{ section.settings.success_message | escape }}
          </p>
        {% else %}
          {% if form.errors %}
            <div class="lab_contact_form__errors" role="alert">
              <p class="lab_contact_form__errors-title">{{ 'There was a problem with your submission' | escape }}</p>
              <ul class="lab_contact_form__errors-list" role="list">
                {% for field in form.errors %}
                  <li role="listitem">{{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}</li>
                {% endfor %}
              </ul>
            </div>
          {% endif %}

          <div class="lab_contact_form__grid">
            <div class="lab_contact_form__field lab_contact_form__field--name">
              <label for="lab-contact-name-{{ section_id }}" class="lab_contact_form__label">
                {{ section.settings.name_label | default: 'Name' | escape }}
                <span class="lab_contact_form__required" aria-hidden="true">*</span>
              </label>
              <input
                type="text"
                id="lab-contact-name-{{ section_id }}"
                name="contact[name]"
                class="lab_contact_form__input"
                autocomplete="name"
                value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
                required
              >
            </div>

            <div class="lab_contact_form__field lab_contact_form__field--email">
              <label for="lab-contact-email-{{ section_id }}" class="lab_contact_form__label">
                {{ section.settings.email_label | default: 'Email' | escape }}
                <span class="lab_contact_form__required" aria-hidden="true">*</span>
              </label>
              <input
                type="email"
                id="lab-contact-email-{{ section_id }}"
                name="contact[email]"
                class="lab_contact_form__input"
                autocomplete="email"
                value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                required
              >
            </div>

            {% if show_phone %}
              <div class="lab_contact_form__field lab_contact_form__field--phone">
                <label for="lab-contact-phone-{{ section_id }}" class="lab_contact_form__label">
                  {{ section.settings.phone_label | default: 'Phone' | escape }}
                </label>
                <input
                  type="tel"
                  id="lab-contact-phone-{{ section_id }}"
                  name="contact[phone]"
                  class="lab_contact_form__input"
                  autocomplete="tel"
                  pattern="[0-9\-+\s\(\)]+"
                  value="{% if form.phone %}{{ form.phone }}{% endif %}"
                >
              </div>
            {% endif %}

            {% if show_subject %}
              <div class="lab_contact_form__field lab_contact_form__field--subject">
                <label for="lab-contact-subject-{{ section_id }}" class="lab_contact_form__label">
                  {{ section.settings.subject_label | default: 'Subject' | escape }}
                </label>
                <input
                  type="text"
                  id="lab-contact-subject-{{ section_id }}"
                  name="contact[subject]"
                  class="lab_contact_form__input"
                >
              </div>
            {% endif %}

            <div class="lab_contact_form__field lab_contact_form__field--message">
              <label for="lab-contact-message-{{ section_id }}" class="lab_contact_form__label">
                {{ section.settings.message_label | default: 'Message' | escape }}
                <span class="lab_contact_form__required" aria-hidden="true">*</span>
              </label>
              <textarea
                id="lab-contact-message-{{ section_id }}"
                name="contact[body]"
                rows="6"
                class="lab_contact_form__input lab_contact_form__textarea"
                required
              >{% if form.body %}{{ form.body }}{% endif %}</textarea>
            </div>
          </div>

          <button type="submit" class="lab_contact_form__submit">
            {{ section.settings.button_label | default: 'Send message' | escape }}
          </button>
        {% endif %}
      {% endform %}
    </div>
  </section>
</div>

{% comment %} 3. CSS — section scoped {% endcomment %}
<style>
  #shopify-section-{{ section.id }} .lab_contact_form {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    padding-inline: clamp(1rem, 4vw, 2rem);
    {% if section.settings.bg_color != blank %}
      background-color: color-mix(in srgb, {{ section.settings.bg_color }} {{ bg_pct }}%, transparent);
    {% else %}
      background-color: var(--color-background);
    {% endif %}
    {% if section.settings.bg_gradient and section.settings.bg_color != blank and section.settings.bg_gradient_color != blank %}
      background-image: linear-gradient(
        {{ section.settings.bg_gradient_direction }},
        color-mix(in srgb, {{ section.settings.bg_color }} {{ bg_pct }}%, transparent),
        color-mix(in srgb, {{ section.settings.bg_gradient_color }} {{ bg_grad_pct }}%, transparent)
      );
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_contact_form__inner {
    width: 100%;
    max-width: {{ section.settings.content_max_width }}px;
    margin-inline: {% if section.settings.content_alignment == 'left' %}0 auto 0 0{% elsif section.settings.content_alignment == 'right' %}0 0 0 auto{% else %}auto{% endif %};
    text-align: {% if section.settings.content_alignment == 'left' %}left{% elsif section.settings.content_alignment == 'right' %}right{% else %}center{% endif %};
    display: flex;
    flex-direction: column;
    gap: clamp(1rem, 2.5vw, 1.75rem);
  }

  #shopify-section-{{ section.id }} .lab_contact_form__heading {
    margin: 0;
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
    text-transform: {{ section.settings.heading_transform }};
    text-align: {{ section.settings.heading_text_align }};
    letter-spacing: calc({{ section.settings.heading_letter_spacing }} / 100 * 1em);
    line-height: calc({{ section.settings.heading_line_height }} / 10);
    {% if section.settings.heading_color != blank %}
      color: color-mix(in srgb, {{ section.settings.heading_color }} {{ section.settings.heading_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_contact_form__subheading {
    margin: 0;
    font-size: {{ section.settings.subheading_size }}px;
    font-weight: {{ section.settings.subheading_weight }};
    text-transform: {{ section.settings.subheading_transform }};
    text-align: {{ section.settings.subheading_text_align }};
    letter-spacing: calc({{ section.settings.subheading_letter_spacing }} / 100 * 1em);
    line-height: calc({{ section.settings.subheading_line_height }} / 10);
    {% if section.settings.subheading_color != blank %}
      color: color-mix(in srgb, {{ section.settings.subheading_color }} {{ section.settings.subheading_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground-75, var(--color-foreground));
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_contact_form__form {
    width: 100%;
    max-width: {{ section.settings.form_max_width }}px;
    margin: 0 {% if section.settings.content_alignment == 'left' %}auto 0 0{% elsif section.settings.content_alignment == 'right' %}0 0 auto{% else %}auto{% endif %};
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: clamp(0.75rem, 2vw, 1.25rem);
  }

  #shopify-section-{{ section.id }} .lab_contact_form__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(0.75rem, 1.5vw, 1rem);
  }

  @media (min-width: 600px) {
    #shopify-section-{{ section.id }} .lab_contact_form--layout-two-column .lab_contact_form__grid {
      grid-template-columns: 1fr 1fr;
    }
    #shopify-section-{{ section.id }} .lab_contact_form--layout-two-column .lab_contact_form__field--message {
      grid-column: 1 / -1;
    }
  }

  #shopify-section-{{ section.id }} .lab_contact_form__field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  #shopify-section-{{ section.id }} .lab_contact_form__label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-foreground);
  }

  #shopify-section-{{ section.id }} .lab_contact_form__required {
    color: color-mix(in srgb, var(--color-foreground) 60%, transparent);
    margin-left: 0.125rem;
  }

  #shopify-section-{{ section.id }} .lab_contact_form__input {
    width: 100%;
    min-height: 48px;
    padding: 0.75rem 1rem;
    border-radius: {{ section.settings.input_border_radius }}px;
    border: {{ section.settings.input_border_width }}px solid {% if section.settings.input_border_color != blank %}color-mix(in srgb, {{ section.settings.input_border_color }} {{ section.settings.input_border_color_opacity }}%, transparent){% else %}color-mix(in srgb, var(--color-foreground) 25%, transparent){% endif %};
    font-family: inherit;
    font-size: 1rem;
    line-height: 1.5;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    {% if section.settings.input_bg_color != blank %}
      background-color: color-mix(in srgb, {{ section.settings.input_bg_color }} {{ section.settings.input_bg_color_opacity }}%, transparent);
    {% else %}
      background-color: var(--color-background);
    {% endif %}
    {% if section.settings.input_text_color != blank %}
      color: color-mix(in srgb, {{ section.settings.input_text_color }} {{ section.settings.input_text_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_contact_form__textarea {
    min-height: 144px;
    resize: vertical;
  }

  #shopify-section-{{ section.id }} .lab_contact_form__input::placeholder {
    color: color-mix(in srgb, currentColor 50%, transparent);
  }

  #shopify-section-{{ section.id }} .lab_contact_form__input:focus,
  #shopify-section-{{ section.id }} .lab_contact_form__input:focus-visible {
    outline: none;
    border-color: {% if section.settings.focus_border_color != blank %}color-mix(in srgb, {{ section.settings.focus_border_color }} {{ section.settings.focus_border_color_opacity }}%, transparent){% else %}var(--color-foreground){% endif %};
    box-shadow: 0 0 0 3px {% if section.settings.focus_border_color != blank %}color-mix(in srgb, {{ section.settings.focus_border_color }} 25%, transparent){% else %}color-mix(in srgb, var(--color-foreground) 18%, transparent){% endif %};
  }

  #shopify-section-{{ section.id }} .lab_contact_form__submit {
    align-self: {% if section.settings.content_alignment == 'right' %}flex-end{% elsif section.settings.content_alignment == 'left' %}flex-start{% else %}center{% endif %};
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: {{ section.settings.cta_padding_y }}px {{ section.settings.cta_padding_x }}px;
    border-radius: {{ section.settings.cta_border_radius }}px;
    border: {{ section.settings.cta_border_width }}px solid {% if section.settings.cta_border_color != blank %}color-mix(in srgb, {{ section.settings.cta_border_color }} {{ section.settings.cta_border_color_opacity }}%, transparent){% else %}transparent{% endif %};
    font-family: inherit;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
    {% if section.settings.cta_bg_color != blank %}
      background-color: color-mix(in srgb, {{ section.settings.cta_bg_color }} {{ section.settings.cta_bg_color_opacity }}%, transparent);
    {% else %}
      background-color: var(--color-button);
    {% endif %}
    {% if section.settings.cta_text_color != blank %}
      color: color-mix(in srgb, {{ section.settings.cta_text_color }} {{ section.settings.cta_text_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-button-text);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_contact_form--btn-hover-fill .lab_contact_form__submit:hover,
  #shopify-section-{{ section.id }} .lab_contact_form--btn-hover-darken .lab_contact_form__submit:hover,
  #shopify-section-{{ section.id }} .lab_contact_form--btn-hover-lift .lab_contact_form__submit:hover,
  #shopify-section-{{ section.id }} .lab_contact_form--btn-hover-glow .lab_contact_form__submit:hover {
    {% if section.settings.cta_hover_bg_color != blank %}
      background-color: color-mix(in srgb, {{ section.settings.cta_hover_bg_color }} {{ section.settings.cta_hover_bg_color_opacity }}%, transparent);
    {% endif %}
    {% if section.settings.cta_hover_text_color != blank %}
      color: color-mix(in srgb, {{ section.settings.cta_hover_text_color }} {{ section.settings.cta_hover_text_color_opacity }}%, transparent);
    {% endif %}
    {% if section.settings.cta_hover_border_color != blank %}
      border-color: color-mix(in srgb, {{ section.settings.cta_hover_border_color }} {{ section.settings.cta_hover_border_color_opacity }}%, transparent);
    {% endif %}
  }
  #shopify-section-{{ section.id }} .lab_contact_form--btn-hover-darken .lab_contact_form__submit:hover {
    filter: brightness(0.88);
  }
  #shopify-section-{{ section.id }} .lab_contact_form--btn-hover-lift .lab_contact_form__submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px color-mix(in srgb, var(--color-foreground) 18%, transparent);
  }
  #shopify-section-{{ section.id }} .lab_contact_form--btn-hover-glow .lab_contact_form__submit:hover {
    box-shadow: 0 0 24px {% if section.settings.cta_hover_bg_color != blank %}color-mix(in srgb, {{ section.settings.cta_hover_bg_color }} 60%, transparent){% else %}color-mix(in srgb, var(--color-foreground) 25%, transparent){% endif %};
  }
  #shopify-section-{{ section.id }} .lab_contact_form--btn-hover-outline .lab_contact_form__submit:hover {
    background-color: transparent;
    {% if section.settings.cta_hover_text_color != blank %}
      color: color-mix(in srgb, {{ section.settings.cta_hover_text_color }} {{ section.settings.cta_hover_text_color_opacity }}%, transparent);
    {% endif %}
    {% if section.settings.cta_hover_border_color != blank %}
      border-color: color-mix(in srgb, {{ section.settings.cta_hover_border_color }} {{ section.settings.cta_hover_border_color_opacity }}%, transparent);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_contact_form__submit:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 3px;
  }

  #shopify-section-{{ section.id }} .lab_contact_form__success {
    margin: 0;
    padding: 1rem 1.25rem;
    border-radius: 8px;
    background-color: color-mix(in srgb, var(--color-foreground) 6%, transparent);
    color: var(--color-foreground);
    font-weight: 500;
  }

  #shopify-section-{{ section.id }} .lab_contact_form__errors {
    margin: 0;
    padding: 1rem 1.25rem;
    border-radius: 8px;
    background-color: color-mix(in srgb, var(--color-foreground) 8%, transparent);
    color: var(--color-foreground);
  }

  #shopify-section-{{ section.id }} .lab_contact_form__errors-title {
    margin: 0 0 0.5rem;
    font-weight: 600;
    font-size: 0.95rem;
  }

  #shopify-section-{{ section.id }} .lab_contact_form__errors-list {
    margin: 0;
    padding-left: 1.25rem;
    font-size: 0.875rem;
    list-style: disc;
  }

  /* Animation */
  {% if animation_enabled %}
    #shopify-section-{{ section.id }} .lab_contact_form--animated .lab_contact_form__inner {
      opacity: 0;
      animation-duration: 0.6s;
      animation-fill-mode: forwards;
      animation-timing-function: ease-out;
    }
    #shopify-section-{{ section.id }} .lab_contact_form--anim-fade .lab_contact_form__inner {
      animation-name: lab_contact_form_fade_{{ section.id }};
    }
    #shopify-section-{{ section.id }} .lab_contact_form--anim-slide .lab_contact_form__inner {
      animation-name: lab_contact_form_slide_{{ section.id }};
    }
    #shopify-section-{{ section.id }} .lab_contact_form--anim-zoom .lab_contact_form__inner {
      animation-name: lab_contact_form_zoom_{{ section.id }};
    }
    @keyframes lab_contact_form_fade_{{ section.id }} {
      from { opacity: 0; } to { opacity: 1; }
    }
    @keyframes lab_contact_form_slide_{{ section.id }} {
      from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); }
    }
    @keyframes lab_contact_form_zoom_{{ section.id }} {
      from { opacity: 0; transform: scale(0.97); } to { opacity: 1; transform: scale(1); }
    }
  {% endif %}

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .lab_contact_form__inner,
    #shopify-section-{{ section.id }} .lab_contact_form__submit,
    #shopify-section-{{ section.id }} .lab_contact_form__input {
      transition: none;
      animation: none;
      transform: none;
    }
  }

  {% if section.settings.hide_on_mobile %}
    #shopify-section-{{ section.id }} { display: none; }
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} {
        display: {% if section.settings.hide_on_desktop %}none{% else %}revert{% endif %};
      }
    }
  {% elsif section.settings.hide_on_desktop %}
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} { display: none; }
    }
  {% endif %}

  {% if section.settings.custom_css != blank %}
    #shopify-section-{{ section.id }} {
      {{ section.settings.custom_css }}
    }
  {% endif %}
</style>

{% schema %}
{
  "name": "🧪 Contact Form",
  "tag": "section",
  "class": "lab_section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get in touch" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Questions, feedback, custom orders — we'd love to hear from you. We reply within one business day." },
    { "type": "checkbox", "id": "show_phone_field", "label": "Show phone field", "default": false },
    { "type": "checkbox", "id": "show_subject_field", "label": "Show subject field", "default": true },
    { "type": "text", "id": "button_label", "label": "Submit button label", "default": "Send message" },
    { "type": "text", "id": "success_message", "label": "Success message", "default": "Thanks — we got your message and will be in touch within one business day." },
    { "type": "text", "id": "name_label", "label": "Name field label", "default": "Name" },
    { "type": "text", "id": "email_label", "label": "Email field label", "default": "Email" },
    { "type": "text", "id": "phone_label", "label": "Phone field label", "default": "Phone" },
    { "type": "text", "id": "subject_label", "label": "Subject field label", "default": "Subject" },
    { "type": "text", "id": "message_label", "label": "Message field label", "default": "Message" },

    { "type": "header", "content": "Typography" },
    { "type": "range", "id": "heading_size", "label": "Heading size", "min": 12, "max": 80, "step": 1, "unit": "px", "default": 36 },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading weight",
      "options": [
        { "value": "300", "label": "Thin" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "heading_transform",
      "label": "Heading text transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "heading_text_align",
      "label": "Heading text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    { "type": "color", "id": "heading_color", "label": "Heading color" },
    { "type": "range", "id": "heading_color_opacity", "label": "Heading color opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 100 },
    { "type": "range", "id": "heading_letter_spacing", "label": "Heading letter spacing", "min": -5, "max": 20, "step": 1, "unit": "em", "default": -1 },
    { "type": "range", "id": "heading_line_height", "label": "Heading line height", "min": 10, "max": 30, "step": 1, "default": 12 },

    { "type": "range", "id": "subheading_size", "label": "Subheading size", "min": 12, "max": 80, "step": 1, "unit": "px", "default": 16 },
    {
      "type": "select",
      "id": "subheading_weight",
      "label": "Subheading weight",
      "options": [
        { "value": "300", "label": "Thin" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "400"
    },
    {
      "type": "select",
      "id": "subheading_transform",
      "label": "Subheading text transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "subheading_text_align",
      "label": "Subheading text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    { "type": "color", "id": "subheading_color", "label": "Subheading color" },
    { "type": "range", "id": "subheading_color_opacity", "label": "Subheading color opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 100 },
