{%- comment -%} 1. Assigns {%- endcomment -%}
{%- liquid
  assign section_id = section.id
  assign s = section.settings
  assign contact_form_id = 'lab-contact-' | append: section_id

  assign anim_enabled = s.entrance_animation
  assign anim_type = s.entrance_type
  assign bg_pct = s.bg_opacity
  assign bg_grad_pct = s.bg_gradient_color_opacity

  assign info_count = 0
  for block in section.blocks
    case block.type
      when 'info_email'
        assign info_count = info_count | plus: 1
      when 'info_phone'
        assign info_count = info_count | plus: 1
      when 'info_address'
        assign info_count = info_count | plus: 1
    endcase
  endfor

  assign show_info_aside = false
  if s.show_info_column and info_count > 0 and s.layout_style != 'single'
    assign show_info_aside = true
  endif

  case s.form_card_shadow
    when 'soft'
      assign card_shadow_css = '0 2px 8px color-mix(in srgb, #000 12%, transparent)'
    when 'medium'
      assign card_shadow_css = '0 6px 18px color-mix(in srgb, #000 18%, transparent)'
    when 'strong'
      assign card_shadow_css = '0 12px 32px color-mix(in srgb, #000 28%, transparent)'
    else
      assign card_shadow_css = 'none'
  endcase
-%}

{%- comment -%} 2. HTML structure {%- endcomment -%}
<div class="color-{{ s.color_scheme }} gradient">
  <section
    id="lab-{{ section_id }}"
    class="lab_contact lab_contact--layout-{{ s.layout_style }} lab_contact--btn-hover-{{ s.submit_hover_effect }}{% if anim_enabled %} lab_contact--animated lab_contact--anim-{{ anim_type }}{% endif %} lab_section{% if s.spacing_size != 'custom' %} lab_section--spacing-{{ s.spacing_size }}{% endif %}"
    aria-label="{{ s.heading | default: 'Contact form' | escape }}"
    data-lab-spacing="{{ s.spacing_size }}"
  >
    <div class="lab_container lab_container--{{ s.container_width }}">
      <div class="lab_contact__layout">
        {%- if show_info_aside -%}
          <aside class="lab_contact__info lab_contact__info--align-{{ s.info_column_align }}">
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when 'info_email' -%}
                  <div class="lab_contact__info-item" {{ block.shopify_attributes }}>
                    <span class="lab_contact__info-icon" aria-hidden="true">
                      <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="5" width="18" height="14" rx="2"/>
                        <path d="M3 7l9 6 9-6"/>
                      </svg>
                    </span>
                    <div class="lab_contact__info-text">
                      {%- if block.settings.label != blank -%}
                        <span class="lab_contact__info-label">{{ block.settings.label | escape }}</span>
                      {%- endif -%}
                      {%- if block.settings.email_address != blank -%}
                        <a href="mailto:{{ block.settings.email_address | escape }}" class="lab_contact__info-value">
                          {{- block.settings.email_address | escape -}}
                        </a>
                      {%- endif -%}
                    </div>
                  </div>
                {%- when 'info_phone' -%}
                  {%- assign tel_href = block.settings.phone_number | replace: ' ', '' | replace: '(', '' | replace: ')', '' | replace: '-', '' -%}
                  <div class="lab_contact__info-item" {{ block.shopify_attributes }}>
                    <span class="lab_contact__info-icon" aria-hidden="true">
                      <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                      </svg>
                    </span>
                    <div class="lab_contact__info-text">
                      {%- if block.settings.label != blank -%}
                        <span class="lab_contact__info-label">{{ block.settings.label | escape }}</span>
                      {%- endif -%}
                      {%- if block.settings.phone_number != blank -%}
                        <a href="tel:{{ tel_href | escape }}" class="lab_contact__info-value">
                          {{- block.settings.phone_number | escape -}}
                        </a>
                      {%- endif -%}
                    </div>
                  </div>
                {%- when 'info_address' -%}
                  <div class="lab_contact__info-item" {{ block.shopify_attributes }}>
                    <span class="lab_contact__info-icon" aria-hidden="true">
                      <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                        <circle cx="12" cy="10" r="3"/>
                      </svg>
                    </span>
                    <div class="lab_contact__info-text">
                      {%- if block.settings.label != blank -%}
                        <span class="lab_contact__info-label">{{ block.settings.label | escape }}</span>
                      {%- endif -%}
                      {%- if block.settings.address != blank -%}
                        <address class="lab_contact__info-value">{{ block.settings.address }}</address>
                      {%- endif -%}
                    </div>
                  </div>
              {%- endcase -%}
            {%- endfor -%}
          </aside>
        {%- endif -%}

        <div class="lab_contact__form-wrap{% if s.form_card_enabled %} lab_contact__form-wrap--card{% endif %}">
          {%- if s.show_heading and s.heading != blank -%}
            <h2 class="lab_contact__heading">{{ s.heading | escape }}</h2>
          {%- endif -%}

          {%- if s.show_subheading and s.subheading != blank -%}
            <div class="lab_contact__subheading">{{ s.subheading }}</div>
          {%- endif -%}

          {%- form 'contact', id: contact_form_id, class: 'lab_contact__form' -%}
            {%- if form.posted_successfully? -%}
              <div class="lab_contact__success" role="status" aria-live="polite" tabindex="-1">
                <svg class="lab_contact__success-icon" aria-hidden="true" focusable="false" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                <p>{{ s.success_message | default: 'Thanks for reaching out — we will be in touch soon.' | escape }}</p>
              </div>
            {%- endif -%}

            {%- if form.errors -%}
              <div class="lab_contact__errors" role="alert" tabindex="-1" id="{{ contact_form_id }}-errors">
                <p class="lab_contact__errors-title">
                  {{- 'templates.contact.form.error_heading' | t | default: 'Please correct the highlighted fields' -}}
                </p>
                <ul class="lab_contact__errors-list" role="list">
                  {%- for error in form.errors -%}
                    <li>
                      {%- if error == 'form' -%}
                        {{ form.errors.messages[error] }}
                      {%- else -%}
                        <a href="#{{ contact_form_id }}-{{ error }}">
                          {{- form.errors.translated_fields[error] | capitalize }} {{ form.errors.messages[error] -}}
                        </a>
                      {%- endif -%}
                    </li>
                  {%- endfor -%}
                </ul>
              </div>
            {%- endif -%}

            {%- unless form.posted_successfully? and s.hide_form_after_success -%}
              <div class="lab_contact__fields">
                {%- for block in section.blocks -%}
                  {%- case block.type -%}
                    {%- when 'email_field' -%}
                      {%- assign field_id = contact_form_id | append: '-email' -%}
                      <div class="lab_contact__field lab_contact__field--full" {{ block.shopify_attributes }}>
                        <label for="{{ field_id }}" class="lab_contact__label">
                          {{- block.settings.label | default: 'Email' | escape -}}
                          {%- if block.settings.required %} <span class="lab_contact__required" aria-hidden="true">*</span>{% endif -%}
                        </label>
                        <input
                          type="email"
                          id="{{ field_id }}"
                          name="contact[email]"
                          autocomplete="email"
                          autocorrect="off"
                          autocapitalize="off"
                          spellcheck="false"
                          placeholder="{{ block.settings.placeholder | default: 'your@email.com' | escape }}"
                          class="lab_contact__input{% if form.errors contains 'email' %} lab_contact__input--error{% endif %}"
                          value="{% if form.email %}{{ form.email | escape }}{% elsif customer %}{{ customer.email | escape }}{% endif %}"
                          {% if block.settings.required %}required{% endif %}
                          {% if form.errors contains 'email' %}aria-invalid="true" aria-describedby="{{ field_id }}-error"{% endif %}
                        >
                        {%- if form.errors contains 'email' -%}
                          <span class="lab_contact__field-error" id="{{ field_id }}-error">
                            {{- form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email -}}
                          </span>
                        {%- endif -%}
                      </div>

                    {%- when 'text_field' -%}
                      {%- assign field_name = block.settings.field_name | default: 'name' | handle -%}
                      {%- assign field_id = contact_form_id | append: '-' | append: field_name -%}
                      <div class="lab_contact__field lab_contact__field--{{ block.settings.field_width }}" {{ block.shopify_attributes }}>
                        <label for="{{ field_id }}" class="lab_contact__label">
                          {{- block.settings.label | escape -}}
                          {%- if block.settings.required %} <span class="lab_contact__required" aria-hidden="true">*</span>{% endif -%}
                        </label>
                        <input
                          type="text"
                          id="{{ field_id }}"
                          name="contact[{{ field_name }}]"
                          autocomplete="{{ block.settings.autocomplete | default: 'off' }}"
                          placeholder="{{ block.settings.placeholder | escape }}"
                          class="lab_contact__input"
                          value="{% if field_name == 'name' %}{% if form.name %}{{ form.name | escape }}{% elsif customer %}{{ customer.name | escape }}{% endif %}{% endif %}"
                          {% if block.settings.required %}required{% endif %}
                        >
                      </div>

                    {%- when 'tel_field' -%}
                      {%- assign field_name = block.settings.field_name | default: 'phone' | handle -%}
                      {%- assign field_id = contact_form_id | append: '-' | append: field_name -%}
                      <div class="lab_contact__field lab_contact__field--{{ block.settings.field_width }}" {{ block.shopify_attributes }}>
                        <label for="{{ field_id }}" class="lab_contact__label">
                          {{- block.settings.label | escape -}}
                          {%- if block.settings.required %} <span class="lab_contact__required" aria-hidden="true">*</span>{% endif -%}
                        </label>
                        <input
                          type="tel"
                          id="{{ field_id }}"
                          name="contact[{{ field_name }}]"
                          autocomplete="tel"
                          inputmode="tel"
                          pattern="[0-9\-+\s\(\)]+"
                          placeholder="{{ block.settings.placeholder | escape }}"
                          class="lab_contact__input"
                          value="{% if form.phone %}{{ form.phone | escape }}{% endif %}"
                          {% if block.settings.required %}required{% endif %}
                        >
                      </div>

                    {%- when 'textarea_field' -%}
                      {%- assign field_name = block.settings.field_name | default: 'body' | handle -%}
                      {%- assign field_id = contact_form_id | append: '-' | append: field_name -%}
                      <div class="lab_contact__field lab_contact__field--full" {{ block.shopify_attributes }}>
                        <label for="{{ field_id }}" class="lab_contact__label">
                          {{- block.settings.label | default: 'Message' | escape -}}
                          {%- if block.settings.required %} <span class="lab_contact__required" aria-hidden="true">*</span>{% endif -%}
                        </label>
                        <textarea
                          id="{{ field_id }}"
                          name="contact[{{ field_name }}]"
                          rows="{{ block.settings.rows | default: 5 }}"
                          placeholder="{{ block.settings.placeholder | escape }}"
                          class="lab_contact__input lab_contact__textarea{% if form.errors contains 'body' and field_name == 'body' %} lab_contact__input--error{% endif %}"
                          {% if block.settings.required %}required{% endif %}
                          {% if form.errors contains 'body' and field_name == 'body' %}aria-invalid="true" aria-describedby="{{ field_id }}-error"{% endif %}
                        >{% if field_name == 'body' and form.body %}{{ form.body }}{% endif %}</textarea>
                        {%- if form.errors contains 'body' and field_name == 'body' -%}
                          <span class="lab_contact__field-error" id="{{ field_id }}-error">
                            {{- form.errors.translated_fields.body | capitalize }} {{ form.errors.messages.body -}}
                          </span>
                        {%- endif -%}
                      </div>

                    {%- when 'select_field' -%}
                      {%- assign field_name = block.settings.field_name | default: 'topic' | handle -%}
                      {%- assign field_id = contact_form_id | append: '-' | append: field_name -%}
                      {%- assign options_lines = block.settings.options_manual | newline_to_br | split: '<br />' -%}
                      <div class="lab_contact__field lab_contact__field--{{ block.settings.field_width }}" {{ block.shopify_attributes }}>
                        <label for="{{ field_id }}" class="lab_contact__label">
                          {{- block.settings.label | escape -}}
                          {%- if block.settings.required %} <span class="lab_contact__required" aria-hidden="true">*</span>{% endif -%}
                        </label>
                        <div class="lab_contact__select-wrap">
                          <select
                            id="{{ field_id }}"
                            name="contact[{{ field_name }}]"
                            class="lab_contact__input lab_contact__select"
                            {% if block.settings.required %}required{% endif %}
                          >
                            {%- if block.settings.placeholder != blank -%}
                              <option value="">{{ block.settings.placeholder | escape }}</option>
                            {%- endif -%}
                            {%- for line in options_lines -%}
                              {%- assign trimmed = line | strip -%}
                              {%- if trimmed != blank -%}
                                {%- assign parts = trimmed | split: '|' -%}
                                {%- if parts.size >= 2 -%}
                                  <option value="{{ parts[1] | strip | escape }}">{{ parts[0] | strip | escape }}</option>
                                {%- elsif parts.size == 1 -%}
                                  <option value="{{ parts[0] | strip | escape }}">{{ parts[0] | strip | escape }}</option>
                                {%- endif -%}
                              {%- endif -%}
                            {%- endfor -%}
                          </select>
                          <svg class="lab_contact__chevron" aria-hidden="true" focusable="false" viewBox="0 0 12 8" width="12" height="8">
                            <path d="M1 1.5L6 6.5L11 1.5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                          </svg>
                        </div>
                      </div>

                    {%- when 'checkbox_field' -%}
                      {%- assign field_name = block.settings.field_name | default: 'consent' | handle -%}
                      {%- assign field_id = contact_form_id | append: '-' | append: field_name -%}
                      <div class="lab_contact__field lab_contact__field--full lab_contact__field--checkbox" {{ block.shopify_attributes }}>
                        <input
                          type="checkbox"
                          id="{{ field_id }}"
                          name="contact[{{ field_name }}]"
                          value="{{ block.settings.checked_value | default: 'yes' | escape }}"
                          class="lab_contact__checkbox"
                          {% if block.settings.required %}required{% endif %}
                        >
                        <label for="{{ field_id }}" class="lab_contact__checkbox-label">
                          {{ block.settings.label }}
                          {%- if block.settings.required %} <span class="lab_contact__required" aria-hidden="true">*</span>{% endif -%}
                        </label>
                      </div>
                  {%- endcase -%}
                {%- endfor -%}
              </div>

              <div class="lab_contact__submit-wrap lab_contact__submit-wrap--align-{{ s.submit_align }}{% if s.submit_full_width %} lab_contact__submit-wrap--full{% endif %}">
                <button type="submit" class="lab_contact__submit">
                  {{ s.submit_label | default: 'Send message' | escape }}
                </button>
              </div>
            {%- endunless -%}
          {%- endform -%}
        </div>
      </div>
    </div>
  </section>
</div>

{%- comment -%} 3. CSS — section scoped {%- endcomment -%}
<style>
  /* Section root */
  #shopify-section-{{ section_id }} .lab_contact {
    position: relative;
    {% if s.bg_color != blank %}
      background-color: color-mix(in srgb, {{ s.bg_color }} {{ bg_pct }}%, transparent);
    {% else %}
      background-color: var(--color-background);
    {% endif %}
    {% if s.bg_gradient and s.bg_color != blank and s.bg_gradient_color != blank %}
      background-image: linear-gradient(
        {{ s.bg_gradient_direction }},
        color-mix(in srgb, {{ s.bg_color }} {{ bg_pct }}%, transparent),
        color-mix(in srgb, {{ s.bg_gradient_color }} {{ bg_grad_pct }}%, transparent)
      );
    {% endif %}
  }

  {% if s.spacing_size == 'custom' %}
    #shopify-section-{{ section_id }} .lab_contact {
      margin-top: {{ s.spacing_top_custom }}px;
      margin-bottom: {{ s.spacing_bottom_custom }}px;
    }
  {% endif %}

  /* Layout — mobile-first stack */
  #shopify-section-{{ section_id }} .lab_contact__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: start;
  }

  /* Heading */
  #shopify-section-{{ section_id }} .lab_contact__heading {
    margin: 0 0 clamp(0.5rem, 1.5vw, 0.75rem);
    font-size: {{ s.heading_size_mobile }}px;
    font-weight: {{ s.heading_weight }};
    text-transform: {{ s.heading_transform }};
    text-align: {{ s.heading_text_align }};
    letter-spacing: calc({{ s.heading_letter_spacing }} / 100 * 1em);
    line-height: calc({{ s.heading_line_height }} / 10);
    {% if s.heading_color != blank %}
      color: color-mix(in srgb, {{ s.heading_color }} {{ s.heading_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground);
    {% endif %}
  }

  /* Subheading */
  #shopify-section-{{ section_id }} .lab_contact__subheading {
    margin: 0 0 clamp(1rem, 2.5vw, 1.5rem);
    font-size: {{ s.subheading_size_mobile }}px;
    font-weight: {{ s.subheading_weight }};
    text-transform: {{ s.subheading_transform }};
    text-align: {{ s.subheading_text_align }};
    letter-spacing: calc({{ s.subheading_letter_spacing }} / 100 * 1em);
    line-height: calc({{ s.subheading_line_height }} / 10);
    {% if s.subheading_color != blank %}
      color: color-mix(in srgb, {{ s.subheading_color }} {{ s.subheading_color_opacity }}%, transparent);
    {% else %}
      color: color-mix(in srgb, var(--color-foreground) 75%, transparent);
    {% endif %}
  }

  #shopify-section-{{ section_id }} .lab_contact__subheading > * { margin: 0; }
  #shopify-section-{{ section_id }} .lab_contact__subheading > * + * { margin-top: 0.5em; }

  /* Form wrap (optionally card-styled) */
  #shopify-section-{{ section_id }} .lab_contact__form-wrap {
    width: 100%;
  }

  #shopify-section-{{ section_id }} .lab_contact__form-wrap--card {
    padding: {{ s.form_card_padding_mobile }}px;
    border-radius: {{ s.form_card_border_radius }}px;
    border: {{ s.form_card_border_width }}px solid {% if s.form_card_border_color != blank %}color-mix(in srgb, {{ s.form_card_border_color }} {{ s.form_card_border_color_opacity }}%, transparent){% else %}transparent{% endif %};
    box-shadow: {{ card_shadow_css }};
    {% if s.form_card_bg_color != blank %}
      background-color: color-mix(in srgb, {{ s.form_card_bg_color }} {{ s.form_card_bg_color_opacity }}%, transparent);
    {% else %}
      background-color: var(--color-background);
    {% endif %}
  }

  /* Form */
  #shopify-section-{{ section_id }} .lab_contact__form {
    display: flex;
    flex-direction: column;
    gap: clamp(0.75rem, 2vw, 1.25rem);
    margin: 0;
  }

  /* Fields grid — mobile-first single column */
  #shopify-section-{{ section_id }} .lab_contact__fields {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(0.75rem, 2vw, 1.25rem);
  }

  /* Field */
  #shopify-section-{{ section_id }} .lab_contact__field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    min-width: 0;
  }

  #shopify-section-{{ section_id }} .lab_contact__field--checkbox {
    flex-direction: row;
    align-items: flex-start;
    gap: 0.6rem;
  }

  /* Label */
  #shopify-section-{{ section_id }} .lab_contact__label {
    font-size: {{ s.label_size }}px;
    font-weight: {{ s.label_weight }};
    text-transform: {{ s.label_transform }};
    letter-spacing: 0.01em;
    {% if s.label_color != blank %}
      color: color-mix(in srgb, {{ s.label_color }} {{ s.label_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground);
    {% endif %}
  }

  #shopify-section-{{ section_id }} .lab_contact__required {
    margin-left: 0.15rem;
    color: color-mix(in srgb, var(--color-foreground) 55%, transparent);
  }

  /* Input / textarea / select */
  #shopify-section-{{ section_id }} .lab_contact__input {
    width: 100%;
    min-height: 44px;
    padding: {{ s.field_padding_y }}px {{ s.field_padding_x }}px;
    border: {{ s.field_border_width }}px solid {% if s.field_border_color != blank %}color-mix(in srgb, {{ s.field_border_color }} {{ s.field_border_color_opacity }}%, transparent){% else %}color-mix(in srgb, var(--color-foreground) 22%, transparent){% endif %};
    border-radius: {{ s.field_border_radius }}px;
    font-family: inherit;
    font-size: 1rem;
    line-height: 1.4;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
    {% if s.field_bg_color != blank %}
      background-color: color-mix(in srgb, {{ s.field_bg_color }} {{ s.field_bg_color_opacity }}%, transparent);
    {% else %}
      background-color: var(--color-background);
    {% endif %}
    {% if s.field_text_color != blank %}
      color: color-mix(in srgb, {{ s.field_text_color }} {{ s.field_text_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground);
    {% endif %}
  }

  #shopify-section-{{ section_id }} .lab_contact__input::placeholder {
    color: color-mix(in srgb, currentColor 45%, transparent);
  }

  #shopify-section-{{ section_id }} .lab_contact__textarea {
    min-height: 120px;
    resize: vertical;
    line-height: 1.5;
  }

  #shopify-section-{{ section_id }} .lab_contact__input:focus,
  #shopify-section-{{ section_id }} .lab_contact__input:focus-visible {
    outline: none;
    border-color: {% if s.field_focus_color != blank %}color-mix(in srgb, {{ s.field_focus_color }} {{ s.field_focus_color_opacity }}%, transparent){% else %}var(--color-foreground){% endif %};
    box-shadow: 0 0 0 3px {% if s.field_focus_color != blank %}color-mix(in srgb, {{ s.field_focus_color }} 22%, transparent){% else %}color-mix(in srgb, var(--color-foreground) 18%, transparent){% endif %};
  }

  #shopify-section-{{ section_id }} .lab_contact__input--error {
    border-color: {% if s.field_error_color != blank %}color-mix(in srgb, {{ s.field_error_color }} 100%, transparent){% else %}#d72c0d{% endif %};
  }

  #shopify-section-{{ section_id }} .lab_contact__input--error:focus,
  #shopify-section-{{ section_id }} .lab_contact__input--error:focus-visible {
    border-color: {% if s.field_error_color != blank %}{{ s.field_error_color }}{% else %}#d72c0d{% endif %};
    box-shadow: 0 0 0 3px {% if s.field_error_color != blank %}color-mix(in srgb, {{ s.field_error_color }} 22%, transparent){% else %}rgba(215, 44, 13, 0.22){% endif %};
  }

  /* Select wrap with chevron */
  #shopify-section-{{ section_id }} .lab_contact__select-wrap {
    position: relative;
    display: block;
  }

  #shopify-section-{{ section_id }} .lab_contact__select {
    appearance: none;
    -webkit-appearance: none;
    -moz-appearance: none;
    padding-right: {{ s.field_padding_x | plus: 32 }}px;
    cursor: pointer;
  }

  #shopify-section-{{ section_id }} .lab_contact__chevron {
    position: absolute;
    top: 50%;
    right: 14px;
    transform: translateY(-50%);
    pointer-events: none;
    color: currentColor;
    opacity: 0.6;
  }

  /* Checkbox */
  #shopify-section-{{ section_id }} .lab_contact__checkbox {
    width: 18px;
    height: 18px;
    margin-top: 0.15rem;
    flex-shrink: 0;
    accent-color: {% if s.field_focus_color != blank %}{{ s.field_focus_color }}{% else %}var(--color-foreground){% endif %};
    cursor: pointer;
  }

  #shopify-section-{{ section_id }} .lab_contact__checkbox-label {
    font-size: 0.95rem;
    line-height: 1.4;
    {% if s.label_color != blank %}
      color: color-mix(in srgb, {{ s.label_color }} {{ s.label_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground);
    {% endif %}
    cursor: pointer;
  }

  #shopify-section-{{ section_id }} .lab_contact__checkbox-label > * {
    margin: 0;
    display: inline;
  }

  #shopify-section-{{ section_id }} .lab_contact__checkbox-label a {
    color: currentColor;
    text-decoration: underline;
  }

  /* Field error message */
  #shopify-section-{{ section_id }} .lab_contact__field-error {
    font-size: 0.85rem;
    color: {% if s.field_error_color != blank %}{{ s.field_error_color }}{% else %}#d72c0d{% endif %};
    margin-top: 0.15rem;
  }

  /* Submit button wrap (alignment) */
  #shopify-section-{{ section_id }} .lab_contact__submit-wrap {
    display: flex;
  }
  #shopify-section-{{ section_id }} .lab_contact__submit-wrap--align-left { justify-content: flex-start; }
  #shopify-section-{{ section_id }} .lab_contact__submit-wrap--align-center { justify-content: center; }
  #shopify-section-{{ section_id }} .lab_contact__submit-wrap--align-right { justify-content: flex-end; }
  #shopify-section-{{ section_id }} .lab_contact__submit-wrap--full .lab_contact__submit { width: 100%; }

  /* Submit button */
  #shopify-section-{{ section_id }} .lab_contact__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: {{ s.submit_padding_y }}px {{ s.submit_padding_x }}px;
    border-radius: {{ s.submit_border_radius }}px;
    border: {{ s.submit_border_width }}px solid {% if s.submit_border_color != blank %}color-mix(in srgb, {{ s.submit_border_color }} {{ s.submit_border_color_opacity }}%, transparent){% else %}transparent{% endif %};
    font-family: inherit;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
    {% if s.submit_bg_color != blank %}
      background-color: color-mix(in srgb, {{ s.submit_bg_color }} {{ s.submit_bg_color_opacity }}%, transparent);
    {% else %}
      background-color: var(--color-button);
    {% endif %}
    {% if s.submit_text_color != blank %}
      color: color-mix(in srgb, {{ s.submit_text_color }} {{ s.submit_text_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-button-text);
    {% endif %}
  }

  /* Submit hover variants */
  #shopify-section-{{ section_id }} .lab_contact--btn-hover-fill .lab_contact__submit:hover,
  #shopify-section-{{ section_id }} .lab_contact--btn-hover-darken .lab_contact__submit:hover,
  #shopify-section-{{ section_id }} .lab_contact--btn-hover-lift .lab_contact__submit:hover,
  #shopify-section-{{ section_id }} .lab_contact--btn-hover-glow .lab_contact__submit:hover {
    {% if s.submit_hover_bg_color != blank %}
      background-color: color-mix(in srgb, {{ s.submit_hover_bg_color }} {{ s.submit_hover_bg_color_opacity }}%, transparent);
    {% endif %}
    {% if s.submit_hover_text_color != blank %}
      color: color-mix(in srgb, {{ s.submit_hover_text_color }} {{ s.submit_hover_text_color_opacity }}%, transparent);
    {% endif %}
    {% if s.submit_hover_border_color != blank %}
      border-color: color-mix(in srgb, {{ s.submit_hover_border_color }} {{ s.submit_hover_border_color_opacity }}%, transparent);
    {% endif %}
  }

  #shopify-section-{{ section_id }} .lab_contact--btn-hover-darken .lab_contact__submit:hover {
    filter: brightness(0.88);
  }
  #shopify-section-{{ section_id }} .lab_contact--btn-hover-lift .lab_contact__submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px color-mix(in srgb, var(--color-foreground) 18%, transparent);
  }
  #shopify-section-{{ section_id }} .lab_contact--btn-hover-glow .lab_contact__submit:hover {
    box-shadow: 0 0 24px {% if s.submit_hover_bg_color != blank %}color-mix(in srgb, {{ s.submit_hover_bg_color }} 60%, transparent){% else %}color-mix(in srgb, var(--color-foreground) 25%, transparent){% endif %};
  }
  #shopify-section-{{ section_id }} .lab_contact--btn-hover-outline .lab_contact__submit:hover {
    background-color: transparent;
    {% if s.submit_hover_text_color != blank %}
      color: color-mix(in srgb, {{ s.submit_hover_text_color }} {{ s.submit_hover_text_color_opacity }}%, transparent);
    {% endif %}
    {% if s.submit_hover_border_color != blank %}
      border-color: color-mix(in srgb, {{ s.submit_hover_border_color }} {{ s.submit_hover_border_color_opacity }}%, transparent);
    {% endif %}
  }

  #shopify-section-{{ section_id }} .lab_contact__submit:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 3px;
  }

  /* Success message */
  #shopify-section-{{ section_id }} .lab_contact__success {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    padding: 1rem 1.25rem;
    border-radius: 8px;
    background-color: color-mix(in srgb, #16a34a 12%, transparent);
    border: 1px solid color-mix(in srgb, #16a34a 35%, transparent);
    color: var(--color-foreground);
  }

  #shopify-section-{{ section_id }} .lab_contact__success p {
    margin: 0;
    font-weight: 500;
    line-height: 1.5;
  }

  #shopify-section-{{ section_id }} .lab_contact__success-icon {
    flex-shrink: 0;
    margin-top: 0.1rem;
    color: #16a34a;
  }

  /* Errors summary */
  #shopify-section-{{ section_id }} .lab_contact__errors {
    padding: 1rem 1.25rem;
    border-radius: 8px;
    background-color: color-mix(in srgb, {% if s.field_error_color != blank %}{{ s.field_error_color }}{% else %}#d72c0d{% endif %} 8%, transparent);
    border: 1px solid color-mix(in srgb, {% if s.field_error_color != blank %}{{ s.field_error_color }}{% else %}#d72c0d{% endif %} 35%, transparent);
    color: var(--color-foreground);
  }

  #shopify-section-{{ section_id }} .lab_contact__errors-title {
    margin: 0 0 0.5rem;
    font-weight: 600;
    font-size: 0.95rem;
    color: {% if s.field_error_color != blank %}{{ s.field_error_color }}{% else %}#d72c0d{% endif %};
  }

  #shopify-section-{{ section_id }} .lab_contact__errors-list {
    margin: 0;
    padding-left: 1.25rem;
    font-size: 0.9rem;
    list-style: disc;
  }

  #shopify-section-{{ section_id }} .lab_contact__errors-list a {
    color: inherit;
    text-decoration: underline;
  }

  /* Info column */
  #shopify-section-{{ section_id }} .lab_contact__info {
    display: flex;
    flex-direction: column;
    gap: clamp(0.75rem, 2vw, 1.25rem);
  }

  #shopify-section-{{ section_id }} .lab_contact__info--align-center {
    align-items: center;
    text-align: center;
  }

  #shopify-section-{{ section_id }} .lab_contact__info-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    min-width: 0;
  }

  #shopify-section-{{ section_id }} .lab_contact__info--align-center .lab_contact__info-item {
    justify-content: center;
  }

  #shopify-section-{{ section_id }} .lab_contact__info-icon {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 999px;
    background-color: color-mix(in srgb, var(--color-foreground) 8%, transparent);
    color: var(--color-foreground);
  }

  #shopify-section-{{ section_id }} .lab_contact__info-text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }

  #shopify-section-{{ section_id }} .lab_contact__info-label {
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: color-mix(in srgb, var(--color-foreground) 65%, transparent);
  }

  #shopify-section-{{ section_id }} .lab_contact__info-value {
    font-size: 1rem;
    color: var(--color-foreground);
    text-decoration: none;
    word-break: break-word;
    font-style: normal;
  }

  #shopify-section-{{ section_id }} .lab_contact__info-value:hover {
    text-decoration: underline;
  }

  /* Tablet/desktop */
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section_id }} .lab_contact__heading {
      font-size: {{ s.heading_size_desktop }}px;
    }

    #shopify-section-{{ section_id }} .lab_contact__subheading {
      font-size: {{ s.subheading_size_desktop }}px;
    }

    #shopify-section-{{ section_id }} .lab_contact__form-wrap--card {
      padding: {{ s.form_card_padding_desktop }}px;
    }

    /* Two-column layout */
    #shopify-section-{{ section_id }} .lab_contact--layout-two-column .lab_contact__layout {
      grid-template-columns: 1fr 1.6fr;
      gap: clamp(2rem, 4vw, 3.5rem);
    }
    #shopify-section-{{ section_id }} .lab_contact--layout-two-column-reverse .lab_contact__layout {
      grid-template-columns: 1.6fr 1fr;
      gap: clamp(2rem, 4vw, 3.5rem);
    }
    #shopify-section-{{ section_id }} .lab_contact--layout-two-column-reverse .lab_contact__info {
      order: 2;
    }

    /* Fields grid two-column on desktop */
    #shopify-section-{{ section_id }} .lab_contact__fields {
      grid-template-columns: 1fr 1fr;
    }
    #shopify-section-{{ section_id }} .lab_contact__field--full {
      grid-column: 1 / -1;
    }
    #shopify-section-{{ section_id }} .lab_contact__field--half {
      grid-column: span 1;
    }
  }

  /* Entrance animation */
  {% if anim_enabled %}
    #shopify-section-{{ section_id }} .lab_contact--animated .lab_contact__layout {
      opacity: 0;
      animation-duration: 0.6s;
      animation-delay: 0.1s;
      animation-fill-mode: forwards;
      animation-timing-function: ease-out;
    }
    #shopify-section-{{ section_id }} .lab_contact--anim-fade .lab_contact__layout {
      animation-name: lab_contact_fade_{{ section_id }};
    }
    #shopify-section-{{ section_id }} .lab_contact--anim-slide-up .lab_contact__layout {
      animation-name: lab_contact_slide_{{ section_id }};
    }
    @keyframes lab_contact_fade_{{ section_id }} {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    @keyframes lab_contact_slide_{{ section_id }} {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
  {% endif %}

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section_id }} *,
    #shopify-section-{{ section_id }} *::before,
    #shopify-section-{{ section_id }} *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }

  {% if s.hide_on_mobile %}
    #shopify-section-{{ section_id }} { display: none; }
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section_id }} {
        display: {% if s.hide_on_desktop %}none{% else %}revert{% endif %};
      }
    }
  {% elsif s.hide_on_desktop %}
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section_id }} { display: none; }
    }
  {% endif %}

  {% if s.custom_css != blank %}
    #shopify-section-{{ section_id }} {
      {{ s.custom_css }}
    }
  {% endif %}
</style>

{% schema %}
{
  "name": "🧪 Contact Form",
  "tag": "section",
  "class": "lab_section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "checkbox", "id": "show_heading", "label": "Show heading", "default": true },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get in touch", "visible_if": "{{ section.settings.show_heading }}" },
    { "type": "checkbox", "id": "show_subheading", "label": "Show subheading", "default": true },
    { "type": "richtext", "id": "subheading", "label": "Subheading", "default": "<p>We'll get back to you within 24 hours.</p>", "visible_if": "{{ section.settings.show_subheading }}" },

    { "type": "header", "content": "Form" },
    { "type": "text", "id": "submit_label", "label": "Submit button label", "default": "Send message" },
    { "type": "textarea", "id": "success_message", "label": "Success message", "default": "Thanks for reaching out — we will be in touch soon." },
    { "type": "checkbox", "id": "hide_form_after_success", "label": "Hide form after successful submission", "default": false, "info": "When unchecked, form remains visible alongside the success message." },

    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "layout_style",
      "label": "Layout",
      "options": [
        { "value": "single", "label": "Single column (form only)" },
        { "value": "two-column", "label": "Two column (info left, form right)" },
        { "value": "two-column-reverse", "label": "Two column (form left, info right)" }
      ],
      "default": "single"
    },
    { "type": "checkbox", "id": "show_info_column", "label": "Show info column", "default": false, "info": "Requires layout = two-column or two-column-reverse, and at least one info block." },
    {
      "type": "select",
      "id": "info_column_align",
      "label": "Info column alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left",
      "visible_if": "{{ section.settings.show_info_column }}"
    },
    { "type": "checkbox", "id": "hide_on_mobile", "label": "Hide on mobile", "default": false },
    { "type": "checkbox", "id": "hide_on_desktop", "label": "Hide on desktop", "default": false },

    { "type": "header", "content": "Typography" },
    { "type": "range", "id": "heading_size_mobile", "label": "Heading size (mobile)", "min": 14, "max": 60, "step": 1, "unit": "px", "default": 28 },
    { "type": "range", "id": "heading_size_desktop", "label": "Heading size (desktop)", "min": 14, "max": 80, "step": 1, "unit": "px", "default": 36 },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading weight",
      "options": [
        { "value": "300", "label": "Thin" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "heading_transform",
      "label": "Heading transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "heading_text_align",
      "label": "Heading text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    { "type": "color", "id": "heading_color", "label": "Heading color" },
    { "type": "range", "id": "heading_color_opacity", "label": "Heading color opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 100 },
    { "type": "range", "id": "heading_letter_spacing", "label": "Heading letter spacing", "min": -5, "max": 20, "step": 1, "unit": "em", "default": -1, "info": "1/100em (0 = 0em, 10 = 0.1em)" },
    { "type": "range", "id": "heading_line_height", "label": "Heading line height", "min": 10, "max": 30, "step": 1, "default": 12 },

    { "type": "range", "id": "subheading_size_mobile", "label": "Subheading size (mobile)", "min": 12, "max": 32, "step": 1, "unit": "px", "default": 15 },
    { "type": "range", "id": "subheading_size_desktop", "label": "Subheading size (desktop)", "min": 12, "max": 32, "step": 1, "unit": "px", "default": 16 },
    {
      "type": "select",
      "id": "subheading_weight",
      "label": "Subheading weight",
      "options": [
        { "value": "300", "label": "Thin" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" }
      ],
      "default": "400"
    },
    {
      "type": "select",
      "id": "subheading_transform",
      "label": "Subheading transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "subheading_text_align",
      "label": "Subheading text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    { "type": "color", "id": "subheading_color", "label": "Subheading color" },
    { "type": "range", "id": "subheading_color_opacity", "label": "Subheading color opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 100 },
    { "type": "range", "id": "subheading_letter_spacing", "label": "Subheading letter spacing", "min": -5, "max": 20, "step": 1, "unit": "em", "default": 0 },
    { "type": "range", "id": "subheading_line_height", "label": "Subheading line height", "min": 10, "max": 30, "step": 1, "default": 15 },

    { "type": "range", "id": "label_size", "label": "Field label size", "min": 10, "max": 20, "step": 1, "unit": "px", "default": 13 },
    {
      "type": "select",
      "id": "label_weight",
      "label": "Field label weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "500"
    },
    {
      "type": "select",
      "id": "label_transform",
      "label": "Field label transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "none"
    },
    { "type": "color", "id": "label_color", "label": "Field label color" },
    { "type": "range", "id": "label_color_opacity", "label": "Field label color opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 100 },

    { "type": "header", "content": "Appearance" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "color", "id": "bg_color", "label": "Section background color" },
    { "type": "range", "id": "bg_opacity", "label": "Section background opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 100 },
    { "type": "checkbox", "id": "bg_gradient", "label": "Enable gradient background", "default": false },
    { "type": "color", "id": "bg_gradient_color", "label": "Gradient second color", "visible_if": "{{ section.settings.bg_gradient }}" },
    { "type": "range", "id": "bg_gradient_color_opacity", "label": "Gradient second color opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 100, "visible_if": "{{ section.settings.bg_gradient }}" },
    {
      "type": "select",
      "id": "bg_gradient_direction",
      "label": "Gradient direction",
      "options": [
        { "value": "to bottom", "label": "To bottom" },
        { "value": "to right", "label": "To right" },
        { "value": "to bottom right", "label": "To bottom right" },
        { "value": "to bottom left", "label": "To bottom left" }
      ],
      "default": "to bottom",
      "visible_if": "{{ section.settings.bg_gradient }}"
    },

    { "type": "checkbox", "id": "form_card_enabled", "label": "Enable form card styling", "default": true, "info": "When off, the form is transparent over the section background." },
    { "type": "color", "id": "form_card_bg_color", "label": "Form card background color", "visible_if": "{{ section.settings.form_card_enabled }}" },
    { "type": "range", "id": "form_card_bg_color_opacity", "label": "Form card background color opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 100, "visible_if": "{{ section.settings.form_card_enabled }}" },
    { "type": "color", "id": "form_card_border_color", "label": "Form card border color", "visible_if": "{{ section.settings.form_card_enabled }}" },
    { "type": "range", "id": "form_card_border_color_opacity", "label": "Form card border color opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 100, "visible_if": "{{ section.settings.form_card_enabled }}" },
    { "type": "range", "id": "form_card_border_width", "label": "Form card border width", "min": 0, "max": 4, "step": 1, "unit": "px", "default": 1, "visible_if": "{{ section.settings.form_card_enabled }}" },
    { "type": "range", "id": "form_card_border_radius", "label": "Form card border radius", "min": 0, "max": 32, "step": 2, "unit": "px", "default": 12, "visible_if": "{{ section.settings.form_card_enabled }}" },
    {
      "type": "select",
      "id": "form_card_shadow",
      "label": "Form card shadow",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "soft", "label": "Soft" },
        { "value": "medium", "label": "Medium" },
        { "value": "strong", "label": "Strong" }
      ],
      "default": "soft",
      "visible_if": "{{ section.settings.form_card_enabled }}"
