{%- comment -%} 1. Assigns {%- endcomment -%}
{%- liquid
  assign section_id = section.id
  assign s = section.settings

  assign slides = section.blocks | where: 'type', 'slide'
  assign filters = section.blocks | where: 'type', 'filter'
  assign slide_count = slides.size

  assign autoplay = s.slider_autoplay
  assign anim_enabled = s.entrance_animation
  assign anim_type = s.entrance_type
  assign bg_pct = s.bg_opacity
  assign bg_grad_pct = s.bg_gradient_color_opacity

  assign card_shadow = s.finder_card_shadow
  case card_shadow
    when 'soft'
      assign card_shadow_css = '0 2px 8px color-mix(in srgb, #000 12%, transparent)'
    when 'medium'
      assign card_shadow_css = '0 6px 18px color-mix(in srgb, #000 18%, transparent)'
    when 'strong'
      assign card_shadow_css = '0 12px 32px color-mix(in srgb, #000 28%, transparent)'
    else
      assign card_shadow_css = 'none'
  endcase

  assign overlay_style = s.slide_overlay_style
  assign finder_position = s.finder_position
-%}

{%- comment -%} 2. HTML structure {%- endcomment -%}
<div class="color-{{ s.color_scheme }} gradient">
  <section
    id="lab-{{ section_id }}"
    class="lab_hero_finder lab_hero_finder--width-{{ s.container_width }} lab_hero_finder--transition-{{ s.slider_transition }}{% if anim_enabled %} lab_hero_finder--animated lab_hero_finder--anim-{{ anim_type }}{% endif %} lab_section{% if s.spacing_size != 'custom' %} lab_section--spacing-{{ s.spacing_size }}{% endif %}"
    aria-label="{{ s.finder_heading | default: 'Hero with product finder' | escape }}"
    data-lab-position="{{ finder_position }}"
    data-lab-autoplay="{% if autoplay %}true{% else %}false{% endif %}"
    data-lab-speed="{{ s.slider_speed }}"
    data-lab-swipe="{% if s.slider_swipe_mobile %}true{% else %}false{% endif %}"
    data-lab-spacing="{{ s.spacing_size }}"
  >
    <div class="lab_hero_finder__inner">
      <div
        class="lab_hero_finder__slider"
        role="region"
        aria-roledescription="slideshow"
        aria-label="{{ 'Hero slideshow' | escape }}"
        tabindex="0"
        data-lab-slider
      >
        <div class="lab_hero_finder__track" data-lab-slider-track>
          {%- if slide_count > 0 -%}
            {%- for block in slides -%}
              {%- liquid
                assign overlay_color = s.slide_overlay_color
                assign overlay_opacity = s.slide_overlay_opacity
                if block.settings.use_custom_overlay
                  assign overlay_color = block.settings.slide_overlay_color
                  assign overlay_opacity = block.settings.slide_overlay_opacity
                endif

                if forloop.first and section.index <= 2
                  assign img_loading = 'eager'
                  assign img_priority = 'high'
                else
                  assign img_loading = 'lazy'
                  assign img_priority = 'auto'
                endif

                assign mobile_image = block.settings.slide_image_mobile
                assign desktop_image = block.settings.slide_image
              -%}
              <div
                class="lab_hero_finder__slide"
                role="group"
                aria-roledescription="slide"
                aria-label="Slide {{ forloop.index }} of {{ slide_count }}"
                {% if forloop.first %}aria-current="true"{% else %}aria-hidden="true"{% endif %}
                data-lab-slide-index="{{ forloop.index0 }}"
                data-lab-slide-id="{{ block.id }}"
                {{ block.shopify_attributes }}
              >
                <div class="lab_hero_finder__slide-media">
                  {%- if desktop_image != blank -%}
                    {{- desktop_image
                      | image_url: width: 2000
                      | image_tag:
                        alt: '',
                        loading: img_loading,
                        fetchpriority: img_priority,
                        width: 2000,
                        height: 1200,
                        widths: '600, 900, 1200, 1600, 2000',
                        sizes: '100vw',
                        class: 'lab_hero_finder__slide-image lab_hero_finder__slide-image--desktop' -}}
                  {%- else -%}
                    <div class="lab_hero_finder__slide-image lab_hero_finder__slide-image--placeholder lab_hero_finder__slide-image--desktop" aria-hidden="true"></div>
                  {%- endif -%}
                  {%- if mobile_image != blank -%}
                    {{- mobile_image
                      | image_url: width: 900
                      | image_tag:
                        alt: '',
                        loading: img_loading,
                        fetchpriority: img_priority,
                        width: 900,
                        height: 1200,
                        widths: '400, 600, 900',
                        sizes: '100vw',
                        class: 'lab_hero_finder__slide-image lab_hero_finder__slide-image--mobile' -}}
                  {%- endif -%}
                </div>

                <div
                  class="lab_hero_finder__slide-overlay lab_hero_finder__slide-overlay--{{ overlay_style }}"
                  style="--lab-slide-overlay-color: {{ overlay_color }}; --lab-slide-overlay-opacity: {{ overlay_opacity | divided_by: 100.0 }};"
                  aria-hidden="true"
                ></div>

                {%- if block.settings.slide_heading != blank or block.settings.slide_subheading != blank -%}
                  <div class="lab_hero_finder__slide-content">
                    {%- if block.settings.slide_heading != blank -%}
                      <h2 class="lab_hero_finder__slide-heading">{{ block.settings.slide_heading }}</h2>
                    {%- endif -%}
                    {%- if block.settings.slide_subheading != blank -%}
                      <p class="lab_hero_finder__slide-subheading">{{ block.settings.slide_subheading | escape | newline_to_br }}</p>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              </div>
            {%- endfor -%}
          {%- else -%}
            <div class="lab_hero_finder__slide lab_hero_finder__slide--empty" aria-hidden="true">
              <div class="lab_hero_finder__slide-media">
                <div class="lab_hero_finder__slide-image lab_hero_finder__slide-image--placeholder" aria-hidden="true"></div>
              </div>
              <div class="lab_hero_finder__slide-overlay lab_hero_finder__slide-overlay--solid" aria-hidden="true"></div>
            </div>
          {%- endif -%}
        </div>

        {%- if s.slider_show_arrows and slide_count > 1 -%}
          <button type="button" class="lab_hero_finder__arrow lab_hero_finder__arrow--prev" aria-label="Previous slide" data-lab-slider-prev>
            <svg aria-hidden="true" focusable="false" viewBox="0 0 16 16" width="16" height="16">
              <path d="M10 2L4 8l6 6" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button type="button" class="lab_hero_finder__arrow lab_hero_finder__arrow--next" aria-label="Next slide" data-lab-slider-next>
            <svg aria-hidden="true" focusable="false" viewBox="0 0 16 16" width="16" height="16">
              <path d="M6 2l6 6-6 6" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        {%- endif -%}

        {%- if s.slider_show_dots and slide_count > 1 -%}
          <div class="lab_hero_finder__dots" role="tablist" aria-label="Slide navigation">
            {%- for block in slides -%}
              <button
                type="button"
                class="lab_hero_finder__dot"
                role="tab"
                aria-label="Go to slide {{ forloop.index }}"
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                data-lab-slider-dot="{{ forloop.index0 }}"
              ></button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <div class="lab_hero_finder__overlay">
        {%- render 'liquid-lab-product-finder',
          show_heading: s.finder_show_heading,
          heading: s.finder_heading,
          show_subheading: s.finder_show_subheading,
          subheading: s.finder_subheading,
          form_target: s.finder_form_target,
          submit_label: s.finder_submit_label,
          blocks: filters,
          card_settings: section,
          context: 'overlay'
        -%}
      </div>
    </div>
  </section>
</div>

{%- comment -%} 3. CSS — section scoped {%- endcomment -%}
<style>
  /* Section root */
  #shopify-section-{{ section_id }} .lab_hero_finder {
    position: relative;
    {% if s.bg_color != blank %}
      background-color: color-mix(in srgb, {{ s.bg_color }} {{ bg_pct }}%, transparent);
    {% else %}
      background-color: var(--color-background);
    {% endif %}
    {% if s.bg_gradient and s.bg_color != blank and s.bg_gradient_color != blank %}
      background-image: linear-gradient(
        {{ s.bg_gradient_direction }},
        color-mix(in srgb, {{ s.bg_color }} {{ bg_pct }}%, transparent),
        color-mix(in srgb, {{ s.bg_gradient_color }} {{ bg_grad_pct }}%, transparent)
      );
    {% endif %}
  }

  /* Section inner — width control */
  #shopify-section-{{ section_id }} .lab_hero_finder__inner {
    position: relative;
    width: 100%;
    max-width: {% case s.container_width %}{% when 'full' %}100%{% when 'narrow' %}var(--lab-container-narrow){% when 'wide' %}var(--lab-container-wide){% else %}var(--lab-container-boxed){% endcase %};
    margin-inline: auto;
    padding-inline: {% if s.container_width == 'full' %}0{% else %}var(--lab-gutter-mobile){% endif %};
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section_id }} .lab_hero_finder__inner {
      padding-inline: {% if s.container_width == 'full' %}0{% else %}var(--lab-gutter-tablet){% endif %};
    }
  }

  @media screen and (min-width: 990px) {
    #shopify-section-{{ section_id }} .lab_hero_finder__inner {
      padding-inline: {% if s.container_width == 'full' %}0{% else %}var(--lab-gutter-desktop){% endif %};
    }
  }

  {% if s.spacing_size == 'custom' %}
    #shopify-section-{{ section_id }} .lab_hero_finder {
      margin-top: {{ s.spacing_top_custom }}px;
      margin-bottom: {{ s.spacing_bottom_custom }}px;
    }
  {% endif %}

  /* Slider */
  #shopify-section-{{ section_id }} .lab_hero_finder__slider {
    position: relative;
    overflow: hidden;
    width: 100%;
    height: {{ s.slider_height_mobile }}px;
    {% if s.container_width != 'full' %}
      border-radius: clamp(0px, 1vw, 12px);
    {% endif %}
  }

  #shopify-section-{{ section_id }} .lab_hero_finder__slider:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 4px;
  }

  /* Track */
  #shopify-section-{{ section_id }} .lab_hero_finder__track {
    display: flex;
    height: 100%;
    width: 100%;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  #shopify-section-{{ section_id }} .lab_hero_finder--transition-fade .lab_hero_finder__track {
    transition: none;
    transform: none !important;
  }

  /* Slide */
  #shopify-section-{{ section_id }} .lab_hero_finder__slide {
    position: relative;
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  #shopify-section-{{ section_id }} .lab_hero_finder--transition-fade .lab_hero_finder__slide {
    position: absolute;
    inset: 0;
    flex: none;
    opacity: 0;
    transition: opacity 0.6s ease;
    z-index: 1;
  }

  #shopify-section-{{ section_id }} .lab_hero_finder--transition-fade .lab_hero_finder__slide[aria-current="true"] {
    opacity: 1;
    z-index: 2;
  }

  /* Slide media */
  #shopify-section-{{ section_id }} .lab_hero_finder__slide-media {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  #shopify-section-{{ section_id }} .lab_hero_finder__slide-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section_id }} .lab_hero_finder__slide-image--placeholder {
    background: linear-gradient(135deg, color-mix(in srgb, var(--color-foreground) 12%, var(--color-background)), color-mix(in srgb, var(--color-foreground) 22%, var(--color-background)));
  }

  #shopify-section-{{ section_id }} .lab_hero_finder__slide-image--desktop { display: none; }
  #shopify-section-{{ section_id }} .lab_hero_finder__slide-image--mobile { display: block; }

  /* Slide overlay */
  #shopify-section-{{ section_id }} .lab_hero_finder__slide-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
  }

  #shopify-section-{{ section_id }} .lab_hero_finder__slide-overlay--solid {
    background-color: color-mix(in srgb, var(--lab-slide-overlay-color) calc(var(--lab-slide-overlay-opacity) * 100%), transparent);
  }

  #shopify-section-{{ section_id }} .lab_hero_finder__slide-overlay--gradient-bottom {
    background: linear-gradient(to top, color-mix(in srgb, var(--lab-slide-overlay-color) calc(var(--lab-slide-overlay-opacity) * 100%), transparent), transparent 80%);
  }

  #shopify-section-{{ section_id }} .lab_hero_finder__slide-overlay--gradient-radial {
    background: radial-gradient(circle at center, transparent 30%, color-mix(in srgb, var(--lab-slide-overlay-color) calc(var(--lab-slide-overlay-opacity) * 100%), transparent) 100%);
  }

  /* Slide content */
  #shopify-section-{{ section_id }} .lab_hero_finder__slide-content {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(1rem, 4vw, 3rem);
    pointer-events: none;
  }

  #shopify-section-{{ section_id }} .lab_hero_finder__slide-heading {
    margin: 0 0 0.5rem;
    max-width: {{ s.slide_content_max_width }}px;
    font-size: {{ s.slide_heading_size_mobile }}px;
    font-weight: {{ s.slide_heading_weight }};
    text-transform: {{ s.slide_heading_transform }};
    text-align: {{ s.slide_content_align }};
    letter-spacing: calc({{ s.slide_heading_letter_spacing }} / 100 * 1em);
    line-height: calc({{ s.slide_heading_line_height }} / 10);
    {% if s.slide_heading_color != blank %}
      color: color-mix(in srgb, {{ s.slide_heading_color }} {{ s.slide_heading_color_opacity }}%, transparent);
    {% else %}
      color: #ffffff;
    {% endif %}
    pointer-events: auto;
  }

  #shopify-section-{{ section_id }} .lab_hero_finder__slide-subheading {
    margin: 0;
    max-width: {{ s.slide_content_max_width }}px;
    font-size: {{ s.slide_subheading_size_mobile }}px;
    font-weight: {{ s.slide_subheading_weight }};
    text-align: {{ s.slide_content_align }};
    {% if s.slide_subheading_color != blank %}
      color: color-mix(in srgb, {{ s.slide_subheading_color }} {{ s.slide_subheading_color_opacity }}%, transparent);
    {% else %}
      color: color-mix(in srgb, #ffffff 90%, transparent);
    {% endif %}
    pointer-events: auto;
  }

  #shopify-section-{{ section_id }} .lab_hero_finder--align-left .lab_hero_finder__slide-content {
    align-items: flex-start;
  }
  #shopify-section-{{ section_id }} .lab_hero_finder--align-center .lab_hero_finder__slide-content {
    align-items: center;
  }
  #shopify-section-{{ section_id }} .lab_hero_finder--align-right .lab_hero_finder__slide-content {
    align-items: flex-end;
  }

  /* Arrows */
  #shopify-section-{{ section_id }} .lab_hero_finder__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 20;
    width: 44px;
    height: 44px;
    min-width: 44px;
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid color-mix(in srgb, #ffffff 35%, transparent);
    border-radius: 999px;
    background-color: color-mix(in srgb, #000000 30%, transparent);
    color: #ffffff;
    cursor: pointer;
    transition: background-color 0.2s ease, transform 0.2s ease;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  #shopify-section-{{ section_id }} .lab_hero_finder__arrow:hover {
    background-color: color-mix(in srgb, #000000 55%, transparent);
  }

  #shopify-section-{{ section_id }} .lab_hero_finder__arrow:focus-visible {
    outline: 2px solid #ffffff;
    outline-offset: 2px;
  }

  #shopify-section-{{ section_id }} .lab_hero_finder__arrow--prev { left: 12px; }
  #shopify-section-{{ section_id }} .lab_hero_finder__arrow--next { right: 12px; }

  /* Dots */
  #shopify-section-{{ section_id }} .lab_hero_finder__dots {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 20;
    display: flex;
    gap: 8px;
    padding: 6px 10px;
    border-radius: 999px;
    background-color: color-mix(in srgb, #000000 30%, transparent);
  }

  #shopify-section-{{ section_id }} .lab_hero_finder__dot {
    width: 10px;
    height: 10px;
    min-width: 44px;
    min-height: 44px;
    padding: 0;
    border: 0;
    border-radius: 999px;
    background: transparent;
    cursor: pointer;
    position: relative;
  }

  #shopify-section-{{ section_id }} .lab_hero_finder__dot::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background-color: color-mix(in srgb, #ffffff 50%, transparent);
    transition: background-color 0.2s ease, width 0.2s ease;
  }

  #shopify-section-{{ section_id }} .lab_hero_finder__dot[aria-selected="true"]::before {
    background-color: #ffffff;
    width: 22px;
    border-radius: 999px;
  }

  #shopify-section-{{ section_id }} .lab_hero_finder__dot:focus-visible {
    outline: 2px solid #ffffff;
    outline-offset: 2px;
  }

  /* Finder overlay container — mobile-first: stacked below slider */
  #shopify-section-{{ section_id }} .lab_hero_finder__overlay {
    position: relative;
    z-index: 5;
    width: 100%;
    max-width: calc(100% - 32px);
    margin: -32px auto 0;
  }

  /* Desktop: absolute overlay */
  @media (min-width: 750px) {
    #shopify-section-{{ section_id }} .lab_hero_finder__slider {
      height: {{ s.slider_height_desktop }}px;
    }

    #shopify-section-{{ section_id }} .lab_hero_finder__slide-image--desktop { display: block; }
    #shopify-section-{{ section_id }} .lab_hero_finder__slide-image--mobile { display: none; }

    #shopify-section-{{ section_id }} .lab_hero_finder__slide-heading {
      font-size: {{ s.slide_heading_size_desktop }}px;
    }
    #shopify-section-{{ section_id }} .lab_hero_finder__slide-subheading {
      font-size: {{ s.slide_subheading_size_desktop }}px;
    }

    #shopify-section-{{ section_id }} .lab_hero_finder__overlay {
      position: absolute;
      z-index: 10;
      width: auto;
      max-width: {{ s.finder_max_width }}px;
      margin: 0;
    }

    #shopify-section-{{ section_id }} .lab_hero_finder[data-lab-position="right"] .lab_hero_finder__overlay {
      top: 50%;
      right: {{ s.finder_edge_offset }}%;
      transform: translateY(-50%);
    }
    #shopify-section-{{ section_id }} .lab_hero_finder[data-lab-position="left"] .lab_hero_finder__overlay {
      top: 50%;
      left: {{ s.finder_edge_offset }}%;
      transform: translateY(-50%);
    }
    #shopify-section-{{ section_id }} .lab_hero_finder[data-lab-position="center-overlay"] .lab_hero_finder__overlay {
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
    }

    #shopify-section-{{ section_id }} .lab_hero_finder__arrow {
      width: 48px;
      height: 48px;
      min-width: 48px;
      min-height: 48px;
    }
    #shopify-section-{{ section_id }} .lab_hero_finder__arrow--prev { left: 24px; }
    #shopify-section-{{ section_id }} .lab_hero_finder__arrow--next { right: 24px; }

    #shopify-section-{{ section_id }} .lab_hero_finder__dots {
      bottom: 24px;
    }
  }

  /* === Finder card styling (rendered by snippet, styled here) === */

  #shopify-section-{{ section_id }} .lab_finder { display: block; width: 100%; }

  #shopify-section-{{ section_id }} .lab_finder__card {
    width: 100%;
    max-width: {{ s.finder_max_width }}px;
    margin-inline: auto;
    padding: {{ s.finder_card_padding_mobile }}px;
    border-radius: {{ s.finder_card_border_radius }}px;
    border: {{ s.finder_card_border_width }}px solid {% if s.finder_card_border_color != blank %}color-mix(in srgb, {{ s.finder_card_border_color }} {{ s.finder_card_border_color_opacity }}%, transparent){% else %}transparent{% endif %};
    box-shadow: {{ card_shadow_css }};
    {% if s.finder_card_bg_color != blank %}
      background-color: color-mix(in srgb, {{ s.finder_card_bg_color }} {{ s.finder_card_bg_color_opacity }}%, transparent);
    {% else %}
      background-color: var(--color-background);
    {% endif %}
    display: flex;
    flex-direction: column;
    gap: clamp(0.75rem, 2vw, 1.25rem);
  }

  @media (min-width: 750px) {
    #shopify-section-{{ section_id }} .lab_finder__card {
      padding: {{ s.finder_card_padding_desktop }}px;
    }
  }

  /* Finder heading */
  #shopify-section-{{ section_id }} .lab_finder__heading {
    margin: 0;
    font-size: {{ s.finder_heading_size_mobile }}px;
    font-weight: {{ s.finder_heading_weight }};
    text-transform: {{ s.finder_heading_transform }};
    text-align: {{ s.finder_heading_text_align }};
    letter-spacing: calc({{ s.finder_heading_letter_spacing }} / 100 * 1em);
    line-height: calc({{ s.finder_heading_line_height }} / 10);
    {% if s.finder_heading_color != blank %}
      color: color-mix(in srgb, {{ s.finder_heading_color }} {{ s.finder_heading_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground);
    {% endif %}
  }

  @media (min-width: 750px) {
    #shopify-section-{{ section_id }} .lab_finder__heading {
      font-size: {{ s.finder_heading_size_desktop }}px;
    }
  }

  /* Finder subheading */
  #shopify-section-{{ section_id }} .lab_finder__subheading {
    margin: 0;
    font-size: {{ s.finder_subheading_size_mobile }}px;
    font-weight: {{ s.finder_subheading_weight }};
    {% if s.finder_subheading_color != blank %}
      color: color-mix(in srgb, {{ s.finder_subheading_color }} {{ s.finder_subheading_color_opacity }}%, transparent);
    {% else %}
      color: color-mix(in srgb, var(--color-foreground) 75%, transparent);
    {% endif %}
  }

  #shopify-section-{{ section_id }} .lab_finder__subheading > * { margin: 0; }
  #shopify-section-{{ section_id }} .lab_finder__subheading > * + * { margin-top: 0.5em; }

  @media (min-width: 750px) {
    #shopify-section-{{ section_id }} .lab_finder__subheading {
      font-size: {{ s.finder_subheading_size_desktop }}px;
    }
  }

  /* Finder form */
  #shopify-section-{{ section_id }} .lab_finder__form {
    display: flex;
    flex-direction: column;
    gap: clamp(0.75rem, 2vw, 1rem);
    margin: 0;
  }

  /* Fields container */
  #shopify-section-{{ section_id }} .lab_finder__fields {
    display: flex;
    flex-direction: column;
    gap: {{ s.fields_gap_mobile }}px;
  }

  @media (min-width: 750px) {
    #shopify-section-{{ section_id }} .lab_finder__fields {
      gap: {{ s.fields_gap_desktop }}px;
    }
    #shopify-section-{{ section_id }} .lab_finder--fields-horizontal-row .lab_finder__fields {
      flex-direction: row;
      flex-wrap: wrap;
      align-items: flex-end;
    }
    #shopify-section-{{ section_id }} .lab_finder--fields-horizontal-row .lab_finder__field {
      flex: 1 1 140px;
      min-width: 0;
    }
  }

  /* Field */
  #shopify-section-{{ section_id }} .lab_finder__field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    min-width: 0;
  }

  #shopify-section-{{ section_id }} .lab_finder__label {
    font-size: {{ s.finder_label_size }}px;
    font-weight: {{ s.finder_label_weight }};
    text-transform: {{ s.finder_label_transform }};
    letter-spacing: 0.02em;
    {% if s.finder_label_color != blank %}
      color: color-mix(in srgb, {{ s.finder_label_color }} {{ s.finder_label_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground);
    {% endif %}
  }

  #shopify-section-{{ section_id }} .lab_finder__select-wrap {
    position: relative;
    display: block;
  }

  #shopify-section-{{ section_id }} .lab_finder__select {
    appearance: none;
    -webkit-appearance: none;
    -moz-appearance: none;
    width: 100%;
    min-height: 44px;
    padding: {{ s.finder_field_padding_y }}px {{ s.finder_field_padding_x | plus: 32 }}px {{ s.finder_field_padding_y }}px {{ s.finder_field_padding_x }}px;
    border: {{ s.finder_field_border_width }}px solid {% if s.finder_field_border_color != blank %}color-mix(in srgb, {{ s.finder_field_border_color }} {{ s.finder_field_border_color_opacity }}%, transparent){% else %}color-mix(in srgb, var(--color-foreground) 22%, transparent){% endif %};
    border-radius: {{ s.finder_field_border_radius }}px;
    font-family: inherit;
    font-size: 1rem;
    line-height: 1.3;
    cursor: pointer;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
    {% if s.finder_field_bg_color != blank %}
      background-color: color-mix(in srgb, {{ s.finder_field_bg_color }} {{ s.finder_field_bg_color_opacity }}%, transparent);
    {% else %}
      background-color: var(--color-background);
    {% endif %}
    {% if s.finder_field_text_color != blank %}
      color: color-mix(in srgb, {{ s.finder_field_text_color }} {{ s.finder_field_text_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground);
    {% endif %}
  }

  #shopify-section-{{ section_id }} .lab_finder__select:disabled {
    cursor: not-allowed;
    opacity: 0.55;
  }

  #shopify-section-{{ section_id }} .lab_finder__select:focus,
  #shopify-section-{{ section_id }} .lab_finder__select:focus-visible {
    outline: none;
    border-color: {% if s.finder_field_focus_color != blank %}color-mix(in srgb, {{ s.finder_field_focus_color }} {{ s.finder_field_focus_color_opacity }}%, transparent){% else %}var(--color-foreground){% endif %};
    box-shadow: 0 0 0 3px {% if s.finder_field_focus_color != blank %}color-mix(in srgb, {{ s.finder_field_focus_color }} 25%, transparent){% else %}color-mix(in srgb, var(--color-foreground) 18%, transparent){% endif %};
  }

  #shopify-section-{{ section_id }} .lab_finder__chevron {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    width: 12px;
    height: 8px;
    pointer-events: none;
    color: currentColor;
    opacity: 0.6;
  }

  /* Submit button */
  #shopify-section-{{ section_id }} .lab_finder__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: {{ s.finder_cta_padding_y }}px {{ s.finder_cta_padding_x }}px;
    border-radius: {{ s.finder_cta_border_radius }}px;
    border: {{ s.finder_cta_border_width }}px solid {% if s.finder_cta_border_color != blank %}color-mix(in srgb, {{ s.finder_cta_border_color }} {{ s.finder_cta_border_color_opacity }}%, transparent){% else %}transparent{% endif %};
    font-family: inherit;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
    align-self: flex-start;
    {% if s.finder_cta_bg_color != blank %}
      background-color: color-mix(in srgb, {{ s.finder_cta_bg_color }} {{ s.finder_cta_bg_color_opacity }}%, transparent);
    {% else %}
      background-color: var(--color-button);
    {% endif %}
    {% if s.finder_cta_text_color != blank %}
      color: color-mix(in srgb, {{ s.finder_cta_text_color }} {{ s.finder_cta_text_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-button-text);
    {% endif %}
  }

  #shopify-section-{{ section_id }} .lab_finder--submit-full .lab_finder__submit {
    width: 100%;
    align-self: stretch;
  }

  /* Hover variants — class set by snippet from cta_hover_effect (unprefixed) */
  #shopify-section-{{ section_id }} .lab_finder--btn-hover-fill .lab_finder__submit:hover,
  #shopify-section-{{ section_id }} .lab_finder--btn-hover-darken .lab_finder__submit:hover,
  #shopify-section-{{ section_id }} .lab_finder--btn-hover-lift .lab_finder__submit:hover,
  #shopify-section-{{ section_id }} .lab_finder--btn-hover-glow .lab_finder__submit:hover {
    {% if s.finder_cta_hover_bg_color != blank %}
      background-color: color-mix(in srgb, {{ s.finder_cta_hover_bg_color }} {{ s.finder_cta_hover_bg_color_opacity }}%, transparent);
    {% endif %}
    {% if s.finder_cta_hover_text_color != blank %}
      color: color-mix(in srgb, {{ s.finder_cta_hover_text_color }} {{ s.finder_cta_hover_text_color_opacity }}%, transparent);
    {% endif %}
    {% if s.finder_cta_hover_border_color != blank %}
      border-color: color-mix(in srgb, {{ s.finder_cta_hover_border_color }} {{ s.finder_cta_hover_border_color_opacity }}%, transparent);
    {% endif %}
  }

  #shopify-section-{{ section_id }} .lab_finder--btn-hover-darken .lab_finder__submit:hover {
    filter: brightness(0.88);
  }
  #shopify-section-{{ section_id }} .lab_finder--btn-hover-lift .lab_finder__submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px color-mix(in srgb, var(--color-foreground) 18%, transparent);
  }
  #shopify-section-{{ section_id }} .lab_finder--btn-hover-glow .lab_finder__submit:hover {
    box-shadow: 0 0 24px {% if s.finder_cta_hover_bg_color != blank %}color-mix(in srgb, {{ s.finder_cta_hover_bg_color }} 60%, transparent){% else %}color-mix(in srgb, var(--color-foreground) 25%, transparent){% endif %};
  }
  #shopify-section-{{ section_id }} .lab_finder--btn-hover-outline .lab_finder__submit:hover {
    background-color: transparent;
    {% if s.finder_cta_hover_text_color != blank %}
      color: color-mix(in srgb, {{ s.finder_cta_hover_text_color }} {{ s.finder_cta_hover_text_color_opacity }}%, transparent);
    {% endif %}
    {% if s.finder_cta_hover_border_color != blank %}
      border-color: color-mix(in srgb, {{ s.finder_cta_hover_border_color }} {{ s.finder_cta_hover_border_color_opacity }}%, transparent);
    {% endif %}
  }

  #shopify-section-{{ section_id }} .lab_finder__submit:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 3px;
  }

  /* Entrance animation */
  {% if anim_enabled %}
    #shopify-section-{{ section_id }} .lab_hero_finder--animated .lab_hero_finder__overlay {
      opacity: 0;
      animation-duration: 0.6s;
      animation-delay: 0.2s;
      animation-fill-mode: forwards;
      animation-timing-function: ease-out;
    }
    #shopify-section-{{ section_id }} .lab_hero_finder--anim-fade .lab_hero_finder__overlay {
      animation-name: lab_hero_finder_fade_{{ section_id }};
    }
    #shopify-section-{{ section_id }} .lab_hero_finder--anim-slide-up .lab_hero_finder__overlay {
      animation-name: lab_hero_finder_slide_{{ section_id }};
    }
    @keyframes lab_hero_finder_fade_{{ section_id }} {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    @keyframes lab_hero_finder_slide_{{ section_id }} {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @media (min-width: 750px) {
      #shopify-section-{{ section_id }} .lab_hero_finder[data-lab-position="right"].lab_hero_finder--animated .lab_hero_finder__overlay,
      #shopify-section-{{ section_id }} .lab_hero_finder[data-lab-position="left"].lab_hero_finder--animated .lab_hero_finder__overlay {
        animation-name: lab_hero_finder_fade_{{ section_id }};
      }
    }
  {% endif %}

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section_id }} *,
    #shopify-section-{{ section_id }} *::before,
    #shopify-section-{{ section_id }} *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
      scroll-behavior: auto !important;
    }
  }

  {% if section.settings.hide_on_mobile %}
    @media (max-width: 749px) {
      #shopify-section-{{ section_id }} { display: none; }
    }
  {% endif %}
  {% if section.settings.hide_on_desktop %}
    @media (min-width: 750px) {
      #shopify-section-{{ section_id }} { display: none; }
    }
  {% endif %}

  {% if s.custom_css != blank %}
    #shopify-section-{{ section_id }} {
      {{ s.custom_css }}
    }
  {% endif %}
</style>

{%- comment -%} 4. JavaScript — slider {%- endcomment -%}
<script>
  (function () {
    var section = document.getElementById('lab-{{ section_id }}');
    if (!section) return;

    var slider = section.querySelector('[data-lab-slider]');
    var track = section.querySelector('[data-lab-slider-track]');
    var slides = section.querySelectorAll('[data-lab-slide-index]');
    var prevBtn = section.querySelector('[data-lab-slider-prev]');
    var nextBtn = section.querySelector('[data-lab-slider-next]');
    var dots = section.querySelectorAll('[data-lab-slider-dot]');

    if (!slider || !track || slides.length === 0) return;

    var slideCount = slides.length;
    var currentIndex = 0;
    var intervalId = null;
    var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var autoplayEnabled = section.dataset.labAutoplay === 'true' && !reduceMotion;
    var swipeEnabled = section.dataset.labSwipe === 'true';
    var speed = (parseFloat(section.dataset.labSpeed) || 5) * 1000;
    var isFade = section.classList.contains('lab_hero_finder--transition-fade');
    var isDesignMode = window.Shopify && window.Shopify.designMode;

    function applyTransform() {
      if (isFade) {
        track.style.transform = '';
        return;
      }
      track.style.transform = 'translateX(-' + (currentIndex * 100) + '%)';
    }

    function syncAria() {
      slides.forEach(function (slide, i) {
        if (i === currentIndex) {
          slide.setAttribute('aria-current', 'true');
          slide.setAttribute('aria-hidden', 'false');
          slide.removeAttribute('inert');
        } else {
          slide.removeAttribute('aria-current');
          slide.setAttribute('aria-hidden', 'true');
          if ('inert' in HTMLElement.prototype) {
            slide.setAttribute('inert', '');
          }
        }
      });
      dots.forEach(function (dot, i) {
        dot.setAttribute('aria-selected', i === currentIndex ? 'true' : 'false');
      });
    }

    function goTo(index) {
      currentIndex = ((index % slideCount) + slideCount) % slideCount;
      applyTransform();
      syncAria();
    }

    function nextSlide() { goTo(currentIndex + 1); }
    function prevSlide() { goTo(currentIndex - 1); }

    function startAutoplay() {
      stopAutoplay();
      if (!autoplayEnabled || isDesignMode || slideCount <= 1) return;
      intervalId = setInterval(nextSlide, speed);
    }

    function stopAutoplay() {
      if (intervalId) {
        clearInterval(intervalId);
        intervalId = null;
      }
    }

    if (prevBtn) prevBtn.addEventListener('click', function () { prevSlide(); stopAutoplay(); });
    if (nextBtn) nextBtn.addEventListener('click', function () { nextSlide(); stopAutoplay(); });

    dots.forEach(function (dot, i) {
      dot.addEventListener('click', function () { goTo(i); stopAutoplay(); });
    });

    function onKey(e) {
      if (e.key === 'ArrowLeft') { prevSlide(); stopAutoplay(); }
      else if (e.key === 'ArrowRight') { nextSlide(); stopAutoplay(); }
    }
    slider.addEventListener('keydown', onKey);

    var touchStartX = 0;
    var touchStartY = 0;
    function onTouchStart(e) {
      touchStartX = e.changedTouches[0].screenX;
      touchStartY = e.changedTouches[0].screenY;
    }
    function onTouchEnd(e) {
      var dx = e.changedTouches[0].screenX - touchStartX;
      var dy = e.changedTouches[0].screenY - touchStartY;
      if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy)) {
        if (dx > 0) prevSlide(); else nextSlide();
        stopAutoplay();
      }
    }
    if (swipeEnabled) {
      slider.addEventListener('touchstart', onTouchStart, { passive: true });
      slider.addEventListener('touchend', onTouchEnd, { passive: true });
    }

    function onMouseEnter() { stopAutoplay(); }
    function onMouseLeave() { startAutoplay(); }
    slider.addEventListener('mouseenter', onMouseEnter);
    slider.addEventListener('mouseleave', onMouseLeave);
    slider.addEventListener('focusin', onMouseEnter);
    slider.addEventListener('focusout', onMouseLeave);

    function onBlockSelect(e) {
      var blockId = e.detail && e.detail.blockId;
      if (!blockId) return;
      slides.forEach(function (slide, i) {
        if (slide.getAttribute('data-lab-slide-id') === blockId) {
          goTo(i);
        }
      });
    }
    if (isDesignMode) {
      document.addEventListener('shopify:block:select', onBlockSelect);
    }

    function cleanup(e) {
      if (e.target !== section) return;
      stopAutoplay();
      slider.removeEventListener('keydown', onKey);
      slider.removeEventListener('touchstart', onTouchStart);
      slider.removeEventListener('touchend', onTouchEnd);
      slider.removeEventListener('mouseenter', onMouseEnter);
      slider.removeEventListener('mouseleave', onMouseLeave);
      slider.removeEventListener('focusin', onMouseEnter);
      slider.removeEventListener('focusout', onMouseLeave);
      if (isDesignMode) document.removeEventListener('shopify:block:select', onBlockSelect);
      document.removeEventListener('shopify:section:unload', cleanup);
    }
    document.addEventListener('shopify:section:unload', cleanup);

    syncAria();
    applyTransform();
    startAutoplay();
  })();
</script>

{% schema %}
{
  "name": "🧪 Hero + Finder",
  "tag": "section",
  "class": "lab_section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    { "type": "header", "content": "Slider" },
    { "type": "checkbox", "id": "slider_autoplay", "label": "Auto-rotate slides", "default": true },
    { "type": "range", "id": "slider_speed", "label": "Slide duration", "min": 3, "max": 10, "step": 1, "unit": "s", "default": 5, "visible_if": "{{ section.settings.slider_autoplay }}" },
    {
      "type": "select",
      "id": "slider_transition",
      "label": "Transition",
