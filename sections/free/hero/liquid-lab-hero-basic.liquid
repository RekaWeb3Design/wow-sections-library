{%- comment -%} 1. Liquid assigns {%- endcomment -%}
{%- liquid
  assign s = section.settings
  assign layout_style = s.layout_style | default: 'stacked'
  assign content_box_alignment = s.content_box_alignment | default: 'middle-center'
  assign content_alignment = s.content_alignment | default: 'center'
-%}

{%- comment -%} 2. HTML structure {%- endcomment -%}
<section
  id="lab-{{ section.id }}"
  class="color-{{ s.color_scheme }} gradient lab_section lab_hero_basic lab_hero_basic--layout-{{ layout_style }} lab_section--spacing-{{ s.spacing_size }}{% if s.inner_spacing_y != 'custom' %} lab_section--inner-y-{{ s.inner_spacing_y }}{% endif %}{% if s.entrance_animation %} lab_hero_basic--anim-{{ s.entrance_type }}{% endif %}"
  aria-label="{{ s.heading | default: 'Hero' | escape }}"
  data-lab-spacing="{{ s.spacing_size }}"
>
  {%- if s.section_bg_image != blank -%}
    <div class="lab_hero_basic__bg-image" aria-hidden="true">
      {{ s.section_bg_image | image_url: width: 2000 | image_tag:
        loading: 'lazy',
        widths: '600, 1200, 2000',
        sizes: '100vw',
        alt: '' }}
      {%- if s.section_bg_overlay_color != blank -%}
        <div class="lab_hero_basic__bg-overlay" aria-hidden="true"></div>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="lab_container lab_container--{{ s.container_width }}{% if s.inner_spacing_x != 'custom' %} lab_container--inner-x-{{ s.inner_spacing_x }}{% endif %}">
    <div class="lab_hero_basic__layout">

      {%- if s.image != blank -%}
        <div class="lab_hero_basic__media">
          {% render 'lab-image',
              image: s.image,
              mobile_image: s.image_mobile,
              aspect_ratio: s.image_aspect_ratio,
              fit: s.image_fit,
              is_lcp: true,
              alt_text: s.heading
          %}
        </div>
      {%- endif -%}

      <div class="lab_hero_basic__content lab_hero_basic__content--box-{{ content_box_alignment }} lab_hero_basic__content--align-{{ content_alignment }}">
        {% render 'lab-heading',
            text: s.heading,
            subtext: s.subheading,
            level: 'h1',
            size_mobile: s.heading_size_mobile,
            size_desktop: s.heading_size_desktop,
            weight: s.heading_weight,
            transform: s.heading_transform,
            color_override: s.heading_color_override,
            color_opacity: s.heading_color_opacity,
            letter_spacing: s.heading_letter_spacing,
            line_height: s.heading_line_height,
            subtext_size_mobile: s.subheading_size_mobile,
            subtext_size_desktop: s.subheading_size_desktop,
            subtext_weight: s.subheading_weight,
            subtext_color_override: s.subheading_color_override,
            unique_id: section.id
        %}

        {%- if s.button_label != blank -%}
          <div class="lab_hero_basic__cta">
            {% render 'lab-button',
                label: s.button_label,
                url: s.button_url,
                style: s.button_style,
                size: s.button_size,
                full_width: s.button_full_width,
                hover_effect: s.button_hover_effect,
                border_radius: s.button_border_radius,
                use_color_override: s.button_colors_override_enabled,
                bg_color_override: s.button_bg_color_override,
                bg_color_opacity: s.button_bg_color_opacity,
                text_color_override: s.button_text_color_override,
                border_color_override: s.button_border_color_override,
                border_width: s.button_border_width,
                unique_id: section.id
            %}
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{%- comment -%} 3. CSS — section-specific layout only (typography/buttons/images own their own CSS in the snippets) {%- endcomment -%}
<style>
  {%- if s.spacing_size == 'custom' -%}
    #shopify-section-{{ section.id }} .lab_section {
      margin-top: {{ s.spacing_top_custom }}px;
      margin-bottom: {{ s.spacing_bottom_custom }}px;
    }
  {%- endif -%}

  {%- if s.inner_spacing_y == 'custom' -%}
    #shopify-section-{{ section.id }} .lab_section {
      padding-top: {{ s.inner_spacing_y_top_custom }}px;
      padding-bottom: {{ s.inner_spacing_y_bottom_custom }}px;
    }
  {%- endif -%}

  {%- if s.inner_spacing_x == 'custom' -%}
    #shopify-section-{{ section.id }} .lab_container {
      padding-inline: {% if s.container_width == 'full' %}{{ s.inner_spacing_x_custom }}px{% else %}calc(var(--lab-gutter-mobile) + {{ s.inner_spacing_x_custom }}px){% endif %};
    }
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} .lab_container {
        padding-inline: {% if s.container_width == 'full' %}{{ s.inner_spacing_x_custom }}px{% else %}calc(var(--lab-gutter-tablet) + {{ s.inner_spacing_x_custom }}px){% endif %};
      }
    }
    @media screen and (min-width: 990px) {
      #shopify-section-{{ section.id }} .lab_container {
        padding-inline: {% if s.container_width == 'full' %}{{ s.inner_spacing_x_custom }}px{% else %}calc(var(--lab-gutter-desktop) + {{ s.inner_spacing_x_custom }}px){% endif %};
      }
    }
  {%- endif -%}

  /* Section background — color override and/or image */
  {%- if s.section_bg_color_override_enabled and s.section_bg_color_override != blank -%}
    #shopify-section-{{ section.id }} .lab_hero_basic {
      background: color-mix(in srgb, {{ s.section_bg_color_override }} {{ s.section_bg_color_opacity }}%, transparent);
    }
  {%- endif -%}

  {%- if s.section_bg_image != blank -%}
    #shopify-section-{{ section.id }} .lab_hero_basic {
      position: relative;
      isolation: isolate;
    }
    #shopify-section-{{ section.id }} .lab_hero_basic__bg-image {
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      overflow: hidden;
    }
    #shopify-section-{{ section.id }} .lab_hero_basic__bg-image img {
      width: 100%;
      height: 100%;
      object-fit: {{ s.section_bg_image_size }};
      object-position: {{ s.section_bg_image_position }};
      opacity: {{ s.section_bg_image_opacity | divided_by: 100.0 }};
      display: block;
    }
    {%- if s.section_bg_overlay_color != blank -%}
      #shopify-section-{{ section.id }} .lab_hero_basic__bg-overlay {
        position: absolute;
        inset: 0;
        background-color: {{ s.section_bg_overlay_color }};
        opacity: {{ s.section_bg_overlay_opacity | divided_by: 100.0 }};
        pointer-events: none;
      }
    {%- endif -%}
    #shopify-section-{{ section.id }} .lab_hero_basic > .lab_container {
      position: relative;
      z-index: 1;
    }
  {%- endif -%}

  /* === Layout grid ===
     Stacked / image-left / image-right share the grid model.
     Background layout overlays content on the image (no grid columns). */
  #shopify-section-{{ section.id }} .lab_hero_basic__layout {
    display: grid;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
  }

  #shopify-section-{{ section.id }} .lab_hero_basic--layout-stacked .lab_hero_basic__layout {
    grid-template-columns: 1fr;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .lab_hero_basic--layout-image-left .lab_hero_basic__layout,
    #shopify-section-{{ section.id }} .lab_hero_basic--layout-image-right .lab_hero_basic__layout {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    }
    #shopify-section-{{ section.id }} .lab_hero_basic--layout-image-right .lab_hero_basic__media {
      order: 2;
    }
  }

  /* Background layout — image fills the section, content overlays it */
  #shopify-section-{{ section.id }} .lab_hero_basic--layout-background .lab_hero_basic__layout {
    grid-template-columns: 1fr;
    grid-template-rows: minmax(320px, 60vh);
    position: relative;
  }
  #shopify-section-{{ section.id }} .lab_hero_basic--layout-background .lab_hero_basic__media,
  #shopify-section-{{ section.id }} .lab_hero_basic--layout-background .lab_hero_basic__content {
    grid-column: 1 / -1;
    grid-row: 1 / -1;
  }
  #shopify-section-{{ section.id }} .lab_hero_basic--layout-background .lab_hero_basic__media {
    z-index: 0;
    height: 100%;
  }
  #shopify-section-{{ section.id }} .lab_hero_basic--layout-background .lab_hero_basic__media .lab_image,
  #shopify-section-{{ section.id }} .lab_hero_basic--layout-background .lab_hero_basic__media .lab_image__img {
    height: 100%;
  }
  #shopify-section-{{ section.id }} .lab_hero_basic--layout-background .lab_hero_basic__content {
    z-index: 1;
    padding: clamp(1.5rem, 4vw, 3rem);
  }

  /* === Content wrapper ===
     Constrains width and applies position-derived alignment. */
  #shopify-section-{{ section.id }} .lab_hero_basic__content {
    width: 100%;
    max-width: {{ s.content_max_width }}px;
    display: flex;
    flex-direction: column;
    gap: clamp(0.75rem, 2vw, 1.5rem);
  }

  /* === Content box alignment ===
     3×3 grid placement of the content WRAPPER within its layout cell.
     align-self drives vertical position; justify-self drives horizontal.
     Text and button alignment INSIDE the wrapper is independent — see
     content_alignment rules below. */
  #shopify-section-{{ section.id }} .lab_hero_basic__content--box-top-left      { align-self: start;  justify-self: start;  }
  #shopify-section-{{ section.id }} .lab_hero_basic__content--box-top-center    { align-self: start;  justify-self: center; }
  #shopify-section-{{ section.id }} .lab_hero_basic__content--box-top-right     { align-self: start;  justify-self: end;    }
  #shopify-section-{{ section.id }} .lab_hero_basic__content--box-middle-left   { align-self: center; justify-self: start;  }
  #shopify-section-{{ section.id }} .lab_hero_basic__content--box-middle-center { align-self: center; justify-self: center; }
  #shopify-section-{{ section.id }} .lab_hero_basic__content--box-middle-right  { align-self: center; justify-self: end;    }
  #shopify-section-{{ section.id }} .lab_hero_basic__content--box-bottom-left   { align-self: end;    justify-self: start;  }
  #shopify-section-{{ section.id }} .lab_hero_basic__content--box-bottom-center { align-self: end;    justify-self: center; }
  #shopify-section-{{ section.id }} .lab_hero_basic__content--box-bottom-right  { align-self: end;    justify-self: end;    }

  /* === Content alignment ===
     One direction (left/center/right) applied to heading + subheading + button
     together. text-align drives the heading and subheading; align-items drives
     the CTA wrapper's flex placement; the lab-heading subtext is also forced
     so a parent text-align can't be lost across nested block elements. */
  #shopify-section-{{ section.id }} .lab_hero_basic__content--align-left {
    text-align: left;
    align-items: flex-start;
  }
  #shopify-section-{{ section.id }} .lab_hero_basic__content--align-left .lab_heading__text,
  #shopify-section-{{ section.id }} .lab_hero_basic__content--align-left .lab_heading__subtext {
    text-align: left;
  }
  #shopify-section-{{ section.id }} .lab_hero_basic__content--align-left .lab_hero_basic__cta {
    align-self: flex-start;
  }

  #shopify-section-{{ section.id }} .lab_hero_basic__content--align-center {
    text-align: center;
    align-items: center;
  }
  #shopify-section-{{ section.id }} .lab_hero_basic__content--align-center .lab_heading__text,
  #shopify-section-{{ section.id }} .lab_hero_basic__content--align-center .lab_heading__subtext {
    text-align: center;
  }
  #shopify-section-{{ section.id }} .lab_hero_basic__content--align-center .lab_hero_basic__cta {
    align-self: center;
  }

  #shopify-section-{{ section.id }} .lab_hero_basic__content--align-right {
    text-align: right;
    align-items: flex-end;
  }
  #shopify-section-{{ section.id }} .lab_hero_basic__content--align-right .lab_heading__text,
  #shopify-section-{{ section.id }} .lab_hero_basic__content--align-right .lab_heading__subtext {
    text-align: right;
  }
  #shopify-section-{{ section.id }} .lab_hero_basic__content--align-right .lab_hero_basic__cta {
    align-self: flex-end;
  }

  /* When the button is full-width, the CTA wrapper must stretch — overrides
     the align-self set by content_alignment above. */
  #shopify-section-{{ section.id }} .lab_hero_basic__cta:has(.lab_button--full) {
    width: 100%;
    align-self: stretch;
  }

  /* Entrance animation */
  {%- if s.entrance_animation -%}
    @media (prefers-reduced-motion: no-preference) {
      #shopify-section-{{ section.id }} .lab_hero_basic__content {
        animation: lab_hero_basic_{{ s.entrance_type | replace: '-', '_' }}_{{ section.id }} 0.6s ease-out both;
      }
      @keyframes lab_hero_basic_fade_{{ section.id }} {
        from { opacity: 0; }
        to   { opacity: 1; }
      }
      @keyframes lab_hero_basic_slide_up_{{ section.id }} {
        from { opacity: 0; transform: translateY(24px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      @keyframes lab_hero_basic_slide_down_{{ section.id }} {
        from { opacity: 0; transform: translateY(-24px); }
        to   { opacity: 1; transform: translateY(0); }
      }
    }
  {%- endif -%}

  {%- if s.hide_on_mobile -%}
    @media screen and (max-width: 749px) {
      #shopify-section-{{ section.id }} { display: none; }
    }
  {%- endif -%}
  {%- if s.hide_on_desktop -%}
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} { display: none; }
    }
  {%- endif -%}

  {%- if s.custom_css != blank -%}
    #shopify-section-{{ section.id }} {
      {{ s.custom_css }}
    }
  {%- endif -%}
</style>

{% schema %}
{
  "name": "🧪 Hero — Basic",
  "tag": "section",
  "class": "lab_section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "header", "content": "Color scheme & background" },
    <<INCLUDE: color-scheme-selector>>,

    { "type": "header", "content": "Content & layout" },
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "image_picker", "id": "image_mobile", "label": "Mobile image (optional)" },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Image aspect ratio",
      "options": [
        { "value": "natural", "label": "Natural" },
        { "value": "21/9", "label": "21:9 (cinematic)" },
        { "value": "16/9", "label": "16:9 (widescreen)" },
        { "value": "4/3", "label": "4:3 (classic)" },
        { "value": "1/1", "label": "1:1 (square)" },
        { "value": "4/5", "label": "4:5 (portrait)" },
        { "value": "9/16", "label": "9:16 (mobile portrait)" }
      ],
      "default": "16/9"
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Image fit",
      "options": [
        { "value": "cover", "label": "Cover (fill frame, may crop)" },
        { "value": "contain", "label": "Contain (whole image visible)" }
      ],
      "default": "cover",
      "info": "How the image fills the aspect ratio frame."
    },
    {
      "type": "select",
      "id": "layout_style",
      "label": "Layout style",
      "options": [
        { "value": "stacked", "label": "Stacked (image above content)" },
        { "value": "image-left", "label": "Image left, content right" },
        { "value": "image-right", "label": "Content left, image right" },
        { "value": "background", "label": "Image as background, content overlay" }
      ],
      "default": "stacked"
    },
    {
      "type": "select",
      "id": "content_box_alignment",
      "label": "Content box alignment",
      "info": "Where the content wrapper is positioned within the section frame (most visible in 'background' layout).",
      "options": [
        { "value": "top-left", "label": "Top left" },
        { "value": "top-center", "label": "Top center" },
        { "value": "top-right", "label": "Top right" },
        { "value": "middle-left", "label": "Middle left" },
        { "value": "middle-center", "label": "Middle center" },
        { "value": "middle-right", "label": "Middle right" },
        { "value": "bottom-left", "label": "Bottom left" },
        { "value": "bottom-center", "label": "Bottom center" },
        { "value": "bottom-right", "label": "Bottom right" }
      ],
      "default": "middle-center"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment",
      "info": "Aligns the heading, subheading, and button together (left, center, or right).",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content max width",
      "min": 300,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "default": 600
    },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Welcome to our store" },
    { "type": "richtext", "id": "subheading", "label": "Subheading", "default": "<p>Discover what's new this season.</p>" },

    <<INCLUDE: typography-heading>>,
    <<INCLUDE: typography-subheading>>,

    { "type": "header", "content": "Button" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop now" },
    { "type": "url", "id": "button_url", "label": "Button link" },
    <<INCLUDE: button-styles>>,

    { "type": "header", "content": "Animation" },
    { "type": "checkbox", "id": "entrance_animation", "label": "Enable entrance animation", "default": false },
    {
      "type": "select",
      "id": "entrance_type",
      "label": "Entrance animation type",
      "options": [
        { "value": "fade", "label": "Fade in" },
        { "value": "slide-up", "label": "Slide up" },
        { "value": "slide-down", "label": "Slide down" }
      ],
      "default": "fade",
      "visible_if": "{{ section.settings.entrance_animation }}"
    },

    <<INCLUDE: universal>>
  ],
  "presets": [
    {
      "name": "🧪 Hero — Basic",
      "category": "Liquid Lab",
      "settings": {
        "color_scheme": "scheme-1"
      }
    }
  ]
}
{% endschema %}
