{% comment %} 1. Assigns {% endcomment %}
{% liquid
  assign section_id = section.id
  assign animation_enabled = section.settings.animation_enabled
  assign animation_type = section.settings.animation_type
  assign animation_delay = section.settings.animation_delay
  assign icon_style = section.settings.icon_style
  assign show_divider = section.settings.show_divider
  assign accordion_max_width = section.settings.accordion_max_width
  assign bg_pct = section.settings.bg_opacity
  assign bg_grad_pct = section.settings.bg_gradient_color_opacity
%}

{% comment %} 2. HTML structure {% endcomment %}
<div class="color-{{ section.settings.color_scheme }} gradient">
  <section
    id="lab-{{ section_id }}"
    class="lab_faq_accordion lab_faq_accordion--align-{{ section.settings.content_alignment }} lab_faq_accordion--pos-{{ section.settings.content_position }} lab_faq_accordion--icon-{{ icon_style }}{% if show_divider %} lab_faq_accordion--has-divider{% endif %}{% if animation_enabled %} lab_faq_accordion--animated lab_faq_accordion--anim-{{ animation_type }}{% endif %} lab_section{% if section.settings.spacing_size != 'custom' %} lab_section--spacing-{{ section.settings.spacing_size }}{% endif %}{% if section.settings.inner_spacing_y != 'custom' %} lab_section--inner-y-{{ section.settings.inner_spacing_y }}{% endif %}"
    data-lab-spacing="{{ section.settings.spacing_size }}"
    data-lab-inner-y="{{ section.settings.inner_spacing_y }}"
    aria-label="{{ section.settings.heading | default: 'FAQ' | escape }}"
  >
    <div class="lab_container lab_container--{{ section.settings.container_width }}{% if section.settings.inner_spacing_x != 'custom' and section.settings.inner_spacing_x != 'none' %} lab_container--inner-x-{{ section.settings.inner_spacing_x }}{% endif %} lab_faq_accordion__inner">
      {% if section.settings.heading != blank or section.settings.subheading != blank %}
        <header class="lab_faq_accordion__header">
          {% if section.settings.heading != blank %}
            <h2 class="lab_faq_accordion__heading">{{ section.settings.heading | escape }}</h2>
          {% endif %}
          {% if section.settings.subheading != blank %}
            <p class="lab_faq_accordion__subheading">{{ section.settings.subheading | escape | newline_to_br }}</p>
          {% endif %}
        </header>
      {% endif %}

      {% if section.blocks.size > 0 %}
        <ul class="lab_faq_accordion__list" role="list">
          {% for block in section.blocks %}
            {% if block.type == 'faq_item' %}
              <li role="listitem" class="lab_faq_accordion__item" {{ block.shopify_attributes }}>
                <details
                  class="lab_faq_accordion__details"
                  {% if block.settings.open_by_default %}open{% endif %}
                  {% if animation_enabled %}style="animation-delay: {{ animation_delay | times: forloop.index0 }}ms;"{% endif %}
                >
                  <summary class="lab_faq_accordion__summary">
                    <span class="lab_faq_accordion__question">{{ block.settings.question | escape }}</span>
                    {% if icon_style != 'none' %}
                      <span class="lab_faq_accordion__icon" aria-hidden="true"></span>
                    {% endif %}
                  </summary>
                  <div class="lab_faq_accordion__answer-wrap">
                    <div class="lab_faq_accordion__answer-inner">
                      <div class="lab_faq_accordion__answer">{{ block.settings.answer | escape | newline_to_br }}</div>
                    </div>
                  </div>
                </details>
              </li>
            {% endif %}
          {% endfor %}
        </ul>
      {% endif %}
    </div>
  </section>
</div>

{% comment %} 3. CSS — section scoped {% endcomment %}
<style>
  #shopify-section-{{ section.id }} .lab_faq_accordion {
    {% if section.settings.bg_color != blank %}
      background-color: color-mix(in srgb, {{ section.settings.bg_color }} {{ bg_pct }}%, transparent);
    {% else %}
      background-color: var(--color-background);
    {% endif %}
    {% if section.settings.bg_gradient and section.settings.bg_color != blank and section.settings.bg_gradient_color != blank %}
      background-image: linear-gradient(
        {{ section.settings.bg_gradient_direction }},
        color-mix(in srgb, {{ section.settings.bg_color }} {{ bg_pct }}%, transparent),
        color-mix(in srgb, {{ section.settings.bg_gradient_color }} {{ bg_grad_pct }}%, transparent)
      );
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_faq_accordion__inner {
    display: flex;
    flex-direction: column;
    align-items: {% if section.settings.content_position == 'top-left' or section.settings.content_position == 'center-left' or section.settings.content_position == 'bottom-left' %}flex-start{% elsif section.settings.content_position == 'top-right' or section.settings.content_position == 'center-right' or section.settings.content_position == 'bottom-right' %}flex-end{% else %}center{% endif %};
  }

  {% if section.settings.spacing_size == 'custom' %}
    #shopify-section-{{ section.id }} .lab_faq_accordion {
      margin-top: {{ section.settings.spacing_top_custom }}px;
      margin-bottom: {{ section.settings.spacing_bottom_custom }}px;
    }
  {% endif %}

  {% if section.settings.inner_spacing_y == 'custom' %}
    #shopify-section-{{ section.id }} .lab_faq_accordion {
      padding-top: {{ section.settings.inner_spacing_y_top_custom }}px;
      padding-bottom: {{ section.settings.inner_spacing_y_bottom_custom }}px;
    }
  {% endif %}

  {% if section.settings.inner_spacing_x == 'custom' %}
    #shopify-section-{{ section.id }} .lab_faq_accordion__inner {
      padding-inline: {% if section.settings.container_width == 'full' %}{{ section.settings.inner_spacing_x_custom }}px{% else %}calc(var(--lab-gutter-mobile) + {{ section.settings.inner_spacing_x_custom }}px){% endif %};
    }
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} .lab_faq_accordion__inner {
        padding-inline: {% if section.settings.container_width == 'full' %}{{ section.settings.inner_spacing_x_custom }}px{% else %}calc(var(--lab-gutter-tablet) + {{ section.settings.inner_spacing_x_custom }}px){% endif %};
      }
    }
    @media screen and (min-width: 990px) {
      #shopify-section-{{ section.id }} .lab_faq_accordion__inner {
        padding-inline: {% if section.settings.container_width == 'full' %}{{ section.settings.inner_spacing_x_custom }}px{% else %}calc(var(--lab-gutter-desktop) + {{ section.settings.inner_spacing_x_custom }}px){% endif %};
      }
    }
  {% endif %}

  #shopify-section-{{ section.id }} .lab_faq_accordion__header {
    width: 100%;
    max-width: {{ section.settings.content_max_width }}px;
    margin-bottom: clamp(1.5rem, 4vw, 3rem);
    text-align: {% if section.settings.content_alignment == 'left' %}left{% elsif section.settings.content_alignment == 'right' %}right{% else %}center{% endif %};
  }

  #shopify-section-{{ section.id }} .lab_faq_accordion__heading {
    margin: 0 0 clamp(0.5rem, 1.5vw, 1rem);
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
    text-transform: {{ section.settings.heading_transform }};
    text-align: {{ section.settings.heading_text_align }};
    letter-spacing: calc({{ section.settings.heading_letter_spacing }} / 100 * 1em);
    line-height: calc({{ section.settings.heading_line_height }} / 10);
    {% if section.settings.heading_color != blank %}
      color: color-mix(in srgb, {{ section.settings.heading_color }} {{ section.settings.heading_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_faq_accordion__subheading {
    margin: 0;
    font-size: {{ section.settings.subheading_size }}px;
    font-weight: {{ section.settings.subheading_weight }};
    text-transform: {{ section.settings.subheading_transform }};
    text-align: {{ section.settings.subheading_text_align }};
    letter-spacing: calc({{ section.settings.subheading_letter_spacing }} / 100 * 1em);
    line-height: calc({{ section.settings.subheading_line_height }} / 10);
    {% if section.settings.subheading_color != blank %}
      color: color-mix(in srgb, {{ section.settings.subheading_color }} {{ section.settings.subheading_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground-75, var(--color-foreground));
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_faq_accordion__list {
    list-style: none;
    margin: 0;
    padding: 0;
    width: 100%;
    max-width: {{ accordion_max_width }}px;
    display: grid;
    gap: {{ section.settings.items_gap }}px;
    align-items: {{ section.settings.items_align }};
  }

  #shopify-section-{{ section.id }} .lab_faq_accordion__item {
    margin: 0;
  }

  #shopify-section-{{ section.id }} .lab_faq_accordion--has-divider .lab_faq_accordion__item {
    border-bottom: {{ section.settings.divider_width }}px {{ section.settings.divider_style }} {% if section.settings.divider_color != blank %}color-mix(in srgb, {{ section.settings.divider_color }} {{ section.settings.divider_color_opacity }}%, transparent){% else %}color-mix(in srgb, var(--color-foreground) {{ section.settings.divider_color_opacity }}%, transparent){% endif %};
    padding-bottom: {{ section.settings.items_gap }}px;
  }

  #shopify-section-{{ section.id }} .lab_faq_accordion--has-divider .lab_faq_accordion__item:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  #shopify-section-{{ section.id }} .lab_faq_accordion__details {
    width: 100%;
  }

  #shopify-section-{{ section.id }} .lab_faq_accordion__summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: clamp(0.75rem, 2vw, 1.5rem);
    min-height: 44px;
    padding: clamp(0.75rem, 2vw, 1.25rem) 0;
    user-select: none;
  }

  #shopify-section-{{ section.id }} .lab_faq_accordion__summary::-webkit-details-marker {
    display: none;
  }

  #shopify-section-{{ section.id }} .lab_faq_accordion__summary:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 4px;
    border-radius: 4px;
  }

  #shopify-section-{{ section.id }} .lab_faq_accordion__question {
    flex: 1 1 auto;
    font-size: {{ section.settings.question_size }}px;
    font-weight: {{ section.settings.question_weight }};
    text-transform: {{ section.settings.question_transform }};
    text-align: {{ section.settings.question_text_align }};
    letter-spacing: calc({{ section.settings.question_letter_spacing }} / 100 * 1em);
    line-height: calc({{ section.settings.question_line_height }} / 10);
    {% if section.settings.question_color != blank %}
      color: color-mix(in srgb, {{ section.settings.question_color }} {{ section.settings.question_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_faq_accordion__icon {
    flex: 0 0 auto;
    position: relative;
    width: 1.25rem;
    height: 1.25rem;
    transition: transform 0.3s ease;
  }

  /* Plus / minus icon — two crossed bars */
  #shopify-section-{{ section.id }} .lab_faq_accordion--icon-plus-minus .lab_faq_accordion__icon::before,
  #shopify-section-{{ section.id }} .lab_faq_accordion--icon-plus-minus .lab_faq_accordion__icon::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    background-color: currentColor;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
  #shopify-section-{{ section.id }} .lab_faq_accordion--icon-plus-minus .lab_faq_accordion__icon::before {
    width: 1rem;
    height: 2px;
    transform: translate(-50%, -50%);
  }
  #shopify-section-{{ section.id }} .lab_faq_accordion--icon-plus-minus .lab_faq_accordion__icon::after {
    width: 2px;
    height: 1rem;
    transform: translate(-50%, -50%);
  }
  #shopify-section-{{ section.id }} .lab_faq_accordion--icon-plus-minus .lab_faq_accordion__details[open] .lab_faq_accordion__icon::after {
    transform: translate(-50%, -50%) rotate(90deg);
    opacity: 0;
  }

  /* Arrow icon — chevron right that rotates 90deg on open */
  #shopify-section-{{ section.id }} .lab_faq_accordion--icon-arrow .lab_faq_accordion__icon::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0.55rem;
    height: 0.55rem;
    border-right: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
    transform: translate(-65%, -65%) rotate(-45deg);
    transition: transform 0.3s ease;
  }
  #shopify-section-{{ section.id }} .lab_faq_accordion--icon-arrow .lab_faq_accordion__details[open] .lab_faq_accordion__icon::before {
    transform: translate(-50%, -50%) rotate(45deg);
  }

  /* Smooth height animation using the grid-rows trick */
  #shopify-section-{{ section.id }} .lab_faq_accordion__answer-wrap {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease;
  }
  #shopify-section-{{ section.id }} .lab_faq_accordion__details[open] .lab_faq_accordion__answer-wrap {
    grid-template-rows: 1fr;
  }
  #shopify-section-{{ section.id }} .lab_faq_accordion__answer-inner {
    overflow: hidden;
    min-height: 0;
  }

  #shopify-section-{{ section.id }} .lab_faq_accordion__answer {
    padding: 0 0 clamp(0.75rem, 2vw, 1.25rem);
    font-size: {{ section.settings.answer_size }}px;
    font-weight: {{ section.settings.answer_weight }};
    text-transform: {{ section.settings.answer_transform }};
    text-align: {{ section.settings.answer_text_align }};
    letter-spacing: calc({{ section.settings.answer_letter_spacing }} / 100 * 1em);
    line-height: calc({{ section.settings.answer_line_height }} / 10);
    {% if section.settings.answer_color != blank %}
      color: color-mix(in srgb, {{ section.settings.answer_color }} {{ section.settings.answer_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground-75, var(--color-foreground));
    {% endif %}
  }

  /* Animation — fade / slide / zoom on the details element */
  {% if animation_enabled %}
    #shopify-section-{{ section.id }} .lab_faq_accordion--animated .lab_faq_accordion__details {
      opacity: 0;
      animation-duration: 0.5s;
      animation-fill-mode: forwards;
      animation-timing-function: ease-out;
    }
    #shopify-section-{{ section.id }} .lab_faq_accordion--anim-fade .lab_faq_accordion__details {
      animation-name: lab_faq_accordion_fade_{{ section.id }};
    }
    #shopify-section-{{ section.id }} .lab_faq_accordion--anim-slide .lab_faq_accordion__details {
      animation-name: lab_faq_accordion_slide_{{ section.id }};
    }
    #shopify-section-{{ section.id }} .lab_faq_accordion--anim-zoom .lab_faq_accordion__details {
      animation-name: lab_faq_accordion_zoom_{{ section.id }};
    }
    @keyframes lab_faq_accordion_fade_{{ section.id }} {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    @keyframes lab_faq_accordion_slide_{{ section.id }} {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes lab_faq_accordion_zoom_{{ section.id }} {
      from { opacity: 0; transform: scale(0.96); }
      to { opacity: 1; transform: scale(1); }
    }
  {% endif %}

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .lab_faq_accordion__icon,
    #shopify-section-{{ section.id }} .lab_faq_accordion__icon::before,
    #shopify-section-{{ section.id }} .lab_faq_accordion__icon::after,
    #shopify-section-{{ section.id }} .lab_faq_accordion__answer-wrap,
    #shopify-section-{{ section.id }} .lab_faq_accordion__details {
      transition: none;
      animation: none;
    }
  }

  {% if section.settings.hide_on_mobile %}
    #shopify-section-{{ section.id }} { display: none; }
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} {
        display: {% if section.settings.hide_on_desktop %}none{% else %}revert{% endif %};
      }
    }
  {% elsif section.settings.hide_on_desktop %}
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} { display: none; }
    }
  {% endif %}

  {% if section.settings.custom_css != blank %}
    #shopify-section-{{ section.id }} {
      {{ section.settings.custom_css }}
    }
  {% endif %}
</style>

{% schema %}
{
  "name": "🧪 FAQ Accordion",
  "tag": "section",
  "class": "lab_section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently asked questions" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Everything you need to know before you buy. Can't find an answer? Get in touch." },

    { "type": "header", "content": "Typography" },
    { "type": "range", "id": "heading_size", "label": "Heading size", "min": 12, "max": 80, "step": 1, "unit": "px", "default": 40 },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading weight",
      "options": [
        { "value": "300", "label": "Thin" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "heading_transform",
      "label": "Heading text transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "heading_text_align",
      "label": "Heading text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
