{% comment %} 1. Assigns {% endcomment %}
{% liquid
  assign section_id = section.id
  assign image = section.settings.image
  assign image_position = section.settings.image_position
  assign image_width = section.settings.image_width
  assign mobile_layout = section.settings.mobile_layout
  assign vertical_alignment = section.settings.vertical_alignment
  assign animation_enabled = section.settings.animation_enabled
  assign animation_type = section.settings.animation_type
  assign animation_delay = section.settings.animation_delay
  assign bg_pct = section.settings.bg_opacity
  assign bg_grad_pct = section.settings.bg_gradient_color_opacity
  assign aspect_ratio = section.settings.image_aspect_ratio

  if section.index <= 2
    assign image_loading = 'eager'
    assign image_fetchpriority = 'high'
  else
    assign image_loading = 'lazy'
    assign image_fetchpriority = 'auto'
  endif
%}

{% comment %} 2. HTML structure {% endcomment %}
<div class="color-{{ section.settings.color_scheme }} gradient">
  <section
    id="lab-{{ section_id }}"
    class="lab_image_with_text lab_image_with_text--image-{{ image_position }} lab_image_with_text--width-{{ image_width }} lab_image_with_text--align-{{ section.settings.content_alignment }} lab_image_with_text--pos-{{ section.settings.content_position }} lab_image_with_text--valign-{{ vertical_alignment }} lab_image_with_text--mobile-{{ mobile_layout }} lab_image_with_text--section-{{ section.settings.section_width }} lab_image_with_text--cta-hover-{{ section.settings.cta_hover_effect }} lab_image_with_text--cta2-hover-{{ section.settings.secondary_cta_hover_effect }}{% if animation_enabled %} lab_image_with_text--animated lab_image_with_text--anim-{{ animation_type }}{% endif %} lab_section"
    aria-label="{{ section.settings.heading | default: 'Image with text' | escape }}"
  >
    <div class="lab_image_with_text__inner">
      <div class="lab_image_with_text__media">
        {% if image != blank %}
          <div class="lab_image_with_text__image-wrap">
            {{ image | image_url: width: 1600 | image_tag:
              alt: section.settings.image_alt | default: section.settings.heading,
              loading: image_loading,
              fetchpriority: image_fetchpriority,
              width: image.width,
              height: image.height,
              widths: '400, 800, 1200, 1600',
              sizes: '(min-width: 750px) 50vw, 100vw',
              class: 'lab_image_with_text__image'
            }}
            {% if section.settings.image_overlay_opacity > 0 %}
              <span class="lab_image_with_text__image-overlay" aria-hidden="true"></span>
            {% endif %}
          </div>
        {% else %}
          <div class="lab_image_with_text__image-wrap lab_image_with_text__image-wrap--placeholder" aria-hidden="true">
            {{ 'lifestyle-1' | placeholder_svg_tag: 'lab_image_with_text__image lab_image_with_text__image--placeholder' }}
          </div>
        {% endif %}
      </div>

      <div class="lab_image_with_text__content"
        {% if animation_enabled %}style="animation-delay: {{ animation_delay }}ms;"{% endif %}>
        {% if section.settings.badge_text != blank %}
          <span class="lab_image_with_text__badge">{{ section.settings.badge_text | escape }}</span>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="lab_image_with_text__heading">{{ section.settings.heading | escape }}</h2>
        {% endif %}

        {% if section.settings.subheading != blank %}
          <p class="lab_image_with_text__subheading">{{ section.settings.subheading | escape | newline_to_br }}</p>
        {% endif %}

        {% if section.settings.body_text != blank %}
          <div class="lab_image_with_text__body">{{ section.settings.body_text }}</div>
        {% endif %}

        {% if section.settings.cta_label != blank or section.settings.secondary_cta_label != blank %}
          <div class="lab_image_with_text__actions">
            {% if section.settings.cta_label != blank %}
              <a
                href="{{ section.settings.cta_url | default: '#' }}"
                class="lab_image_with_text__cta lab_image_with_text__cta--primary"
              >
                {{ section.settings.cta_label | escape }}
              </a>
            {% endif %}
            {% if section.settings.secondary_cta_label != blank %}
              <a
                href="{{ section.settings.secondary_cta_url | default: '#' }}"
                class="lab_image_with_text__cta lab_image_with_text__cta--secondary"
              >
                {{ section.settings.secondary_cta_label | escape }}
              </a>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>
  </section>
</div>

{% comment %} 3. CSS — section scoped {% endcomment %}
<style>
  #shopify-section-{{ section.id }} .lab_image_with_text {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    {% if section.settings.bg_color != blank %}
      background-color: color-mix(in srgb, {{ section.settings.bg_color }} {{ bg_pct }}%, transparent);
    {% else %}
      background-color: var(--color-background);
    {% endif %}
    {% if section.settings.bg_gradient and section.settings.bg_color != blank and section.settings.bg_gradient_color != blank %}
      background-image: linear-gradient(
        {{ section.settings.bg_gradient_direction }},
        color-mix(in srgb, {{ section.settings.bg_color }} {{ bg_pct }}%, transparent),
        color-mix(in srgb, {{ section.settings.bg_gradient_color }} {{ bg_grad_pct }}%, transparent)
      );
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_image_with_text__inner {
    width: 100%;
    max-width: {% if section.settings.section_width == 'full' %}100%{% elsif section.settings.section_width == 'narrow' %}960px{% else %}var(--page-width, 1200px){% endif %};
    margin-inline: auto;
    padding-inline: {% if section.settings.section_width == 'full' %}0{% else %}clamp(1rem, 4vw, 2rem){% endif %};
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ section.settings.items_gap }}px;
    align-items: {{ section.settings.items_align }};
  }

  #shopify-section-{{ section.id }} .lab_image_with_text__media {
    order: {% if mobile_layout == 'image-first' %}1{% else %}2{% endif %};
  }

  #shopify-section-{{ section.id }} .lab_image_with_text__content {
    order: {% if mobile_layout == 'image-first' %}2{% else %}1{% endif %};
    display: flex;
    flex-direction: column;
    gap: clamp(0.75rem, 1.5vw, 1.25rem);
    width: 100%;
    max-width: {{ section.settings.content_max_width }}px;
    margin-inline: {% if section.settings.content_alignment == 'left' %}0 auto 0 0{% elsif section.settings.content_alignment == 'right' %}0 0 0 auto{% else %}auto{% endif %};
    text-align: {% if section.settings.content_alignment == 'left' %}left{% elsif section.settings.content_alignment == 'right' %}right{% else %}center{% endif %};
  }

  #shopify-section-{{ section.id }} .lab_image_with_text__image-wrap {
    position: relative;
    overflow: hidden;
    border-radius: {{ section.settings.image_border_radius }}px;
    {% case aspect_ratio %}
      {% when '1-1' %}aspect-ratio: 1 / 1;
      {% when '4-3' %}aspect-ratio: 4 / 3;
      {% when '16-9' %}aspect-ratio: 16 / 9;
      {% when '3-2' %}aspect-ratio: 3 / 2;
      {% when '2-3' %}aspect-ratio: 2 / 3;
    {% endcase %}
  }

  #shopify-section-{{ section.id }} .lab_image_with_text__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.image_object_fit }};
    transition: transform 0.6s ease;
  }

  #shopify-section-{{ section.id }} .lab_image_with_text__image-wrap:hover .lab_image_with_text__image {
    transform: scale(1.03);
  }

  #shopify-section-{{ section.id }} .lab_image_with_text__image-wrap--placeholder {
    aspect-ratio: 4 / 3;
    background-color: color-mix(in srgb, var(--color-foreground) 6%, transparent);
  }

  #shopify-section-{{ section.id }} .lab_image_with_text__image--placeholder {
    width: 100%;
    height: 100%;
    object-fit: contain;
    color: color-mix(in srgb, var(--color-foreground) 25%, transparent);
  }

  #shopify-section-{{ section.id }} .lab_image_with_text__image-overlay {
    position: absolute;
    inset: 0;
    background-color: color-mix(in srgb, {% if section.settings.image_overlay_color != blank %}{{ section.settings.image_overlay_color }}{% else %}var(--color-foreground){% endif %} {{ section.settings.image_overlay_color_opacity }}%, transparent);
    opacity: calc({{ section.settings.image_overlay_opacity }} / 100);
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .lab_image_with_text__badge {
    align-self: {% if section.settings.content_alignment == 'left' %}flex-start{% elsif section.settings.content_alignment == 'right' %}flex-end{% else %}center{% endif %};
    display: inline-flex;
    align-items: center;
    padding: clamp(0.25rem, 0.5vw, 0.4rem) clamp(0.6rem, 1.2vw, 0.9rem);
    border-radius: 999px;
    font-size: {{ section.settings.badge_size }}px;
    font-weight: {{ section.settings.badge_weight }};
    text-transform: {{ section.settings.badge_transform }};
    text-align: {{ section.settings.badge_text_align }};
    letter-spacing: calc({{ section.settings.badge_letter_spacing }} / 100 * 1em);
    line-height: calc({{ section.settings.badge_line_height }} / 10);
    background-color: color-mix(in srgb, var(--color-foreground) 8%, transparent);
    {% if section.settings.badge_color != blank %}
      color: color-mix(in srgb, {{ section.settings.badge_color }} {{ section.settings.badge_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_image_with_text__heading {
    margin: 0;
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
    text-transform: {{ section.settings.heading_transform }};
    text-align: {{ section.settings.heading_text_align }};
    letter-spacing: calc({{ section.settings.heading_letter_spacing }} / 100 * 1em);
    line-height: calc({{ section.settings.heading_line_height }} / 10);
    {% if section.settings.heading_color != blank %}
      color: color-mix(in srgb, {{ section.settings.heading_color }} {{ section.settings.heading_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_image_with_text__subheading {
    margin: 0;
    font-size: {{ section.settings.subheading_size }}px;
    font-weight: {{ section.settings.subheading_weight }};
    text-transform: {{ section.settings.subheading_transform }};
    text-align: {{ section.settings.subheading_text_align }};
    letter-spacing: calc({{ section.settings.subheading_letter_spacing }} / 100 * 1em);
    line-height: calc({{ section.settings.subheading_line_height }} / 10);
    {% if section.settings.subheading_color != blank %}
      color: color-mix(in srgb, {{ section.settings.subheading_color }} {{ section.settings.subheading_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground-75, var(--color-foreground));
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_image_with_text__body {
    margin: 0;
    font-size: {{ section.settings.body_text_size }}px;
    font-weight: {{ section.settings.body_text_weight }};
    text-transform: {{ section.settings.body_text_transform }};
    text-align: {{ section.settings.body_text_text_align }};
    letter-spacing: calc({{ section.settings.body_text_letter_spacing }} / 100 * 1em);
    line-height: calc({{ section.settings.body_text_line_height }} / 10);
    {% if section.settings.body_text_color != blank %}
      color: color-mix(in srgb, {{ section.settings.body_text_color }} {{ section.settings.body_text_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground-75, var(--color-foreground));
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_image_with_text__body p {
    margin: 0 0 0.75em;
  }
  #shopify-section-{{ section.id }} .lab_image_with_text__body p:last-child {
    margin-bottom: 0;
  }

  #shopify-section-{{ section.id }} .lab_image_with_text__actions {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(0.5rem, 1.5vw, 1rem);
    margin-top: clamp(0.5rem, 1vw, 1rem);
    justify-content: {% if section.settings.content_alignment == 'left' %}flex-start{% elsif section.settings.content_alignment == 'right' %}flex-end{% else %}center{% endif %};
  }

  #shopify-section-{{ section.id }} .lab_image_with_text__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
  }

  #shopify-section-{{ section.id }} .lab_image_with_text__cta--primary {
    padding: {{ section.settings.cta_padding_y }}px {{ section.settings.cta_padding_x }}px;
    border-radius: {{ section.settings.cta_border_radius }}px;
    border: {{ section.settings.cta_border_width }}px solid {% if section.settings.cta_border_color != blank %}color-mix(in srgb, {{ section.settings.cta_border_color }} {{ section.settings.cta_border_color_opacity }}%, transparent){% else %}transparent{% endif %};
    font-weight: 600;
    {% if section.settings.cta_bg_color != blank %}
      background-color: color-mix(in srgb, {{ section.settings.cta_bg_color }} {{ section.settings.cta_bg_color_opacity }}%, transparent);
    {% else %}
      background-color: var(--color-button);
    {% endif %}
    {% if section.settings.cta_text_color != blank %}
      color: color-mix(in srgb, {{ section.settings.cta_text_color }} {{ section.settings.cta_text_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-button-text);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_image_with_text--cta-hover-fill .lab_image_with_text__cta--primary:hover,
  #shopify-section-{{ section.id }} .lab_image_with_text--cta-hover-darken .lab_image_with_text__cta--primary:hover,
  #shopify-section-{{ section.id }} .lab_image_with_text--cta-hover-lift .lab_image_with_text__cta--primary:hover,
  #shopify-section-{{ section.id }} .lab_image_with_text--cta-hover-glow .lab_image_with_text__cta--primary:hover {
    {% if section.settings.cta_hover_bg_color != blank %}
      background-color: color-mix(in srgb, {{ section.settings.cta_hover_bg_color }} {{ section.settings.cta_hover_bg_color_opacity }}%, transparent);
    {% endif %}
    {% if section.settings.cta_hover_text_color != blank %}
      color: color-mix(in srgb, {{ section.settings.cta_hover_text_color }} {{ section.settings.cta_hover_text_color_opacity }}%, transparent);
    {% endif %}
    {% if section.settings.cta_hover_border_color != blank %}
      border-color: color-mix(in srgb, {{ section.settings.cta_hover_border_color }} {{ section.settings.cta_hover_border_color_opacity }}%, transparent);
    {% endif %}
  }
  #shopify-section-{{ section.id }} .lab_image_with_text--cta-hover-darken .lab_image_with_text__cta--primary:hover,
  #shopify-section-{{ section.id }} .lab_image_with_text--cta2-hover-darken .lab_image_with_text__cta--secondary:hover {
    filter: brightness(0.88);
  }
  #shopify-section-{{ section.id }} .lab_image_with_text--cta-hover-lift .lab_image_with_text__cta--primary:hover,
  #shopify-section-{{ section.id }} .lab_image_with_text--cta2-hover-lift .lab_image_with_text__cta--secondary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px color-mix(in srgb, var(--color-foreground) 18%, transparent);
  }
  #shopify-section-{{ section.id }} .lab_image_with_text--cta-hover-glow .lab_image_with_text__cta--primary:hover {
    box-shadow: 0 0 24px {% if section.settings.cta_hover_bg_color != blank %}color-mix(in srgb, {{ section.settings.cta_hover_bg_color }} 60%, transparent){% else %}color-mix(in srgb, var(--color-foreground) 25%, transparent){% endif %};
  }
  #shopify-section-{{ section.id }} .lab_image_with_text--cta2-hover-glow .lab_image_with_text__cta--secondary:hover {
    box-shadow: 0 0 24px {% if section.settings.secondary_cta_hover_bg_color != blank %}color-mix(in srgb, {{ section.settings.secondary_cta_hover_bg_color }} 60%, transparent){% else %}color-mix(in srgb, var(--color-foreground) 25%, transparent){% endif %};
  }
  #shopify-section-{{ section.id }} .lab_image_with_text--cta-hover-outline .lab_image_with_text__cta--primary:hover,
  #shopify-section-{{ section.id }} .lab_image_with_text--cta2-hover-outline .lab_image_with_text__cta--secondary:hover {
    background-color: transparent;
  }
  #shopify-section-{{ section.id }} .lab_image_with_text--cta-hover-outline .lab_image_with_text__cta--primary:hover {
    {% if section.settings.cta_hover_text_color != blank %}
      color: color-mix(in srgb, {{ section.settings.cta_hover_text_color }} {{ section.settings.cta_hover_text_color_opacity }}%, transparent);
    {% endif %}
    {% if section.settings.cta_hover_border_color != blank %}
      border-color: color-mix(in srgb, {{ section.settings.cta_hover_border_color }} {{ section.settings.cta_hover_border_color_opacity }}%, transparent);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_image_with_text__cta--secondary {
    padding: {{ section.settings.secondary_cta_padding_y }}px {{ section.settings.secondary_cta_padding_x }}px;
    border-radius: {{ section.settings.secondary_cta_border_radius }}px;
    border: {{ section.settings.secondary_cta_border_width }}px solid {% if section.settings.secondary_cta_border_color != blank %}color-mix(in srgb, {{ section.settings.secondary_cta_border_color }} {{ section.settings.secondary_cta_border_color_opacity }}%, transparent){% else %}var(--color-foreground){% endif %};
    font-weight: 600;
    {% if section.settings.secondary_cta_bg_color != blank %}
      background-color: color-mix(in srgb, {{ section.settings.secondary_cta_bg_color }} {{ section.settings.secondary_cta_bg_color_opacity }}%, transparent);
    {% else %}
      background-color: transparent;
    {% endif %}
    {% if section.settings.secondary_cta_text_color != blank %}
      color: color-mix(in srgb, {{ section.settings.secondary_cta_text_color }} {{ section.settings.secondary_cta_text_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_image_with_text--cta2-hover-fill .lab_image_with_text__cta--secondary:hover,
  #shopify-section-{{ section.id }} .lab_image_with_text--cta2-hover-darken .lab_image_with_text__cta--secondary:hover,
  #shopify-section-{{ section.id }} .lab_image_with_text--cta2-hover-lift .lab_image_with_text__cta--secondary:hover,
  #shopify-section-{{ section.id }} .lab_image_with_text--cta2-hover-glow .lab_image_with_text__cta--secondary:hover {
    {% if section.settings.secondary_cta_hover_bg_color != blank %}
      background-color: color-mix(in srgb, {{ section.settings.secondary_cta_hover_bg_color }} {{ section.settings.secondary_cta_hover_bg_color_opacity }}%, transparent);
    {% endif %}
    {% if section.settings.secondary_cta_hover_text_color != blank %}
      color: color-mix(in srgb, {{ section.settings.secondary_cta_hover_text_color }} {{ section.settings.secondary_cta_hover_text_color_opacity }}%, transparent);
    {% endif %}
    {% if section.settings.secondary_cta_hover_border_color != blank %}
      border-color: color-mix(in srgb, {{ section.settings.secondary_cta_hover_border_color }} {{ section.settings.secondary_cta_hover_border_color_opacity }}%, transparent);
    {% endif %}
  }
  #shopify-section-{{ section.id }} .lab_image_with_text--cta2-hover-outline .lab_image_with_text__cta--secondary:hover {
    {% if section.settings.secondary_cta_hover_text_color != blank %}
      color: color-mix(in srgb, {{ section.settings.secondary_cta_hover_text_color }} {{ section.settings.secondary_cta_hover_text_color_opacity }}%, transparent);
    {% endif %}
    {% if section.settings.secondary_cta_hover_border_color != blank %}
      border-color: color-mix(in srgb, {{ section.settings.secondary_cta_hover_border_color }} {{ section.settings.secondary_cta_hover_border_color_opacity }}%, transparent);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_image_with_text__cta:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 3px;
  }

  /* Animation */
  {% if animation_enabled %}
    #shopify-section-{{ section.id }} .lab_image_with_text--animated .lab_image_with_text__content,
    #shopify-section-{{ section.id }} .lab_image_with_text--animated .lab_image_with_text__media {
      opacity: 0;
      animation-duration: 0.6s;
      animation-fill-mode: forwards;
      animation-timing-function: ease-out;
    }
    #shopify-section-{{ section.id }} .lab_image_with_text--anim-fade .lab_image_with_text__content,
    #shopify-section-{{ section.id }} .lab_image_with_text--anim-fade .lab_image_with_text__media {
      animation-name: lab_image_with_text_fade_{{ section.id }};
    }
    #shopify-section-{{ section.id }} .lab_image_with_text--anim-slide .lab_image_with_text__content,
    #shopify-section-{{ section.id }} .lab_image_with_text--anim-slide .lab_image_with_text__media {
      animation-name: lab_image_with_text_slide_{{ section.id }};
    }
    #shopify-section-{{ section.id }} .lab_image_with_text--anim-zoom .lab_image_with_text__content,
    #shopify-section-{{ section.id }} .lab_image_with_text--anim-zoom .lab_image_with_text__media {
      animation-name: lab_image_with_text_zoom_{{ section.id }};
    }
    @keyframes lab_image_with_text_fade_{{ section.id }} {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    @keyframes lab_image_with_text_slide_{{ section.id }} {
      from { opacity: 0; transform: translateY(16px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes lab_image_with_text_zoom_{{ section.id }} {
      from { opacity: 0; transform: scale(0.97); }
      to { opacity: 1; transform: scale(1); }
    }
  {% endif %}

  /* Desktop split layout — image position via order, image_width via grid columns */
  @media (min-width: 750px) {
    #shopify-section-{{ section.id }} .lab_image_with_text__inner {
      grid-template-columns:
        {% case image_width %}
          {% when '40' %}{% if image_position == 'right' %}1fr 40%{% else %}40% 1fr{% endif %};
          {% when '60' %}{% if image_position == 'right' %}1fr 60%{% else %}60% 1fr{% endif %};
          {% else %}1fr 1fr;
        {% endcase %}
      align-items: {% if vertical_alignment == 'top' %}start{% elsif vertical_alignment == 'bottom' %}end{% else %}center{% endif %};
    }
    #shopify-section-{{ section.id }} .lab_image_with_text__media {
      order: {% if image_position == 'right' %}2{% else %}1{% endif %};
    }
    #shopify-section-{{ section.id }} .lab_image_with_text__content {
      order: {% if image_position == 'right' %}1{% else %}2{% endif %};
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .lab_image_with_text__image,
    #shopify-section-{{ section.id }} .lab_image_with_text__cta,
    #shopify-section-{{ section.id }} .lab_image_with_text__content,
    #shopify-section-{{ section.id }} .lab_image_with_text__media {
      transition: none;
      animation: none;
      transform: none;
    }
  }

  {% if section.settings.hide_on_mobile %}
    #shopify-section-{{ section.id }} { display: none; }
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} {
        display: {% if section.settings.hide_on_desktop %}none{% else %}revert{% endif %};
      }
    }
  {% elsif section.settings.hide_on_desktop %}
    @media screen and (min-width: 750px) {
