{% comment %} 1. Assigns {% endcomment %}
{% liquid
  assign section_id = section.id
  assign collection = collections[section.settings.collection]
  assign products_count = section.settings.products_count
  assign columns = section.settings.columns
  assign show_vendor = section.settings.show_vendor
  assign show_sale_badge = section.settings.show_sale_badge
  assign show_view_all_button = section.settings.show_view_all_button
  assign card_hover = section.settings.product_card_hover_transform
  assign animation_enabled = section.settings.animation_enabled
  assign animation_type = section.settings.animation_type
  assign animation_delay = section.settings.animation_delay
  assign aspect_ratio = section.settings.product_image_aspect_ratio
  assign bg_pct = section.settings.bg_opacity
  assign bg_grad_pct = section.settings.bg_gradient_color_opacity

  if section.index <= 2
    assign section_eager = true
  else
    assign section_eager = false
  endif
%}

{% comment %} 2. HTML structure {% endcomment %}
<div class="color-{{ section.settings.color_scheme }} gradient">
  <section
    id="lab-{{ section_id }}"
    class="lab_collection_cards lab_collection_cards--cols-{{ columns }} lab_collection_cards--align-{{ section.settings.content_alignment }} lab_collection_cards--shadow-{{ section.settings.product_card_shadow }} lab_collection_cards--hover-shadow-{{ section.settings.product_card_hover_shadow }} lab_collection_cards--hover-{{ card_hover }}{% if animation_enabled %} lab_collection_cards--animated lab_collection_cards--anim-{{ animation_type }}{% endif %} lab_section{% if section.settings.spacing_size != 'custom' %} lab_section--spacing-{{ section.settings.spacing_size }}{% endif %}{% if section.settings.inner_spacing_y != 'custom' %} lab_section--inner-y-{{ section.settings.inner_spacing_y }}{% endif %}"
    data-lab-spacing="{{ section.settings.spacing_size }}"
    data-lab-inner-y="{{ section.settings.inner_spacing_y }}"
    aria-label="{{ section.settings.heading | default: 'Featured collection' | escape }}"
  >
    <div class="lab_container lab_container--{{ section.settings.container_width }}{% if section.settings.inner_spacing_x != 'custom' and section.settings.inner_spacing_x != 'none' %} lab_container--inner-x-{{ section.settings.inner_spacing_x }}{% endif %} lab_collection_cards__inner">
      {% if section.settings.heading != blank or section.settings.subheading != blank %}
        <header class="lab_collection_cards__header">
          {% if section.settings.heading != blank %}
            <h2 class="lab_collection_cards__heading">{{ section.settings.heading | escape }}</h2>
          {% endif %}
          {% if section.settings.subheading != blank %}
            <p class="lab_collection_cards__subheading">{{ section.settings.subheading | escape | newline_to_br }}</p>
          {% endif %}
        </header>
      {% endif %}

      <ul class="lab_collection_cards__grid" role="list">
        {% if collection != blank and collection.products.size > 0 %}
          {% for product in collection.products limit: products_count %}
            {% liquid
              assign on_sale = false
              if product.compare_at_price > product.price
                assign on_sale = true
              endif

              if section_eager and forloop.index <= 2
                assign img_loading = 'eager'
                assign img_fetchpriority = 'high'
              else
                assign img_loading = 'lazy'
                assign img_fetchpriority = 'auto'
              endif
            %}

            <li role="listitem" class="lab_collection_cards__item"
              {% if animation_enabled %}style="animation-delay: {{ animation_delay | times: forloop.index0 }}ms;"{% endif %}>
              <article class="lab_collection_cards__card">
                <a href="{{ product.url }}" class="lab_collection_cards__media-link" aria-label="{{ 'View product: ' | append: product.title | escape }}" tabindex="-1">
                  <div class="lab_collection_cards__media">
                    {% if product.featured_image != blank %}
                      {{ product.featured_image
                        | image_url: width: 800
                        | image_tag:
                          alt: product.featured_image.alt | default: product.title,
                          loading: img_loading,
                          fetchpriority: img_fetchpriority,
                          width: product.featured_image.width,
                          height: product.featured_image.height,
                          widths: '400, 600, 800',
                          sizes: '(min-width: 1200px) 25vw, (min-width: 750px) 33vw, 50vw',
                          class: 'lab_collection_cards__image'
                      }}
                    {% else %}
                      <div class="lab_collection_cards__image lab_collection_cards__image--placeholder" aria-hidden="true">
                        {{ 'product-1' | placeholder_svg_tag: 'lab_collection_cards__placeholder-svg' }}
                      </div>
                    {% endif %}

                    {% if show_sale_badge and on_sale %}
                      <span class="lab_collection_cards__badge">{{ section.settings.sale_badge_text | escape }}</span>
                    {% endif %}
                  </div>
                </a>

                <div class="lab_collection_cards__body">
                  {% if show_vendor and product.vendor != blank %}
                    <p class="lab_collection_cards__vendor">{{ product.vendor | escape }}</p>
                  {% endif %}

                  <h3 class="lab_collection_cards__title">
                    <a href="{{ product.url }}" class="lab_collection_cards__title-link">{{ product.title | escape }}</a>
                  </h3>

                  <p class="lab_collection_cards__price">
                    {% if on_sale %}
                      <span class="lab_collection_cards__price-sale">{{ product.price | money }}</span>
                      <s class="lab_collection_cards__price-was">{{ product.compare_at_price | money }}</s>
                    {% else %}
                      <span class="lab_collection_cards__price-regular">{{ product.price | money }}</span>
                    {% endif %}
                  </p>

                  <a
                    href="{{ product.url }}"
                    class="lab_collection_cards__cta"
                    aria-label="{{ 'View product: ' | append: product.title | escape }}"
                  >
                    {{ section.settings.product_button_label | default: 'View product' | escape }}
                  </a>
                </div>
              </article>
            </li>
          {% endfor %}
        {% else %}
          {% comment %} Placeholder cards when no collection is selected (Theme Editor preview) {% endcomment %}
          {% for i in (1..products_count) %}
            <li role="listitem" class="lab_collection_cards__item">
              <article class="lab_collection_cards__card">
                <div class="lab_collection_cards__media">
                  <div class="lab_collection_cards__image lab_collection_cards__image--placeholder" aria-hidden="true">
                    {{ 'product-1' | placeholder_svg_tag: 'lab_collection_cards__placeholder-svg' }}
                  </div>
                </div>
                <div class="lab_collection_cards__body">
                  {% if show_vendor %}
                    <p class="lab_collection_cards__vendor">Vendor name</p>
                  {% endif %}
                  <h3 class="lab_collection_cards__title">
                    <span class="lab_collection_cards__title-link">Sample product {{ forloop.index }}</span>
                  </h3>
                  <p class="lab_collection_cards__price">
                    <span class="lab_collection_cards__price-regular">$49.00</span>
                  </p>
                  <span class="lab_collection_cards__cta lab_collection_cards__cta--placeholder" aria-hidden="true">{{ section.settings.product_button_label | default: 'View product' | escape }}</span>
                </div>
              </article>
            </li>
          {% endfor %}
        {% endif %}
      </ul>

      {% if show_view_all_button and section.settings.button_label != blank and collection != blank %}
        <div class="lab_collection_cards__footer">
          <a
            href="{{ collection.url }}"
            class="lab_collection_cards__view-all"
            aria-label="{{ 'View all in ' | append: collection.title | escape }}"
          >
            {{ section.settings.button_label | escape }}
          </a>
        </div>
      {% endif %}
    </div>
  </section>
</div>

{% comment %} 3. CSS — section scoped {% endcomment %}
<style>
  #shopify-section-{{ section.id }} .lab_collection_cards {
    {% if section.settings.bg_color != blank %}
      background-color: color-mix(in srgb, {{ section.settings.bg_color }} {{ bg_pct }}%, transparent);
    {% else %}
      background-color: var(--color-background);
    {% endif %}
    {% if section.settings.bg_gradient and section.settings.bg_color != blank and section.settings.bg_gradient_color != blank %}
      background-image: linear-gradient(
        {{ section.settings.bg_gradient_direction }},
        color-mix(in srgb, {{ section.settings.bg_color }} {{ bg_pct }}%, transparent),
        color-mix(in srgb, {{ section.settings.bg_gradient_color }} {{ bg_grad_pct }}%, transparent)
      );
    {% endif %}
  }

  {% if section.settings.spacing_size == 'custom' %}
    #shopify-section-{{ section.id }} .lab_collection_cards {
      margin-top: {{ section.settings.spacing_top_custom }}px;
      margin-bottom: {{ section.settings.spacing_bottom_custom }}px;
    }
  {% endif %}

  {% if section.settings.inner_spacing_y == 'custom' %}
    #shopify-section-{{ section.id }} .lab_collection_cards {
      padding-top: {{ section.settings.inner_spacing_y_top_custom }}px;
      padding-bottom: {{ section.settings.inner_spacing_y_bottom_custom }}px;
    }
  {% endif %}

  {% if section.settings.inner_spacing_x == 'custom' %}
    #shopify-section-{{ section.id }} .lab_collection_cards__inner {
      padding-inline: {% if section.settings.container_width == 'full' %}{{ section.settings.inner_spacing_x_custom }}px{% else %}calc(var(--lab-gutter-mobile) + {{ section.settings.inner_spacing_x_custom }}px){% endif %};
    }
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} .lab_collection_cards__inner {
        padding-inline: {% if section.settings.container_width == 'full' %}{{ section.settings.inner_spacing_x_custom }}px{% else %}calc(var(--lab-gutter-tablet) + {{ section.settings.inner_spacing_x_custom }}px){% endif %};
      }
    }
    @media screen and (min-width: 990px) {
      #shopify-section-{{ section.id }} .lab_collection_cards__inner {
        padding-inline: {% if section.settings.container_width == 'full' %}{{ section.settings.inner_spacing_x_custom }}px{% else %}calc(var(--lab-gutter-desktop) + {{ section.settings.inner_spacing_x_custom }}px){% endif %};
      }
    }
  {% endif %}

  #shopify-section-{{ section.id }} .lab_collection_cards__header {
    width: 100%;
    max-width: {{ section.settings.content_max_width }}px;
    margin: 0 auto clamp(1.5rem, 4vw, 3rem);
    text-align: {% if section.settings.content_alignment == 'left' %}left{% elsif section.settings.content_alignment == 'right' %}right{% else %}center{% endif %};
  }

  #shopify-section-{{ section.id }} .lab_collection_cards__heading {
    margin: 0 0 clamp(0.5rem, 1.5vw, 1rem);
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
    text-transform: {{ section.settings.heading_transform }};
    text-align: {{ section.settings.heading_text_align }};
    letter-spacing: calc({{ section.settings.heading_letter_spacing }} / 100 * 1em);
    line-height: calc({{ section.settings.heading_line_height }} / 10);
    {% if section.settings.heading_color != blank %}
      color: color-mix(in srgb, {{ section.settings.heading_color }} {{ section.settings.heading_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_collection_cards__subheading {
    margin: 0;
    font-size: {{ section.settings.subheading_size }}px;
    font-weight: {{ section.settings.subheading_weight }};
    text-transform: {{ section.settings.subheading_transform }};
    text-align: {{ section.settings.subheading_text_align }};
    letter-spacing: calc({{ section.settings.subheading_letter_spacing }} / 100 * 1em);
    line-height: calc({{ section.settings.subheading_line_height }} / 10);
    {% if section.settings.subheading_color != blank %}
      color: color-mix(in srgb, {{ section.settings.subheading_color }} {{ section.settings.subheading_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground-75, var(--color-foreground));
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_collection_cards__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: {{ section.settings.items_gap }}px;
    align-items: {{ section.settings.items_align }};
  }

  @media (min-width: 750px) {
    #shopify-section-{{ section.id }} .lab_collection_cards--cols-2 .lab_collection_cards__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    #shopify-section-{{ section.id }} .lab_collection_cards--cols-3 .lab_collection_cards__grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    #shopify-section-{{ section.id }} .lab_collection_cards--cols-4 .lab_collection_cards__grid { grid-template-columns: repeat(4, minmax(0, 1fr)); }
  }

  #shopify-section-{{ section.id }} .lab_collection_cards__item {
    margin: 0;
    display: flex;
  }

  #shopify-section-{{ section.id }} .lab_collection_cards__card {
    width: 100%;
    display: flex;
    flex-direction: column;
    padding: {{ section.settings.product_card_padding }}px;
    border-radius: {{ section.settings.product_card_border_radius }}px;
    border: {{ section.settings.product_card_border_width }}px solid {% if section.settings.product_card_border_color != blank %}color-mix(in srgb, {{ section.settings.product_card_border_color }} {{ section.settings.product_card_border_color_opacity }}%, transparent){% else %}transparent{% endif %};
    transition: background-color 0.3s ease, border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
    {% if section.settings.product_card_bg_color != blank %}
      background-color: color-mix(in srgb, {{ section.settings.product_card_bg_color }} {{ section.settings.product_card_bg_color_opacity }}%, transparent);
    {% else %}
      background-color: transparent;
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_collection_cards--shadow-soft .lab_collection_cards__card { box-shadow: 0 1px 3px color-mix(in srgb, var(--color-foreground) 8%, transparent); }
  #shopify-section-{{ section.id }} .lab_collection_cards--shadow-medium .lab_collection_cards__card { box-shadow: 0 4px 12px color-mix(in srgb, var(--color-foreground) 12%, transparent); }
  #shopify-section-{{ section.id }} .lab_collection_cards--shadow-strong .lab_collection_cards__card { box-shadow: 0 12px 32px color-mix(in srgb, var(--color-foreground) 18%, transparent); }

  #shopify-section-{{ section.id }} .lab_collection_cards__card:hover {
    {% if section.settings.product_card_hover_bg_color != blank %}
      background-color: color-mix(in srgb, {{ section.settings.product_card_hover_bg_color }} {{ section.settings.product_card_hover_bg_color_opacity }}%, transparent);
    {% endif %}
    {% if section.settings.product_card_hover_border_color != blank %}
      border-color: color-mix(in srgb, {{ section.settings.product_card_hover_border_color }} {{ section.settings.product_card_hover_border_color_opacity }}%, transparent);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_collection_cards--hover-shadow-soft .lab_collection_cards__card:hover { box-shadow: 0 2px 8px color-mix(in srgb, var(--color-foreground) 10%, transparent); }
  #shopify-section-{{ section.id }} .lab_collection_cards--hover-shadow-medium .lab_collection_cards__card:hover { box-shadow: 0 6px 20px color-mix(in srgb, var(--color-foreground) 14%, transparent); }
  #shopify-section-{{ section.id }} .lab_collection_cards--hover-shadow-strong .lab_collection_cards__card:hover { box-shadow: 0 16px 40px color-mix(in srgb, var(--color-foreground) 22%, transparent); }

  #shopify-section-{{ section.id }} .lab_collection_cards--hover-lift .lab_collection_cards__card:hover {
    transform: translateY(-4px);
  }
  #shopify-section-{{ section.id }} .lab_collection_cards--hover-scale .lab_collection_cards__card:hover {
    transform: scale(1.02);
  }
  #shopify-section-{{ section.id }} .lab_collection_cards--hover-border .lab_collection_cards__card:hover {
    border-color: var(--color-foreground);
  }
  #shopify-section-{{ section.id }} .lab_collection_cards--hover-glow .lab_collection_cards__card:hover {
    box-shadow: 0 0 28px color-mix(in srgb, var(--color-foreground) 22%, transparent);
  }

  #shopify-section-{{ section.id }} .lab_collection_cards__media-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  #shopify-section-{{ section.id }} .lab_collection_cards__media {
    position: relative;
    overflow: hidden;
    border-radius: {{ section.settings.product_image_border_radius }}px;
    margin-bottom: clamp(0.75rem, 1.5vw, 1.25rem);
    {% case aspect_ratio %}
      {% when '1-1' %}aspect-ratio: 1 / 1;
      {% when '4-3' %}aspect-ratio: 4 / 3;
      {% when '16-9' %}aspect-ratio: 16 / 9;
      {% when '3-2' %}aspect-ratio: 3 / 2;
      {% when '2-3' %}aspect-ratio: 2 / 3;
    {% endcase %}
    background-color: color-mix(in srgb, var(--color-foreground) 4%, transparent);
  }

  #shopify-section-{{ section.id }} .lab_collection_cards__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.product_image_object_fit }};
    transition: transform 0.5s ease;
  }

  #shopify-section-{{ section.id }} .lab_collection_cards__card:hover .lab_collection_cards__image {
    transform: scale(1.05);
  }

  #shopify-section-{{ section.id }} .lab_collection_cards__image--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    color: color-mix(in srgb, var(--color-foreground) 25%, transparent);
  }

  #shopify-section-{{ section.id }} .lab_collection_cards__placeholder-svg {
    width: 60%;
    height: 60%;
    object-fit: contain;
  }

  {% if section.settings.product_image_overlay_opacity > 0 %}
    #shopify-section-{{ section.id }} .lab_collection_cards__media::after {
      content: '';
      position: absolute;
      inset: 0;
      background-color: color-mix(in srgb, {% if section.settings.product_image_overlay_color != blank %}{{ section.settings.product_image_overlay_color }}{% else %}var(--color-foreground){% endif %} {{ section.settings.product_image_overlay_color_opacity }}%, transparent);
      opacity: calc({{ section.settings.product_image_overlay_opacity }} / 100);
      pointer-events: none;
    }
  {% endif %}

  #shopify-section-{{ section.id }} .lab_collection_cards__badge {
    position: absolute;
    top: clamp(0.5rem, 1vw, 0.75rem);
    left: clamp(0.5rem, 1vw, 0.75rem);
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    line-height: 1.4;
    z-index: 1;
    {% if section.settings.sale_badge_color != blank %}
      background-color: color-mix(in srgb, {{ section.settings.sale_badge_color }} {{ section.settings.sale_badge_color_opacity }}%, transparent);
    {% else %}
      background-color: var(--color-foreground);
    {% endif %}
    {% if section.settings.sale_badge_text_color != blank %}
      color: color-mix(in srgb, {{ section.settings.sale_badge_text_color }} {{ section.settings.sale_badge_text_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-background);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_collection_cards__body {
    display: flex;
    flex-direction: column;
    gap: clamp(0.25rem, 0.75vw, 0.5rem);
    text-align: {% if section.settings.content_alignment == 'right' %}right{% elsif section.settings.content_alignment == 'center' %}center{% else %}left{% endif %};
  }

  #shopify-section-{{ section.id }} .lab_collection_cards__vendor {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: color-mix(in srgb, var(--color-foreground) 60%, transparent);
  }

  #shopify-section-{{ section.id }} .lab_collection_cards__title {
    margin: 0;
    font-size: {{ section.settings.product_title_size }}px;
    font-weight: {{ section.settings.product_title_weight }};
    text-transform: {{ section.settings.product_title_transform }};
    text-align: {{ section.settings.product_title_text_align }};
    letter-spacing: calc({{ section.settings.product_title_letter_spacing }} / 100 * 1em);
    line-height: calc({{ section.settings.product_title_line_height }} / 10);
    {% if section.settings.product_title_color != blank %}
      color: color-mix(in srgb, {{ section.settings.product_title_color }} {{ section.settings.product_title_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_collection_cards__title-link {
    color: inherit;
    text-decoration: none;
  }
  #shopify-section-{{ section.id }} .lab_collection_cards__title-link:hover {
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  #shopify-section-{{ section.id }} .lab_collection_cards__price {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem;
    font-size: {{ section.settings.product_price_size }}px;
    font-weight: {{ section.settings.product_price_weight }};
    text-transform: {{ section.settings.product_price_transform }};
    letter-spacing: calc({{ section.settings.product_price_letter_spacing }} / 100 * 1em);
    line-height: calc({{ section.settings.product_price_line_height }} / 10);
    justify-content: {% if section.settings.content_alignment == 'right' %}flex-end{% elsif section.settings.content_alignment == 'center' %}center{% else %}flex-start{% endif %};
    {% if section.settings.product_price_color != blank %}
      color: color-mix(in srgb, {{ section.settings.product_price_color }} {{ section.settings.product_price_color_opacity }}%, transparent);
    {% else %}
      color: var(--color-foreground);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_collection_cards__price-sale {
    {% if section.settings.sale_badge_color != blank %}
      color: color-mix(in srgb, {{ section.settings.sale_badge_color }} {{ section.settings.sale_badge_color_opacity }}%, transparent);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lab_collection_cards__price-was {
    font-weight: 400;
    opacity: 0.6;
  }

  #shopify-section-{{ section.id }} .lab_collection_cards__cta {
    display: inline-flex;
    align-self: {% if section.settings.content_alignment == 'right' %}flex-end{% elsif section.settings.content_alignment == 'center' %}center{% else %}flex-start{% endif %};
    align-items: center;
    justify-content: center;
    margin-top: clamp(0.5rem, 1vw, 0.75rem);
    padding: 0.625rem 1.25rem;
    min-height: 44px;
    border-radius: 6px;
    border: 1px solid var(--color-foreground);
    background-color: transparent;
    color: var(--color-foreground);
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  #shopify-section-{{ section.id }} .lab_collection_cards__cta:hover {
    background-color: var(--color-foreground);
    color: var(--color-background);
  }

  #shopify-section-{{ section.id }} .lab_collection_cards__cta--placeholder {
    opacity: 0.6;
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .lab_collection_cards__cta:focus-visible,
  #shopify-section-{{ section.id }} .lab_collection_cards__title-link:focus-visible,
  #shopify-section-{{ section.id }} .lab_collection_cards__media-link:focus-visible,
  #shopify-section-{{ section.id }} .lab_collection_cards__view-all:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 3px;
    border-radius: 4px;
  }

  #shopify-section-{{ section.id }} .lab_collection_cards__footer {
    display: flex;
    justify-content: center;
    margin-top: clamp(1.5rem, 3vw, 2.5rem);
  }

  #shopify-section-{{ section.id }} .lab_collection_cards__view-all {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0.875rem 1.75rem;
    border-radius: 8px;
    background-color: var(--color-foreground);
    color: var(--color-background);
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: filter 0.2s ease, transform 0.2s ease;
  }
  #shopify-section-{{ section.id }} .lab_collection_cards__view-all:hover {
    filter: brightness(0.9);
    transform: translateY(-2px);
  }

  /* Animation */
  {% if animation_enabled %}
    #shopify-section-{{ section.id }} .lab_collection_cards--animated .lab_collection_cards__item {
      opacity: 0;
      animation-duration: 0.6s;
      animation-fill-mode: forwards;
      animation-timing-function: ease-out;
    }
    #shopify-section-{{ section.id }} .lab_collection_cards--anim-fade .lab_collection_cards__item {
      animation-name: lab_collection_cards_fade_{{ section.id }};
    }
    #shopify-section-{{ section.id }} .lab_collection_cards--anim-slide .lab_collection_cards__item {
      animation-name: lab_collection_cards_slide_{{ section.id }};
    }
    #shopify-section-{{ section.id }} .lab_collection_cards--anim-zoom .lab_collection_cards__item {
      animation-name: lab_collection_cards_zoom_{{ section.id }};
    }
    @keyframes lab_collection_cards_fade_{{ section.id }} {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    @keyframes lab_collection_cards_slide_{{ section.id }} {
      from { opacity: 0; transform: translateY(16px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes lab_collection_cards_zoom_{{ section.id }} {
      from { opacity: 0; transform: scale(0.96); }
      to { opacity: 1; transform: scale(1); }
    }
  {% endif %}

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .lab_collection_cards__card,
    #shopify-section-{{ section.id }} .lab_collection_cards__image,
    #shopify-section-{{ section.id }} .lab_collection_cards__item,
    #shopify-section-{{ section.id }} .lab_collection_cards__view-all,
    #shopify-section-{{ section.id }} .lab_collection_cards__cta {
      transition: none;
      animation: none;
      transform: none;
    }
  }

  {% if section.settings.hide_on_mobile %}
    #shopify-section-{{ section.id }} { display: none; }
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} {
        display: {% if section.settings.hide_on_desktop %}none{% else %}revert{% endif %};
      }
    }
  {% elsif section.settings.hide_on_desktop %}
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} { display: none; }
    }
  {% endif %}

  {% if section.settings.custom_css != blank %}
    #shopify-section-{{ section.id }} {
      {{ section.settings.custom_css }}
    }
  {% endif %}
</style>

