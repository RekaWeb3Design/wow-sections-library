{
  "name": "lab-image",
  "type": "atomic_snippet",
  "version": "1.0.0",
  "description": "Renders a responsive image with lazy or eager (LCP) loading. Block-compatible.",
  "parameters": {
    "required": [
      { "name": "image", "type": "image", "description": "Shopify image object" }
    ],
    "optional": [
      { "name": "mobile_image", "type": "image", "description": "Separate mobile image" },
      { "name": "alt", "type": "string", "description": "Alt text override" },
      { "name": "sizes", "type": "string", "default": "100vw" },
      { "name": "widths", "type": "string", "default": "375,550,750,1100,1500,1780,2000" },
      { "name": "max_width", "type": "number", "default": 2000 },
      { "name": "aspect_ratio", "type": "enum", "values": ["natural", "16/9", "1/1", "4/5", "3/2"], "default": "natural" },
      { "name": "object_fit", "type": "enum", "values": ["cover", "contain"], "default": "cover" },
      { "name": "loading", "type": "enum", "values": ["lazy", "eager"], "default": "lazy" },
      { "name": "fetchpriority", "type": "enum", "values": ["auto", "high"], "default": "auto" },
      { "name": "is_lcp", "type": "boolean", "default": false, "description": "Forces eager + high priority" },
      { "name": "placeholder_svg", "type": "string", "default": "lifestyle-1" }
    ]
  },
  "css_classes": [
    "lab_image",
    "lab_image__img",
    "lab_image--ratio-16-9",
    "lab_image--ratio-1-1",
    "lab_image--ratio-4-5",
    "lab_image--ratio-3-2",
    "lab_image__img--placeholder"
  ],
  "horizon_block_compatible": true
}
