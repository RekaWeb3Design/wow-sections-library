  { "type": "checkbox", "id": "button_full_width", "label": "Full width", "default": false },
  {
    "type": "select",
    "id": "button_hover_effect",
    "label": "Hover effect",
    "options": [
      { "value": "none", "label": "None" },
      { "value": "fill", "label": "Fill" },
      { "value": "darken", "label": "Darken" },
