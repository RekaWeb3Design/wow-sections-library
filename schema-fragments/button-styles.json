[
  { "type": "header", "content": "Button styles" },
  {
    "type": "select",
    "id": "button_style",
    "label": "Style",
    "options": [
      { "value": "primary", "label": "Primary" },
      { "value": "secondary", "label": "Secondary" },
      { "value": "outline", "label": "Outline" }
    ],
    "default": "primary"
  },
  {
    "type": "select",
    "id": "button_size",
    "label": "Size",
