[
  { "type": "header", "content": "Button styles" },
  {
    "type": "select",
    "id": "button_style",
    "label": "Button style",
    "options": [
      { "value": "primary", "label": "Primary" },
      { "value": "secondary", "label": "Secondary" },
      { "value": "outline", "label": "Outline" }
    ],
    "default": "primary"
  },
  {
    "type": "select",
    "id": "button_size",
    "label": "Button size",
    "options": [
      { "value": "small", "label": "Small" },
      { "value": "medium", "label": "Medium" },
      { "value": "large", "label": "Large" }
    ],
    "default": "medium"
  },
  { "type": "checkbox", "id": "button_full_width", "label": "Button full width", "default": false },
  {
    "type": "select",
    "id": "button_hover_effect",
    "label": "Button hover effect",
    "options": [
      { "value": "none", "label": "None" },
      { "value": "fill", "label": "Fill" },
      { "value": "darken", "label": "Darken" },
      { "value": "lift", "label": "Lift" },
      { "value": "outline", "label": "Outline" },
      { "value": "glow", "label": "Glow" }
    ],
    "default": "lift"
  },
  { "type": "range", "id": "button_border_radius", "label": "Button border radius", "min": 0, "max": 50, "step": 1, "unit": "px", "default": 6 },

  { "type": "header", "content": "Button colors (advanced)" },
  {
    "type": "checkbox",
    "id": "button_colors_override_enabled",
    "label": "Override scheme button colors",
    "default": false,
    "info": "By default, button uses the color scheme. Enable to customize."
  },
  {
    "type": "color",
    "id": "button_bg_color_override",
    "label": "Button background color",
    "visible_if": "{{ section.settings.button_colors_override_enabled }}"
  },
  {
    "type": "range",
    "id": "button_bg_color_opacity",
    "label": "Button background opacity",
    "min": 0,
    "max": 100,
    "step": 5,
    "unit": "%",
    "default": 100,
    "visible_if": "{{ section.settings.button_colors_override_enabled }}"
  },
  {
    "type": "color",
    "id": "button_text_color_override",
    "label": "Button text color",
    "visible_if": "{{ section.settings.button_colors_override_enabled }}"
  },
  {
    "type": "color",
    "id": "button_border_color_override",
    "label": "Button border color",
    "visible_if": "{{ section.settings.button_colors_override_enabled }}"
  },
  {
    "type": "range",
    "id": "button_border_width",
    "label": "Button border width",
    "min": 0,
    "max": 8,
    "step": 1,
    "unit": "px",
    "default": 0,
    "visible_if": "{{ section.settings.button_colors_override_enabled }}"
  }
]
