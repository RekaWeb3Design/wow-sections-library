{%- comment -%}
  Liquid Lab — Image Snippet

  Renders a responsive image with lazy loading or eager (LCP).
  Block-compatible.

  Required parameters:
    - image: Shopify image object (e.g. section.settings.image, block.settings.image, product.featured_image)

  Optional parameters:
    - mobile_image: separate mobile version (image object)
    - alt: alt text override (default uses image.alt)
    - sizes: sizes attribute (default '100vw')
    - widths: comma-separated widths string (default '375,550,750,1100,1500,1780,2000')
    - max_width: max width in px (default 2000)
    - aspect_ratio: '16/9' | '1/1' | '4/5' | '3/2' | 'natural' (default 'natural')
    - object_fit: 'cover' | 'contain' (default 'cover')
    - loading: 'lazy' | 'eager' (default 'lazy')
    - fetchpriority: 'auto' | 'high' (default 'auto')
    - is_lcp: boolean (when true, sets eager + high — overrides loading & fetchpriority)
    - placeholder_svg: name (default 'lifestyle-1')
    - extra_class: string
{%- endcomment -%}

{%- liquid
  assign max_width = max_width | default: 2000
  assign sizes = sizes | default: '100vw'
  assign widths = widths | default: '375,550,750,1100,1500,1780,2000'
  assign aspect_ratio = aspect_ratio | default: 'natural'
  assign object_fit = object_fit | default: 'cover'
  assign placeholder_svg = placeholder_svg | default: 'lifestyle-1'

  if is_lcp
    assign loading = 'eager'
    assign fetchpriority = 'high'
  else
    assign loading = loading | default: 'lazy'
    assign fetchpriority = fetchpriority | default: 'auto'
  endif

  assign aspect_ratio_class = ''
  if aspect_ratio != 'natural'
    assign aspect_ratio_class = ' lab_image--ratio-' | append: aspect_ratio | replace: '/', '-'
  endif
-%}

<div class="lab_image{{ aspect_ratio_class }}{% if extra_class %} {{ extra_class }}{% endif %}">
  {%- if image -%}
    {%- if mobile_image -%}
      <picture>
        <source media="(max-width: 749px)" srcset="{{ mobile_image | image_url: width: 900 }}" />
        {{- image
          | image_url: width: max_width
          | image_tag:
              alt: alt | default: image.alt | default: '',
              loading: loading,
              fetchpriority: fetchpriority,
              widths: widths,
              sizes: sizes,
              class: 'lab_image__img'
        -}}
      </picture>
    {%- else -%}
      {{- image
        | image_url: width: max_width
        | image_tag:
            alt: alt | default: image.alt | default: '',
            loading: loading,
            fetchpriority: fetchpriority,
            widths: widths,
            sizes: sizes,
            class: 'lab_image__img'
      -}}
    {%- endif -%}
  {%- else -%}
    {{ placeholder_svg | placeholder_svg_tag: 'lab_image__img lab_image__img--placeholder' }}
  {%- endif -%}
</div>

<style>
  .lab_image { display: block; width: 100%; }
  .lab_image__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: {{ object_fit }};
  }
  .lab_image--ratio-16-9 { aspect-ratio: 16/9; }
  .lab_image--ratio-1-1 { aspect-ratio: 1/1; }
  .lab_image--ratio-4-5 { aspect-ratio: 4/5; }
  .lab_image--ratio-3-2 { aspect-ratio: 3/2; }
  .lab_image__img--placeholder {
    background-color: rgba(var(--color-foreground-rgb, 10, 11, 26), 0.05);
  }
</style>
